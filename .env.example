# Copy this file to .env and fill in real values. Do NOT commit .env.
# These configure docker-compose.yml.

# SQL Server 'sa' password (REQUIRED).
# Must satisfy SQL Server complexity rules (upper, lower, digit, symbol, 8+).
MSSQL_SA_PASSWORD=Change-me_1234

# --- API storage locations --------------------------------------------------
# Where the API stores database backups and uploaded user photos.
#
# Leave BLANK to use Docker-managed named volumes (default, portable).
# Set to a HOST path to bind-mount a real folder you can browse and back up
# directly. Examples:
#   Linux / macOS:  BACKUP_PATH=/srv/doorsweb/backups
#                   USER_PHOTO_PATH=/srv/doorsweb/user-photo
#   Windows:        BACKUP_PATH=D:/DoorsData/backups
#                   USER_PHOTO_PATH=D:/DoorsData/user-photo
BACKUP_PATH=
USER_PHOTO_PATH=
