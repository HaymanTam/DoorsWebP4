# Copy this file to .env and fill in real values. Do NOT commit .env.
# These configure docker-compose.yml.

# PostgreSQL 'postgres' superuser password (REQUIRED).
POSTGRES_PASSWORD=Change-me_1234

# Optional: override the host port PostgreSQL is published on (default 5432).
# The in-container port stays 5432 (clients use doorsweb.postgres:5432).
# POSTGRES_HOST_PORT=5432

# --- API storage locations --------------------------------------------------
# Where the API stores database backups, uploaded user photos, cardholder
# photos, and the System Settings (connector polling) JSON file.
#
# Leave BLANK to use Docker-managed named volumes (default, portable).
# Set to a HOST path to bind-mount a real folder you can browse and back up
# directly. Examples:
#   Linux / macOS:  BACKUP_PATH=/srv/doorsweb/backups
#                   USER_PHOTO_PATH=/srv/doorsweb/user-photo
#                   CARD_PHOTO_PATH=/srv/doorsweb/card-photo
#                   SETTINGS_PATH=/srv/doorsweb/settings
#   Windows:        BACKUP_PATH=D:/DoorsData/backups
#                   USER_PHOTO_PATH=D:/DoorsData/user-photo
#                   CARD_PHOTO_PATH=D:/DoorsData/card-photo
#                   SETTINGS_PATH=D:/DoorsData/settings
BACKUP_PATH=
USER_PHOTO_PATH=
CARD_PHOTO_PATH=
SETTINGS_PATH=
