{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Backup": {
    "Directory": ""
  },
  "Storage": {
    "UserPhotoDirectory": ""
  },
  "UdpProtocol": {
    "ListenPort": 10012,
    "DefaultSendPort": 10012
  },
  "Jwt": {
    "SecretKey": "CHANGE-ME-use-a-long-random-secret-32chars+",
    "Issuer": "DoorsWeb",
    "Audience": "DoorsWeb",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "7"
  }
}
