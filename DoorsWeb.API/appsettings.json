{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Backup": {
    "Directory": ""
  },
  "Storage": {
    "UserPhotoDirectory": "",
    "CardPhotoDirectory": "",
    "SettingsDirectory": ""
  },
  "UdpProtocol": {
    "ListenPort": 10013,
    "DefaultSendPort": 10012
  },
  "Jwt": {
    // SecretKey is intentionally blank in source control. Supply it per
    // environment and never commit it: dev via
    //   dotnet user-secrets set "Jwt:SecretKey" "<random 32+ byte value>"
    // deployed environments via the Jwt__SecretKey environment variable.
    "SecretKey": "",
    "Issuer": "DoorsWeb",
    "Audience": "DoorsWeb",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "7"
  },
  "Licensing": {
    // Public key used to verify signed license keys. PEM (SubjectPublicKeyInfo) or a single-line
    // base64 of the same. The matching PRIVATE key lives only in the keygen / payment site and is
    // never committed or shipped. Blank = unlicensed mode (any key is rejected).
    "PublicKey": "",
    // Limits applied when there is no valid license. Full read/write, just a small product tier.
    "UnlicensedMaxDoors": 5,
    "UnlicensedMaxCards": 25
  }
}
