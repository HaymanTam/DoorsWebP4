{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Backup": {
    "Directory": ""
  },
  "Storage": {
    "UserPhotoDirectory": "",
    "SettingsDirectory": ""
  },
  "UdpProtocol": {
    "ListenPort": 10012,
    "DefaultSendPort": 10012
  },
  "Jwt": {
    // SecretKey is intentionally blank in source control. Supply it per
    // environment and never commit it: dev via
    //   dotnet user-secrets set "Jwt:SecretKey" "<random 32+ byte value>"
    // deployed environments via the Jwt__SecretKey environment variable.
    "SecretKey": "",
    "Issuer": "DoorsWeb",
    "Audience": "DoorsWeb",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "7"
  }
}
