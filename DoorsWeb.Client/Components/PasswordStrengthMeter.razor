@* Live password-strength bar + label. Drop under a password input and pass the bound value:
   <PasswordStrengthMeter Password="@context.Password" />
   Scoring lives in PasswordStrength so the page can also gate saving on it. *@

@if (level == PasswordStrengthLevel.None)
{
    <div class="form-text">Minimum 8 characters with a mix of letters, numbers or symbols.</div>
}
else
{
    <div class="progress mt-1" style="height: 4px;">
        <div class="progress-bar bg-@color" role="progressbar" style="width: @percent%;"
             aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
    <div class="form-text text-@color">
        Password strength: <strong>@label</strong>
        @if (level < PasswordStrength.MinimumToSave)
        {
            <span class="text-muted">— too weak to save</span>
        }
    </div>
}

@code {
    /// <summary>The password to score (typically the bound editor value).</summary>
    [Parameter] public string? Password { get; set; }

    private PasswordStrengthLevel level;
    private string label = "";
    private string color = "secondary";
    private int percent;

    protected override void OnParametersSet()
    {
        level = PasswordStrength.Evaluate(Password);
        label = PasswordStrength.Label(level);
        color = PasswordStrength.ColorClass(level);
        percent = PasswordStrength.Percent(level);
    }
}
