@* Recursive node for the User Properties → Permissions checkbox tree.
   Checking/unchecking a node cascades to all of its descendants. *@

<li class="list-unstyled">
    <div class="d-flex align-items-center py-1">
        @if (Node.Children.Count > 0)
        {
            <button type="button" class="btn btn-sm p-0 me-1 border-0 bg-transparent" style="width: 1.25rem;" @onclick="Toggle">
                <Icon IconType="@(Node.Expanded ? TablerIcons.Minus : TablerIcons.Plus)" />
            </button>
        }
        else
        {
            <span class="d-inline-block me-1" style="width: 1.25rem;"></span>
        }
        <label class="form-check mb-0 d-flex align-items-center">
            <input type="checkbox" class="form-check-input mt-0 me-2" checked="@Node.Checked" @onchange="OnChecked" />
            <Icon class="icon me-2" IconType="@Node.IconType" />
            <span class="form-check-label">@Node.Name</span>
        </label>
    </div>

    @if (Node.Expanded && Node.Children.Count > 0)
    {
        <ul class="ms-4 ps-2 mb-0">
            @foreach (var child in Node.Children)
            {
                <PermissionTreeNode Node="child" />
            }
        </ul>
    }
</li>

@code {
    [Parameter, EditorRequired] public PermissionNode Node { get; set; } = null!;

    private void Toggle() => Node.Expanded = !Node.Expanded;

    private void OnChecked(ChangeEventArgs e)
    {
        SetChecked(Node, e.Value is bool b && b);
    }

    private static void SetChecked(PermissionNode node, bool value)
    {
        node.Checked = value;
        foreach (var child in node.Children)
        {
            SetChecked(child, value);
        }
    }
}
