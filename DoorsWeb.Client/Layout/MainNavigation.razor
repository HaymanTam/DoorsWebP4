@using DoorsWeb.Client.Auth
@using DoorsWeb.Client.Components
@using DoorsWeb.Client.Pages
@using DoorsWeb.Shared.DTO
@using DoorsWeb.Shared.Entities
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject JwtAuthStateProvider AuthStateProvider
@inject IHttpClientFactory ClientFactory
@inject TabBlazor.Services.IModalService ModalService

<Navbar Direction=NavbarDirection.Vertical Background=NavbarBackground.Dark>

    <a href="/" class="navbar-brand d-flex align-items-center">
        <img src="img/fingerprint.svg" alt="Doors Web" class="navbar-brand-image me-2" style="height: 2.5rem; width: auto;">
        <div class="m-0 lh-1">
            <div class="text-uppercase text-muted mb-1" style="font-size: .65rem; letter-spacing: .1em;">Progeny</div>
            <div class="d-flex align-items-center">
                <span class="fw-bold text-white" style="font-size: 1.15rem;">Doors Web</span>
                <span class="badge bg-red text-white ms-2">P4</span>
            </div>
        </div>
    </a>

    <NavbarMenu>
        <AuthorizeView>
            <Authorized>
                <NavbarMenuItem Href="events" Text="Events">
                    <MenuItemIcon>
                        <Icon class="icon" IconType="@TablerIcons.Search" />
                    </MenuItemIcon>
                </NavbarMenuItem>
                <NavbarMenuItem Href="alarms" Text="Alarms">
                    <MenuItemIcon>
                        <Icon class="icon" IconType="@TablerIcons.Alert_triangle" />
                    </MenuItemIcon>
                </NavbarMenuItem>
                <NavbarMenuItem Href="cardmanager" Text="Card Manager">
                    <MenuItemIcon>
                        <Icon class="icon" IconType="@TablerIcons.Users" />
                    </MenuItemIcon>
                </NavbarMenuItem>

                @* ---- Site: Temp (click to expand) ---- *@
                <li class="nav-item">
                    <a class="nav-link" href="#" @onclick="ToggleTemp" @onclick:preventDefault>
                        <span class="nav-link-icon">
                            <Icon class="icon" IconType="@TablerIcons.Building" />
                        </span>
                        <span class="nav-link-title">Temp</span>
                        <span class="ms-auto">
                            <Icon IconType="@(tempOpen ? TablerIcons.Chevron_down : TablerIcons.Chevron_right)" />
                        </span>
                    </a>
                </li>
                @if (tempOpen)
                {
                    <div class="ms-4">
                        <li class="nav-item">
                            <NavLink class="nav-link" href="doors">
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Door" /></span>
                                <span class="nav-link-title">Doors</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowAccessLevelsModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Key" /></span>
                                <span class="nav-link-title">Access Levels</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowTimeZonesModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Clock" /></span>
                                <span class="nav-link-title">Time Zones</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowCalendarsModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Calendar_clock" /></span>
                                <span class="nav-link-title">Calendars</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowSpaceZonesModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.World" /></span>
                                <span class="nav-link-title">Space Zones</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowApbZonesModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Hand_stop" /></span>
                                <span class="nav-link-title">Anti-Passback Zones</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowDoorTriggerModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Flag_bolt" /></span>
                                <span class="nav-link-title">Door Triggers</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowSpaceZoneTriggerModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Flag_pin" /></span>
                                <span class="nav-link-title">Space Zone Triggers</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="floorplans">
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Home" /></span>
                                <span class="nav-link-title">Floor Plans</span>
                            </NavLink>
                        </li>
                    </div>
                }

                @* ---- Control Panel (click to expand) ---- *@
                <li class="nav-item">
                    <a class="nav-link" href="#" @onclick="ToggleControlPanel" @onclick:preventDefault>
                        <span class="nav-link-icon">
                            <Icon class="icon" IconType="@TablerIcons.Settings" />
                        </span>
                        <span class="nav-link-title">Control Panel</span>
                        <span class="ms-auto">
                            <Icon IconType="@(controlPanelOpen ? TablerIcons.Chevron_down : TablerIcons.Chevron_right)" />
                        </span>
                    </a>
                </li>
                @if (controlPanelOpen)
                {
                    <div class="ms-4">
                        <li class="nav-item">
                            <NavLink class="nav-link" href="updatehardware">
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Refresh" /></span>
                                <span class="nav-link-title">Update Hardware</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowBackupRestoreModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Database" /></span>
                                <span class="nav-link-title">Backup and Restore</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="userspasswords">
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.User_star" /></span>
                                <span class="nav-link-title">Users and Passwords</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowSystemSettingsModal" @onclick:preventDefault>
                                <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Adjustments" /></span>
                                <span class="nav-link-title">System Settings</span>
                            </a>
                        </li>
                    </div>
                }

                @* ---- Login/Logout pinned to bottom ---- *@
                <li class="nav-item mt-auto">
                    <a class="nav-link" href="#" @onclick="Logout" @onclick:preventDefault>
                        <span class="nav-link-icon">
                            <Icon class="icon" IconType="@TablerIcons.Logout" />
                        </span>
                        <span class="nav-link-title">Logout</span>
                    </a>
                </li>
            </Authorized>
            <NotAuthorized>
                <li class="nav-item mt-auto">
                    <NavbarMenuItem Href="login" Text="Sign in">
                        <MenuItemIcon>
                            <Icon class="icon" IconType="@TablerIcons.Login" />
                        </MenuItemIcon>
                    </NavbarMenuItem>
                </li>
            </NotAuthorized>
        </AuthorizeView>
    </NavbarMenu>
</Navbar>

@code {
    private bool tempOpen = true;
    private bool controlPanelOpen = false;

    // Accordion behaviour: opening one section collapses the other so only one is expanded at a time.
    private void ToggleTemp()
    {
        tempOpen = !tempOpen;
        if (tempOpen) controlPanelOpen = false;
    }

    private void ToggleControlPanel()
    {
        controlPanelOpen = !controlPanelOpen;
        if (controlPanelOpen) tempOpen = false;
    }

    // ---- Access Levels: shared name-only list modal (replaces the /accesslevels page link) ----
    private async Task ShowAccessLevelsModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Access Level")
            .Set(e => e.Load, LoadAccessLevelRows)
            .Set(e => e.OnAdd, () => ShowAccessLevelEdit(null))
            .Set(e => e.OnEdit, (EntityListRow row) => ShowAccessLevelEdit(row))
            .Set(e => e.OnDelete, DeleteAccessLevel);

        await ModalService.ShowAsync("Access Levels", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task<List<EntityListRow>> LoadAccessLevelRows()
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<AccessLevelDto>>("api/AccessLevel") ?? new();
        return list.Select(a => new EntityListRow { Id = a.Id.ToString(), Name = a.Name ?? "" }).ToList();
    }

    private async Task ShowAccessLevelEdit(EntityListRow? row)
    {
        var title = row is null ? "Access levels - New access level" : "Access levels - Edit access level";
        var seed = row is null ? null : new AccessLevelModal.AccessLevelModel { Name = row.Name };
        var component = new RenderComponent<AccessLevelModal>().Set(e => e.Level, seed);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task DeleteAccessLevel(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/AccessLevel/" + row.Id);
    }

    // ---- Time Zones: name-only list modal (api/TimeZoneHeader, key { Site, TimeZone }) ----
    private async Task ShowTimeZonesModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Time Zone")
            .Set(e => e.Load, LoadTimeZoneRows)
            .Set(e => e.OnAdd, () => ShowTimeZoneEdit(null))
            .Set(e => e.OnEdit, (EntityListRow row) => ShowTimeZoneEdit(row))
            .Set(e => e.OnDelete, DeleteTimeZone);

        await ModalService.ShowAsync("Time Zones", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task<List<EntityListRow>> LoadTimeZoneRows()
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<TTimeZoneHeader>>("api/TimeZoneHeader") ?? new();
        // Delete route is api/TimeZoneHeader/{site}/{timeZone}, so encode both into the row Id.
        return list.Select(t => new EntityListRow { Id = $"{t.Site}/{t.TimeZone}", Name = t.Name ?? "" }).ToList();
    }

    private async Task ShowTimeZoneEdit(EntityListRow? row)
    {
        var title = row is null ? "Time zones - New time zone" : "Time zones - Edit time zone";
        var seed = row is null ? null : new TimeZoneModal.TimeZoneModel { Name = row.Name };
        var component = new RenderComponent<TimeZoneModal>().Set(e => e.TimeZone, seed);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task DeleteTimeZone(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/TimeZoneHeader/" + row.Id);
    }

    // ---- Calendars: name-only list modal (api/CalendarHeader, key Code) ----
    private async Task ShowCalendarsModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Calendar")
            .Set(e => e.Load, LoadCalendarRows)
            .Set(e => e.OnAdd, () => ShowCalendarEdit(null))
            .Set(e => e.OnEdit, (EntityListRow row) => ShowCalendarEdit(row))
            .Set(e => e.OnDelete, DeleteCalendar);

        await ModalService.ShowAsync("Calendars", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task<List<EntityListRow>> LoadCalendarRows()
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<TCalendarHeader>>("api/CalendarHeader") ?? new();
        return list.Select(c => new EntityListRow { Id = c.Code.ToString(), Name = c.Description ?? "" }).ToList();
    }

    private async Task ShowCalendarEdit(EntityListRow? row)
    {
        var title = row is null ? "Calendars - New calendar" : "Calendars - Edit calendar";
        var seed = row is null ? null : new CalendarModal.CalendarModel { Name = row.Name };
        var component = new RenderComponent<CalendarModal>().Set(e => e.Calendar, seed);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
