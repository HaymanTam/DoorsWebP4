@using DoorsWeb.Client.Auth
@using DoorsWeb.Client.Components
@using DoorsWeb.Client.Pages
@using DoorsWeb.Client.Services
@using DoorsWeb.Shared.DTO
@using DoorsWeb.Shared.Entities
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject JwtAuthStateProvider AuthStateProvider
@inject IHttpClientFactory ClientFactory
@inject DoorStatusStore DoorStatus
@inject TabBlazor.Services.IModalService ModalService

<Navbar Direction=NavbarDirection.Vertical Background=NavbarBackground.Dark>

    <a href="/" class="navbar-brand d-flex align-items-center">
        <img src="img/fingerprint.svg" alt="Doors Web" class="navbar-brand-image me-2" style="height: 2.5rem; width: auto;">
        <div class="m-0 lh-1">
            <div class="text-uppercase text-muted mb-1" style="font-size: .65rem; letter-spacing: .1em;">Progeny</div>
            <div class="d-flex align-items-center">
                <span class="fw-bold text-white" style="font-size: 1.15rem;">Doors Web</span>
                <span class="badge bg-red text-white ms-2">P4</span>
            </div>
        </div>
    </a>

    <NavbarMenu>
        <AuthorizeView>
            <Authorized Context="auth">
                @* Events and Alarms are visible to any authenticated user. *@
                <NavbarMenuItem Href="events" Text="Events">
                    <MenuItemIcon>
                        <Icon class="icon" IconType="@TablerIcons.Search" />
                    </MenuItemIcon>
                </NavbarMenuItem>
                <li class="nav-item">
                    <NavLink class="nav-link" href="alarms">
                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Alert_triangle" /></span>
                        <span class="nav-link-title">Alarms</span>
                        @* Live count of doors currently in alarm (all sites), right-aligned (ms-auto) to match the
                           chevrons. The .nav-count-badge class hooks the site.css override that undoes Tabler's
                           top-right corner notification-dot positioning. *@
                        @if (auth.User.CanReadSiteSettings() && DoorStatus.AlarmCount > 0)
                        {
                            <span class="badge bg-red text-white nav-count-badge ms-auto" title="@($"{DoorStatus.AlarmCount} in alarm")">
                                @DoorStatus.AlarmCount
                            </span>
                        }
                    </NavLink>
                </li>
                @if (auth.User.CanReadCardManager())
                {
                    <NavbarMenuItem Href="cardmanager" Text="Card Manager">
                        <MenuItemIcon>
                            <Icon class="icon" IconType="@TablerIcons.Users" />
                        </MenuItemIcon>
                    </NavbarMenuItem>
                }
                @* Reports hub: categorized report catalogue + generic runner. Needs the Reports area. *@
                @if (auth.User.CanReadReports())
                {
                    <NavbarMenuItem Href="reports" Text="Reports">
                        <MenuItemIcon>
                            <Icon class="icon" IconType="@TablerIcons.Report" />
                        </MenuItemIcon>
                    </NavbarMenuItem>
                }

                @* ---- One collapsible group per site (click to expand). Requires Site Settings read. ---- *@
                @if (auth.User.CanReadSiteSettings() && sites is not null)
                {
                    @foreach (var site in sites)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="() => ToggleSite(site.Site)" @onclick:preventDefault>
                                <span class="nav-link-icon">
                                    <Icon class="icon" IconType="@TablerIcons.Building" />
                                </span>
                                <span class="nav-link-title">@site.Name</span>
                                <span class="ms-auto">
                                    <Icon IconType="@(openSiteId == site.Site ? TablerIcons.Chevron_down : TablerIcons.Chevron_right)" />
                                </span>
                            </a>
                        </li>
                        @if (openSiteId == site.Site)
                        {
                            <div class="ms-4">
                                <li class="nav-item">
                                    <NavLink class="nav-link" href="@($"doors/{site.Site}")">
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Door" /></span>
                                        <span class="nav-link-title">Doors</span>
                                        @* Inactive (offline) door count, right-aligned (ms-auto) to line up with the
                                           collapse chevrons. Tabler force-positions any .badge inside a navbar .nav-link
                                           to the link's top-right corner (its notification-dot pattern); the
                                           .nav-count-badge class hooks the site.css override that restores normal flow,
                                           letting ms-auto push it to the right edge instead. *@
                                        @if (DoorStatus.InactiveCountFor(site.Site) > 0)
                                        {
                                            <span class="badge bg-orange text-white nav-count-badge ms-auto"
                                                  title="@($"{DoorStatus.InactiveCountFor(site.Site)} inactive")">
                                                @DoorStatus.InactiveCountFor(site.Site)
                                            </span>
                                        }
                                    </NavLink>
                                </li>
                                @* Live floorplan deep-linked to this site. Edit (place doors) is gated to site-write inside the page. *@
                                <li class="nav-item">
                                    <NavLink class="nav-link" href="@($"floorplan/{site.Site}")">
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Map_2" /></span>
                                        <span class="nav-link-title">Floorplan</span>
                                    </NavLink>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="() => ShowAccessLevelsModal(site)" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Key" /></span>
                                        <span class="nav-link-title">Access Levels</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="() => ShowTimeZonesModal(site)" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Clock" /></span>
                                        <span class="nav-link-title">Time Zones</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="() => ShowCalendarsModal(site)" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Calendar_clock" /></span>
                                        <span class="nav-link-title">Calendars</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="() => ShowSpaceZonesModal(site)" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.World" /></span>
                                        <span class="nav-link-title">Space Zones</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="() => ShowApbZonesModal(site)" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Hand_stop" /></span>
                                        <span class="nav-link-title">Anti-Passback Zones</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="() => ShowDoorTriggerModal(site)" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Flag_bolt" /></span>
                                        <span class="nav-link-title">Door Triggers</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="() => ShowSpaceZoneTriggerModal(site)" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Flag_pin" /></span>
                                        <span class="nav-link-title">Space Zone Triggers</span>
                                    </a>
                                </li>
                            </div>
                        }
                    }
                }

                @* ---- Control Panel (click to expand). Shown only when at least one child is visible. ---- *@
                @if (auth.User.CanReadSiteSettings() || auth.User.CanReadUserSettings())
                {
                    <li class="nav-item">
                        <a class="nav-link" href="#" @onclick="ToggleControlPanel" @onclick:preventDefault>
                            <span class="nav-link-icon">
                                <Icon class="icon" IconType="@TablerIcons.Settings" />
                            </span>
                            <span class="nav-link-title">Control Panel</span>
                            <span class="ms-auto">
                                <Icon IconType="@(controlPanelOpen ? TablerIcons.Chevron_down : TablerIcons.Chevron_right)" />
                            </span>
                        </a>
                    </li>
                    @if (controlPanelOpen)
                    {
                        <div class="ms-4">
                            @* Update Hardware and Backup push to controllers, so require Site write. *@
                            @if (auth.User.CanWriteSiteSettings())
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="ShowUpdateHardwareModal" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Refresh" /></span>
                                        <span class="nav-link-title">Update Hardware</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="ShowBackupRestoreModal" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Database" /></span>
                                        <span class="nav-link-title">Backup and Restore</span>
                                    </a>
                                </li>
                            }
                            @if (auth.User.CanReadUserSettings())
                            {
                                <li class="nav-item">
                                    <NavLink class="nav-link" href="userspasswords">
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.User_star" /></span>
                                        <span class="nav-link-title">Users and Passwords</span>
                                    </NavLink>
                                </li>
                                <li class="nav-item">
                                    <NavLink class="nav-link" href="audit">
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Timeline" /></span>
                                        <span class="nav-link-title">Audit Log</span>
                                    </NavLink>
                                </li>
                            }
                            @if (auth.User.CanReadSiteSettings())
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="#" @onclick="ShowSystemSettingsModal" @onclick:preventDefault>
                                        <span class="nav-link-icon"><Icon class="icon" IconType="@TablerIcons.Adjustments" /></span>
                                        <span class="nav-link-title">System Settings</span>
                                    </a>
                                </li>
                            }
                        </div>
                    }
                }

                @* ---- Login/Logout pinned to bottom ---- *@
                <li class="nav-item mt-auto">
                    <a class="nav-link" href="#" @onclick="Logout" @onclick:preventDefault>
                        <span class="nav-link-icon">
                            <Icon class="icon" IconType="@TablerIcons.Logout" />
                        </span>
                        <span class="nav-link-title">Logout</span>
                    </a>
                </li>
            </Authorized>
            <NotAuthorized>
                <li class="nav-item mt-auto">
                    <NavbarMenuItem Href="login" Text="Sign in">
                        <MenuItemIcon>
                            <Icon class="icon" IconType="@TablerIcons.Login" />
                        </MenuItemIcon>
                    </NavbarMenuItem>
                </li>
            </NotAuthorized>
        </AuthorizeView>
    </NavbarMenu>
</Navbar>

@code {
    // The list of sites that each get their own collapsible nav group.
    private List<SiteDto>? sites;
    // Id of the currently expanded site group (null = none). Acts as an accordion with Control Panel.
    private int? openSiteId;
    private bool controlPanelOpen = false;

    // Whether the signed-in user may mutate site config (Site Settings ReadWrite). When false the
    // site-config list modals are opened read-only (no Add/Edit/Delete). The API still enforces it.
    private bool canWriteSite;

    protected override async Task OnInitializedAsync()
    {
        // Reload the site list whenever the auth state changes (e.g. after sign-in),
        // since the nav is long-lived and OnInitialized only runs once.
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
        DoorStatus.Changed += OnDoorStatusChanged;
        await LoadSites();
    }

    // Repaint the nav badges whenever a door's live state changes.
    private void OnDoorStatusChanged() => InvokeAsync(StateHasChanged);

    private async void OnAuthStateChanged(Task<AuthenticationState> _)
    {
        await LoadSites();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadSites()
    {
        try
        {
            // The site groups need Site Settings read; skip the call otherwise (the API would 403).
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            canWriteSite = state.User.CanWriteSiteSettings();
            if (!state.User.CanReadSiteSettings())
            {
                sites = new();
                openSiteId = null;
                return;
            }

            // Start the live door-status feed (idempotent) so the nav problem badge updates.
            await DoorStatus.EnsureStartedAsync();

            var client = ClientFactory.CreateClient("WebAPI");
            sites = await client.GetFromJsonAsync<List<SiteDto>>("api/Sites") ?? new();

            // Keep the open group valid; default to the first site when nothing is selected.
            if (sites.Count == 0)
                openSiteId = null;
            else if (openSiteId is null || sites.All(s => s.Site != openSiteId))
                openSiteId = sites[0].Site;
        }
        catch
        {
            // Anonymous (pre-login) or transient failure: render no site groups.
            sites = new();
        }
    }

    // Accordion behaviour: opening one section collapses the other so only one is expanded at a time.
    private void ToggleSite(int siteId)
    {
        openSiteId = openSiteId == siteId ? null : siteId;
        if (openSiteId is not null) controlPanelOpen = false;
    }

    private void ToggleControlPanel()
    {
        controlPanelOpen = !controlPanelOpen;
        if (controlPanelOpen) openSiteId = null;
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
        DoorStatus.Changed -= OnDoorStatusChanged;
    }

    // ---- Access Levels: name-only list modal (api/AccessLevel, key { Site, AccessLevel }) ----
    private async Task ShowAccessLevelsModal(SiteDto site)
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Access Level")
            .Set(e => e.Load, () => LoadAccessLevelRows(site.Site));
        // Read-only users get a view-only list (EntityListModal hides Add/Edit/Delete when these are null).
        if (canWriteSite)
            component.Set(e => e.OnAdd, () => ShowAccessLevelEdit(site, null))
                     .Set(e => e.OnEdit, (EntityListRow row) => ShowAccessLevelEdit(site, row))
                     .Set(e => e.OnDelete, DeleteAccessLevel);

        await ModalService.ShowAsync($"Access Levels — {site.Name}", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
            CloseOnEsc = true,
        });
    }

    private async Task<List<EntityListRow>> LoadAccessLevelRows(int siteId)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<AccessLevels>>("api/AccessLevel") ?? new();
        // Delete route is api/AccessLevel/{site}/{accessLevel}, so encode both into the row Id.
        return list.Where(a => a.Site == siteId)
                   .Select(a => new EntityListRow { Id = $"{a.Site}/{a.AccessLevel}", Name = a.Name ?? "" }).ToList();
    }

    private async Task ShowAccessLevelEdit(SiteDto site, EntityListRow? row)
    {
        var title = row is null ? "Access levels - New access level" : "Access levels - Edit access level";
        // Row Id is "{site}/{accessLevel}"; the second segment is the level number.
        int? accessLevelId = row is null ? null : int.Parse(row.Id.Split('/')[1]);
        var component = new RenderComponent<AccessLevelModal>()
            .Set(e => e.SiteId, site.Site);
        // TabBlazor's RenderComponent.Set rejects null, so only set the key when editing.
        if (accessLevelId is int id) component.Set(e => e.AccessLevelId, id);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task DeleteAccessLevel(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/AccessLevel/" + row.Id);
    }

    // ---- Time Zones: name-only list modal (api/TimeZone, key { Site, TimeZone }) ----
