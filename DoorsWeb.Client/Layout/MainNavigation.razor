    private async Task DeleteTrigger(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/Trigger/" + row.Id);
    }

    private async Task ShowBackupRestoreModal()
    {
        // Share the options instance with the modal body so it can hide the header
        // close (X) button while a backup/restore is in progress (see BackupRestoreModal.busy).
        var options = new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        };
        var component = new RenderComponent<BackupRestoreModal>().Set(c => c.Options, options);
        await ModalService.ShowAsync("Backup and Restore", component, options);
    }

