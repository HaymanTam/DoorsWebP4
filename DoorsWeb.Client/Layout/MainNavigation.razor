    private async Task ShowSystemSettingsModal()
    {
        var component = new RenderComponent<SystemSettingsModal>();
        await ModalService.ShowAsync("System Settings", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "access_token");
        await JS.InvokeVoidAsync("localStorage.removeItem", "refresh_token");
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("/login");
    }
}
