        return list.Where(t => t.Site == siteId)
                   .Select(t => new EntityListRow { Id = $"{t.Site}/{t.TimeZone}", Name = t.Name ?? "" }).ToList();
    }

    private async Task ShowTimeZoneEdit(SiteDto site, EntityListRow? row)
