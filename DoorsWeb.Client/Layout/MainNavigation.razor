    // ---- Anti-Passback Zones: name-only list modal (api/ApbzoneHeader, key Apbnumber) ----
    private async Task ShowApbZonesModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Anti-Passback Zone")
            .Set(e => e.Load, LoadApbZoneRows)
