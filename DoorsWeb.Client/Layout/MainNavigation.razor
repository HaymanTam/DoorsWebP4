    private async Task<List<EntityListRow>> LoadSpaceZoneTriggerRows()
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<TTriggersHeader>>("api/TriggersHeader") ?? new();
        return list.Where(t => t.TriggerType == 3)
                   .Select(t => new EntityListRow { Id = t.Code.ToString(), Name = t.Name }).ToList();
    }

    private async Task ShowSpaceZoneTriggerEdit(EntityListRow? row)
    {
        var title = row is null ? "Triggers - New Trigger" : "Triggers - Edit Trigger";
        var seed = row is null ? null : new SpaceZoneTriggerModal.SpaceZoneTriggerModel { Name = row.Name };
        var component = new RenderComponent<SpaceZoneTriggerModal>().Set(e => e.Trigger, seed);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
