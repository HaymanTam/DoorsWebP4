    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Space Zone Trigger")
            .Set(e => e.Load, () => LoadSpaceZoneTriggerRows(site.Site));
        if (canWriteSite)
            component.Set(e => e.OnAdd, () => ShowSpaceZoneTriggerEdit(site, null))
                     .Set(e => e.OnEdit, (EntityListRow row) => ShowSpaceZoneTriggerEdit(site, row))
                     .Set(e => e.OnDelete, DeleteTrigger);

        await ModalService.ShowAsync($"Space Zone Triggers — {site.Name}", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
            CloseOnEsc = true,
