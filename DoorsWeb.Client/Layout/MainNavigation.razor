    private async Task DeleteCalendar(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/CalendarHeader/" + row.Id);
    }

    // ---- Space Zones: name-only list modal (api/SpaceZoneHeader, key ZoneNumber) ----
