        var list = await client.GetFromJsonAsync<List<TApbzoneHeader>>("api/ApbzoneHeader") ?? new();
        return list.Select(z => new EntityListRow { Id = z.Apbnumber.ToString(), Name = z.Name ?? "" }).ToList();
    }

    private async Task ShowApbZoneEdit(EntityListRow? row)
    {
        var title = row is null ? "Anti-passback zones - New zone" : "Anti-passback zones - Edit zone";
        var seed = row is null ? null : new AntiPassbackZoneModal.AntiPassbackZoneModel { Name = row.Name };
        var component = new RenderComponent<AntiPassbackZoneModal>().Set(e => e.Zone, seed);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task DeleteApbZone(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/ApbzoneHeader/" + row.Id);
    }

    // ---- Door Triggers: name-only list modal (api/TriggersHeader where TriggerType == 1) ----
    private async Task ShowDoorTriggerModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Door Trigger")
            .Set(e => e.Load, LoadDoorTriggerRows)
            .Set(e => e.OnAdd, () => ShowDoorTriggerEdit(null))
            .Set(e => e.OnEdit, (EntityListRow row) => ShowDoorTriggerEdit(row))
            .Set(e => e.OnDelete, DeleteTrigger);

        await ModalService.ShowAsync("Door Triggers", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task<List<EntityListRow>> LoadDoorTriggerRows()
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<TTriggersHeader>>("api/TriggersHeader") ?? new();
        // TriggerType: 1 = Door, 3 = SpaceZone (legacy TriggerTypeConstants).
        return list.Where(t => t.TriggerType == 1)
                   .Select(t => new EntityListRow { Id = t.Code.ToString(), Name = t.Name }).ToList();
    }

    private async Task ShowDoorTriggerEdit(EntityListRow? row)
    {
        var title = row is null ? "Triggers - New Trigger" : "Triggers - Edit Trigger";
        var seed = row is null ? null : new TriggerModal.TriggerModel { Name = row.Name };
        var component = new RenderComponent<TriggerModal>().Set(e => e.Trigger, seed);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    // ---- Space Zone Triggers: name-only list modal (api/TriggersHeader where TriggerType == 3) ----
    private async Task ShowSpaceZoneTriggerModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Space Zone Trigger")
            .Set(e => e.Load, LoadSpaceZoneTriggerRows)
            .Set(e => e.OnAdd, () => ShowSpaceZoneTriggerEdit(null))
            .Set(e => e.OnEdit, (EntityListRow row) => ShowSpaceZoneTriggerEdit(row))
            .Set(e => e.OnDelete, DeleteTrigger);

        await ModalService.ShowAsync("Space Zone Triggers", component, new ModalOptions
        {
