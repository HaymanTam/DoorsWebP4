        await ModalService.ShowAsync("Space Zones", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task<List<EntityListRow>> LoadSpaceZoneRows()
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<TSpaceZoneHeader>>("api/SpaceZoneHeader") ?? new();
        return list.Select(z => new EntityListRow { Id = z.ZoneNumber.ToString(), Name = z.Name ?? "" }).ToList();
