    // ---- Door Triggers: name-only list modal (api/Trigger where TriggerType == 1) ----
    private async Task ShowDoorTriggerModal(SiteDto site)
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Door Trigger")
            .Set(e => e.Load, () => LoadDoorTriggerRows(site.Site));
        if (canWriteSite)
            component.Set(e => e.OnAdd, () => ShowDoorTriggerEdit(site, null))
                     .Set(e => e.OnEdit, (EntityListRow row) => ShowDoorTriggerEdit(site, row))
                     .Set(e => e.OnDelete, DeleteTrigger);

        await ModalService.ShowAsync($"Door Triggers — {site.Name}", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
            CloseOnEsc = true,
        });
    }

    private async Task<List<EntityListRow>> LoadDoorTriggerRows(int siteId)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<Trigger>>("api/Trigger") ?? new();
        // TriggerType: 1 = Door, 3 = SpaceZone (legacy TriggerTypeConstants).
        return list.Where(t => t.TriggerType == 1 && t.Site == siteId)
                   .Select(t => new EntityListRow { Id = t.Code.ToString(), Name = t.Name }).ToList();
    }

    private async Task ShowDoorTriggerEdit(SiteDto site, EntityListRow? row)
    {
        var title = row is null ? "Triggers - New Trigger" : "Triggers - Edit Trigger";
        // Row Id is the trigger code.
        int? code = row is null ? null : int.Parse(row.Id);
        var component = new RenderComponent<TriggerModal>()
            .Set(e => e.SiteId, site.Site);
        // TabBlazor's RenderComponent.Set rejects null, so only set the key when editing.
        if (code is int c) component.Set(e => e.Code, c);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    // ---- Space Zone Triggers: name-only list modal (api/Trigger where TriggerType == 3) ----
