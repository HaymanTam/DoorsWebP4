        return list.Where(c => c.Site == siteId)
                   .Select(c => new EntityListRow { Id = c.Code.ToString(), Name = c.Description ?? "" }).ToList();
    }

    private async Task ShowCalendarEdit(SiteDto site, EntityListRow? row)
    {
        var title = row is null ? "Calendars - New calendar" : "Calendars - Edit calendar";
        var component = new RenderComponent<CalendarModal>()
            .Set(e => e.SiteId, site.Site);
        // TabBlazor's RenderComponent.Set rejects null, so only set the key when editing.
        if (row is not null) component.Set(e => e.Code, int.Parse(row.Id));

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task DeleteCalendar(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/Calendar/" + row.Id);
    }

    // ---- Space Zones: name-only list modal (api/SpaceZone, key ZoneNumber) ----
    private async Task ShowSpaceZonesModal(SiteDto site)
