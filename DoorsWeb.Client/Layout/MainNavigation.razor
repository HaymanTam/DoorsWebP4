@using DoorsWeb.Client.Auth
@using DoorsWeb.Client.Components
@using DoorsWeb.Client.Pages
@using DoorsWeb.Shared.DTO
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject JwtAuthStateProvider AuthStateProvider
@inject IHttpClientFactory ClientFactory
@inject TabBlazor.Services.IModalService ModalService

<Navbar Direction=NavbarDirection.Vertical Background=NavbarBackground.Dark>

    <a href="/" class="navbar-brand d-flex align-items-center">
        <img src="img/fingerprint.svg" alt="Doors Web" class="navbar-brand-image me-2" style="height: 2.5rem; width: auto;">
        <div class="m-0 lh-1">
            <div class="text-uppercase text-muted mb-1" style="font-size: .65rem; letter-spacing: .1em;">Progeny</div>
            <div class="d-flex align-items-center">
                <span class="fw-bold text-white" style="font-size: 1.15rem;">Doors Web</span>
                <span class="badge bg-red text-white ms-2">P4</span>
            </div>
        </div>
    </a>

    <NavbarMenu>
        <AuthorizeView>
            <Authorized>
                <NavbarMenuItem Href="events" Text="Events">
                    <MenuItemIcon>
                        <Icon class="icon" IconType="@TablerIcons.Search" />
                    </MenuItemIcon>
                </NavbarMenuItem>
                <NavbarMenuItem Href="cardmanager" Text="Card Manager">
                    <MenuItemIcon>
                        <Icon class="icon" IconType="@TablerIcons.Users" />
                    </MenuItemIcon>
                </NavbarMenuItem>

                @* ---- Site: Temp (click to expand) ---- *@
                <li class="nav-item">
                    <a class="nav-link" href="#" @onclick="ToggleTemp" @onclick:preventDefault>
                        <span class="nav-link-icon">
                            <Icon class="icon" IconType="@TablerIcons.Building" />
                        </span>
                        <span class="nav-link-title">Temp</span>
                        <span class="ms-auto">
                            <Icon IconType="@(tempOpen ? TablerIcons.Chevron_down : TablerIcons.Chevron_right)" />
                        </span>
                    </a>
                </li>
                @if (tempOpen)
                {
                    <div class="ms-4">
                        <NavbarMenuItem Href="doors" Text="Doors">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.Door" /></MenuItemIcon>
                        </NavbarMenuItem>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowAccessLevelsModal" @onclick:preventDefault>
                                <span class="nav-link-icon">
                                    <Icon class="icon" IconType="@TablerIcons.Key" />
                                </span>
                                <span class="nav-link-title">Access Levels</span>
                            </a>
                        </li>
                        <NavbarMenuItem Href="timezone" Text="Time Zones">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.Clock" /></MenuItemIcon>
                        </NavbarMenuItem>
                        <NavbarMenuItem Href="calendar" Text="Calendars">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.Calendar_clock" /></MenuItemIcon>
                        </NavbarMenuItem>
                        <NavbarMenuItem Href="spacezones" Text="Space Zones">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.World" /></MenuItemIcon>
                        </NavbarMenuItem>
                        <NavbarMenuItem Href="apbzones" Text="Anti-Passback Zones">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.Hand_stop" /></MenuItemIcon>
                        </NavbarMenuItem>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowDoorTriggerModal" @onclick:preventDefault>
                                <span class="nav-link-icon">
                                    <Icon class="icon" IconType="@TablerIcons.Door" />
                                </span>
                                <span class="nav-link-title">Door Triggers</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowSpaceZoneTriggerModal" @onclick:preventDefault>
                                <span class="nav-link-icon">
                                    <Icon class="icon" IconType="@TablerIcons.World" />
                                </span>
                                <span class="nav-link-title">Space Zone Triggers</span>
                            </a>
                        </li>
                        <NavbarMenuItem Href="floorplans" Text="Floor Plans">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.Home" /></MenuItemIcon>
                        </NavbarMenuItem>
                    </div>
                }

                <NavbarMenuItem Href="alarms" Text="Alarms">
                    <MenuItemIcon>
                        <Icon class="icon" IconType="@TablerIcons.Alert_triangle" />
                    </MenuItemIcon>
                </NavbarMenuItem>

                @* ---- Control Panel (click to expand) ---- *@
                <li class="nav-item">
                    <a class="nav-link" href="#" @onclick="ToggleControlPanel" @onclick:preventDefault>
                        <span class="nav-link-icon">
                            <Icon class="icon" IconType="@TablerIcons.Settings" />
                        </span>
                        <span class="nav-link-title">Control Panel</span>
                        <span class="ms-auto">
                            <Icon IconType="@(controlPanelOpen ? TablerIcons.Chevron_down : TablerIcons.Chevron_right)" />
                        </span>
                    </a>
                </li>
                @if (controlPanelOpen)
                {
                    <div class="ms-4">
                        <NavbarMenuItem Href="updatehardware" Text="Update Hardware">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.Refresh" /></MenuItemIcon>
                        </NavbarMenuItem>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowBackupRestoreModal" @onclick:preventDefault>
                                <span class="nav-link-icon">
                                    <Icon class="icon" IconType="@TablerIcons.Database" />
                                </span>
                                <span class="nav-link-title">Backup and Restore</span>
                            </a>
                        </li>
                        <NavbarMenuItem Href="userspasswords" Text="Users and Passwords">
                            <MenuItemIcon><Icon class="icon" IconType="@TablerIcons.Users" /></MenuItemIcon>
                        </NavbarMenuItem>
                        <li class="nav-item">
                            <a class="nav-link" href="#" @onclick="ShowSystemSettingsModal" @onclick:preventDefault>
                                <span class="nav-link-icon">
                                    <Icon class="icon" IconType="@TablerIcons.Adjustments" />
                                </span>
                                <span class="nav-link-title">System Settings</span>
                            </a>
                        </li>
                    </div>
                }

                @* ---- Login/Logout pinned to bottom ---- *@
                <li class="nav-item mt-auto">
                    <a class="nav-link" href="#" @onclick="Logout" @onclick:preventDefault>
                        <span class="nav-link-icon">
                            <Icon class="icon" IconType="@TablerIcons.Logout" />
                        </span>
                        <span class="nav-link-title">Logout</span>
                    </a>
                </li>
            </Authorized>
            <NotAuthorized>
                <li class="nav-item mt-auto">
                    <NavbarMenuItem Href="login" Text="Sign in">
                        <MenuItemIcon>
                            <Icon class="icon" IconType="@TablerIcons.Login" />
                        </MenuItemIcon>
                    </NavbarMenuItem>
                </li>
            </NotAuthorized>
        </AuthorizeView>
    </NavbarMenu>
</Navbar>

@code {
    private bool tempOpen = true;
    private bool controlPanelOpen = false;

    private void ToggleTemp() => tempOpen = !tempOpen;
    private void ToggleControlPanel() => controlPanelOpen = !controlPanelOpen;

    // ---- Access Levels: shared name-only list modal (replaces the /accesslevels page link) ----
    private async Task ShowAccessLevelsModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Access Level")
            .Set(e => e.Load, LoadAccessLevelRows)
            .Set(e => e.OnAdd, () => ShowAccessLevelEdit(null))
            .Set(e => e.OnEdit, (EntityListRow row) => ShowAccessLevelEdit(row))
            .Set(e => e.OnDelete, DeleteAccessLevel);

        await ModalService.ShowAsync("Access Levels", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task<List<EntityListRow>> LoadAccessLevelRows()
    {
        var client = ClientFactory.CreateClient("WebAPI");
        var list = await client.GetFromJsonAsync<List<AccessLevelDto>>("api/AccessLevel") ?? new();
        return list.Select(a => new EntityListRow { Id = a.Id.ToString(), Name = a.Name ?? "" }).ToList();
    }

    private async Task ShowAccessLevelEdit(EntityListRow? row)
    {
        var title = row is null ? "Access levels - New access level" : "Access levels - Edit access level";
        var seed = row is null ? null : new AccessLevelModal.AccessLevelModel { Name = row.Name };
        var component = new RenderComponent<AccessLevelModal>().Set(e => e.Level, seed);

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task DeleteAccessLevel(EntityListRow row)
    {
        var client = ClientFactory.CreateClient("WebAPI");
        await client.DeleteAsync("api/AccessLevel/" + row.Id);
    }

    private async Task ShowDoorTriggerModal()
    {
        var component = new RenderComponent<TriggerModal>();
        await ModalService.ShowAsync("Triggers - New Trigger", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task ShowSpaceZoneTriggerModal()
    {
        var component = new RenderComponent<SpaceZoneTriggerModal>();
        await ModalService.ShowAsync("Triggers - New Trigger", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task ShowBackupRestoreModal()
    {
        var component = new RenderComponent<BackupRestoreModal>();
        await ModalService.ShowAsync("Backup and Restore", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task ShowSystemSettingsModal()
    {
        var component = new RenderComponent<SystemSettingsModal>();
        await ModalService.ShowAsync("System Settings", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "access_token");
        await JS.InvokeVoidAsync("localStorage.removeItem", "refresh_token");
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("/login");
    }
}
