@* Access Level dialog (mirrors LegacyDoorsClient "Access levels - New access level").
   Shown via ModalService.ShowAsync("Access levels - New access level", ...).
   OK + Cancel only (Apply ignored). The green "Auto-update is ON" banner is intentionally omitted. *@

@using DoorsWeb.Shared.Entities

<TablerForm Model="@level" OnValidSubmit="OK">
    <Card Size="CardSize.Default">
        <CardBody>
            <CardTitle>Access Level</CardTitle>
            <div class="mb-1 row align-items-center">
                <div class="col-lg-3 text-end">
                    <label class="form-label mb-0">Name</label>
                </div>
                <div class="col-lg-9">
                    <InputText class="form-control" @bind-Value="level.Name"></InputText>
                </div>
            </div>
        </CardBody>
    </Card>

    <Card Size="CardSize.Default">
        <CardBody>
            <CardTitle>Time Zone</CardTitle>
            <div class="mb-1 row align-items-center">
                <div class="col-lg-4 text-end">
                    <label class="form-label mb-0">Allow access during</label>
                </div>
                <div class="col-lg-7">
                    <InputSelect class="form-select" @bind-Value="level.TimeZone">
                        <option value="all hours">all hours</option>
                        <option value="no access">no access</option>
                    </InputSelect>
                </div>
                <div class="col-lg-1">
                    <button type="button" class="btn btn-outline-secondary w-100" @onclick="EditTimeZones">...</button>
                </div>
            </div>
        </CardBody>
    </Card>

    <Card Size="CardSize.Default">
        <CardBody>
            <CardTitle>Doors</CardTitle>
            <p class="mb-1">Select the doors you want to include in this access level.</p>
            <p class="mb-2">Pick a Time Zone per door, or leave it on “(level default)” to follow the access level above.</p>

            <div class="table-responsive border rounded mb-2" style="max-height: 320px; overflow-y: auto;">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width: 50%;">Door</th>
                            <th style="width: 50%;">Time Zone</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (VisibleDoors.Count == 0)
                        {
                            <tr><td colspan="2" class="text-muted text-center py-4">No doors available.</td></tr>
                        }
                        else
                        {
                            @foreach (var door in VisibleDoors)
                            {
                                <tr>
                                    <td>
                                        <label class="form-check mb-0">
                                            <InputCheckbox class="form-check-input" @bind-Value="door.Selected"></InputCheckbox>
                                            <span class="form-check-label">@door.Name</span>
                                        </label>
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm" style="width: auto;"
                                                value="@(door.LevelDefault ? "default" : door.DoorTimeZone?.ToString())"
                                                @onchange="e => OnDoorTimeZoneChanged(door, e)"
                                                disabled="@(!door.Selected)">
                                            <option value="default">(level default)</option>
                                            @foreach (var tz in timeZones)
                                            {
                                                <option value="@tz.TimeZone">@tz.Name</option>
                                            }
                                            @* Keep the door's current value selectable even if it isn't a named site time zone (e.g. legacy id 0). *@
                                            @if (!door.LevelDefault && door.DoorTimeZone is int dtz && timeZones.All(t => t.TimeZone != dtz))
                                            {
                                                <option value="@dtz">Time zone @dtz</option>
                                            }
                                        </select>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <label class="form-check mb-0">
                <InputCheckbox class="form-check-input" @bind-Value="level.ShowSelectedOnly"></InputCheckbox>
                <span class="form-check-label">Show selected doors only</span>
            </label>
        </CardBody>
    </Card>

    @if (status is not null)
    {
        <div class="alert alert-danger py-2 px-3 small mt-3 mb-0" role="alert">@status</div>
    }

    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-secondary" @onclick="Cancel" disabled="@busy">Cancel</button>
        <button type="submit" class="btn btn-primary" disabled="@busy">OK</button>
    </div>
</TablerForm>

@code {

    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;
    [Inject] IHttpClientFactory ClientFactory { get; set; } = null!;

    /// <summary>Existing access level's number; null when creating a new one.</summary>
    [Parameter] public int? AccessLevelId { get; set; }

    /// <summary>Owning site (required when creating).</summary>
    [Parameter] public int SiteId { get; set; }

    private AccessLevelModel level = new();
    private bool busy;
    private string? status;

    // Header TimeZone (FK) carried through unchanged; the dropdown above is cosmetic for now.
    private int? timeZoneValue;

    // Time zones defined for this site, used to populate the per-door Time Zone dropdowns.
    private List<TTimeZoneHeader> timeZones = new();

    private List<DoorRow> VisibleDoors =>
        level.ShowSelectedOnly ? level.Doors.Where(d => d.Selected).ToList() : level.Doors;

    protected override async Task OnInitializedAsync()
    {
        // Always pull the site's door list; selection + header are seeded when editing.
        try
        {
            var client = ClientFactory.CreateClient("WebAPI");

            // Populate the per-door Time Zone dropdowns from the site's defined time zones.
            var tzList = await client.GetFromJsonAsync<List<TTimeZoneHeader>>("api/TimeZoneHeader");
            if (tzList is not null)
                timeZones = tzList.Where(t => t.Site == SiteId).OrderBy(t => t.Name).ToList();

            var url = $"api/AccessLevelHeader/{SiteId}/doors";
            if (AccessLevelId is int id) url += $"?accessLevel={id}";

            var dto = await client.GetFromJsonAsync<AccessLevelSaveDto>(url);
            if (dto is not null)
            {
                level.Name = dto.Name ?? level.Name;
                timeZoneValue = dto.TimeZone;
                level.Doors = dto.Doors.Select(d => new DoorRow
                {
                    Door = d.Door,
                    Name = d.Name,
                    Selected = d.Selected,
                    DoorTimeZone = d.DoorTimeZone,
                    LevelDefault = d.LevelDefault,
                }).ToList();
            }
        }
        catch
        {
            // Leave the form empty; the user can still enter a name.
        }
    }

    private async Task OK(EditContext context)
    {
        busy = true;
        status = null;
        try
        {
            var dto = new AccessLevelSaveDto
            {
                AccessLevel = AccessLevelId,
                Site = SiteId,
                Name = level.Name,
                TimeZone = timeZoneValue,
                Doors = level.Doors.Select(d => new AccessLevelDoorDto
                {
                    Door = d.Door,
                    Selected = d.Selected,
                    DoorTimeZone = d.DoorTimeZone,
                    LevelDefault = d.LevelDefault,
                }).ToList(),
            };

            var client = ClientFactory.CreateClient("WebAPI");
            var response = await client.PostAsJsonAsync("api/AccessLevelHeader/save", dto);
            if (response.IsSuccessStatusCode)
            {
                ModalService.Close(ModalResult.Ok());
                return;
            }

            status = $"Save failed ({(int)response.StatusCode}). {await response.Content.ReadAsStringAsync()}";
        }
        catch (Exception ex)
        {
            status = $"Save failed: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }

    private void Cancel()
    {
        ModalService.Close(ModalResult.Cancel());
    }

    private void EditTimeZones()
    {
        // Placeholder: open the time-zone editor (no dialog wired yet).
    }

    // The per-door Time Zone dropdown carries two pieces of state: whether the door follows the
    // level default, and (if not) which individual time zone. "default" maps back to LevelDefault.
    private void OnDoorTimeZoneChanged(DoorRow door, ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrEmpty(value) || value == "default")
        {
            door.LevelDefault = true;
            door.DoorTimeZone = null;
        }
        else if (int.TryParse(value, out var tz))
        {
            door.LevelDefault = false;
            door.DoorTimeZone = tz;
        }
    }

    public class AccessLevelModel
    {
        public string? Name { get; set; }
        public string TimeZone { get; set; } = "all hours";
        public bool ShowSelectedOnly { get; set; } = false;
        public List<DoorRow> Doors { get; set; } = new();
    }

    public class DoorRow
    {
        public int Door { get; set; }
        public bool Selected { get; set; }
        public string? Name { get; set; }
        public int? DoorTimeZone { get; set; }
        public bool LevelDefault { get; set; } = true;
    }
}
