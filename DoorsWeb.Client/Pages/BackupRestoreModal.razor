@* Backup and Restore dialog. Shown via ModalService.ShowAsync("Backup and Restore", ...).
   Calls the API's BackupController (pg_dump / pg_restore run server-side). *@

@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Forms
@implements IAsyncDisposable
@inject IHttpClientFactory ClientFactory

<Card Size="CardSize.Default">
    <CardBody>
        <CardTitle>Create Backup</CardTitle>
        <div class="mb-2 row align-items-center">
            <div class="col-lg-3 text-end">
                <label class="form-label mb-0">File name</label>
            </div>
            <div class="col-lg-9">
                <input class="form-control" placeholder="(auto: DatabaseName_yyyyMMdd_HHmmss.dump)" @bind="newFileName" disabled="@busy" />
            </div>
        </div>
        <div class="mb-2 row align-items-center">
            <div class="col-lg-3"></div>
            <div class="col-lg-9">
                <label class="form-check mb-0">
                    <input type="checkbox" class="form-check-input" @bind="compress" disabled="@busy" />
                    <span class="form-check-label">Compress backup</span>
                </label>
            </div>
        </div>
        <div>
            <button type="button" class="btn btn-primary" @onclick="CreateBackup" disabled="@busy">
                @if (busy && busyAction == "backup") { <span class="spinner-border spinner-border-sm me-2"></span> }
                Backup Now
            </button>
        </div>
    </CardBody>
</Card>

<Card Size="CardSize.Default">
    <CardBody>
        <div class="d-flex align-items-center justify-content-between">
            <CardTitle class="mb-0">Restore</CardTitle>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LoadBackups" disabled="@busy">Refresh</button>
        </div>
        <p class="text-muted small mt-1 mb-2">Restoring overwrites the current database and disconnects all users. This cannot be undone.</p>

        <div class="table-responsive border rounded" style="max-height: 280px; overflow-y: auto;">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 2.5rem;"></th>
                        <th>File</th>
                        <th class="text-end">Size</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @if (backups is null)
                    {
                        <tr><td colspan="4" class="text-muted text-center py-4">Loading…</td></tr>
                    }
                    else if (backups.Count == 0)
                    {
                        <tr><td colspan="4" class="text-muted text-center py-4">No backups found.</td></tr>
                    }
                    else
                    {
                        @foreach (var b in backups)
                        {
                            <tr class="@(b.FileName == selectedFile ? "table-active" : null)" @onclick="() => selectedFile = b.FileName" style="cursor: pointer;">
                                <td>
                                    <input type="radio" name="backupFile" class="form-check-input"
                                           checked="@(b.FileName == selectedFile)"
                                           @onchange="() => selectedFile = b.FileName" />
                                </td>
                                <td>@b.FileName</td>
                                <td class="text-end">@FormatSize(b.SizeBytes)</td>
                                <td>@b.CreatedUtc.ToLocalTime().ToString("g")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-2">
            <button type="button" class="btn btn-danger" @onclick="RestoreBackup" disabled="@(busy || selectedFile is null)">
                @if (busy && busyAction == "restore") { <span class="spinner-border spinner-border-sm me-2"></span> }
                Restore Selected
            </button>
        </div>
    </CardBody>
</Card>

<Card Size="CardSize.Default">
    <CardBody>
        <CardTitle>Restore Legacy Backup (.zip)</CardTitle>
        <p class="text-muted small mt-1 mb-2">
            Import an old DoorsClient backup (a password-protected ZIP of <code>.sql</code>/<code>.rs</code>
            table dumps). The matching tables are cleared and reloaded. This overwrites the current data
            and cannot be undone.
        </p>
        @* .alert is a flexbox in Tabler, so keep the icon as one flex child and all the
           text in a single sibling element - otherwise each text node becomes its own column. *@
        <div class="alert alert-warning py-2 px-3 small mb-2" role="alert">
            <Icon class="icon flex-shrink-0 me-2" IconType="@TablerIcons.Alert_triangle" />
            <div>
                Connectors are obsolete and no longer used — this system is <strong>IP only</strong>.<br />
                Doors connect directly by their own IP address; any connector data in a legacy backup is irrelevant.
            </div>
        </div>
        <div class="alert alert-warning py-2 px-3 small mb-2" role="alert">
            <Icon class="icon flex-shrink-0 me-2" IconType="@TablerIcons.Alert_triangle" />
            <div>
                <strong>Card Design</strong> and <strong>Floor Plan</strong> features have been removed — this system no longer manages them.<br />
                Any such data in a legacy backup is still restored (so the import stays consistent), but it is unused and not accessible here.
            </div>
        </div>
        <div class="alert alert-warning py-2 px-3 small mb-2" role="alert">
            <Icon class="icon flex-shrink-0 me-2" IconType="@TablerIcons.Alert_triangle" />
            <div>
                <strong>All previous audit history will be dropped.</strong><br />
                The audit log is cleared on import — the restored data is from a different point in time,
                so existing audit entries no longer apply. The legacy backup carries no audit data to replace it.
            </div>
        </div>

        @* Prominent, hard-to-miss notice: a legacy backup carries no granular permission data, so the
           importer promotes EVERY imported user to full (Super) access. Make this impossible to skim past. *@
        <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
            <Icon class="icon flex-shrink-0 me-3" IconType="@TablerIcons.Shield_lock"
                  style="width: 2.5rem; height: 2.5rem;" />
            <div>
                <h3 class="alert-title mb-1">Every user will be granted FULL access</h3>
                <div>
                    A legacy backup holds no permission data, so on import <strong>every imported user is
                    promoted to Super</strong> — full read/write access to Card Manager, Site Settings and
                    User Settings. Review and lock down user permissions immediately after the import.
                </div>
            </div>
        </div>

        @* Gate the restore behind an explicit acknowledgement: the user must confirm they have
           read the warnings above before the import button becomes enabled. *@
        <div class="mb-3">
            <label class="form-check">
                <input class="form-check-input" type="checkbox" @bind="legacyAcknowledged" disabled="@busy" />
                <span class="form-check-label">
                    I have read and understand the warnings above — this import overwrites current data, drops all
                    audit history, and grants <strong>every imported user full (Super) access</strong>. This cannot be undone.
                </span>
            </label>
        </div>

        <div class="mb-2 row align-items-center">
            <div class="col-lg-3 text-end">
                <label class="form-label mb-0">Backup file</label>
            </div>
            <div class="col-lg-9">
                <InputFile class="form-control" accept=".zip" OnChange="OnLegacyFileSelected" disabled="@busy" />
                @if (legacyFile is not null)
                {
                    <div class="form-text">@legacyFile.Name (@FormatSize(legacyFile.Size))</div>
                }
            </div>
        </div>
        <div class="mb-2 row align-items-center">
            <div class="col-lg-3 text-end">
                <label class="form-label mb-0">Password</label>
            </div>
            <div class="col-lg-9">
                <div class="input-group input-group-flat">
                    <input type="@(showLegacyPwd ? "text" : "password")" class="form-control" placeholder="(leave blank if not encrypted)"
                           @bind="legacyPassword" disabled="@busy" autocomplete="off" />
                    <span class="input-group-text">
                        <a href="#" class="link-secondary" tabindex="-1" title="Show password"
                           @onclick="() => showLegacyPwd = !showLegacyPwd" @onclick:preventDefault="true">
                            <Icon class="icon" IconType="@(showLegacyPwd ? TablerIcons.Eye_off : TablerIcons.Eye)" />
                        </a>
                    </span>
                </div>
            </div>
        </div>
        <div>
            <button type="button" class="btn btn-danger" @onclick="RestoreLegacy" disabled="@(busy || legacyFile is null || !legacyAcknowledged)">
                @if (busy && busyAction == "legacy") { <span class="spinner-border spinner-border-sm me-2"></span> }
                Restore Legacy Backup
            </button>
        </div>

        @if (legacyResult is not null && legacyResult.Tables.Count > 0)
        {
            <div class="table-responsive border rounded mt-3" style="max-height: 220px; overflow-y: auto;">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr><th>Table</th><th class="text-end">Rows loaded</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in legacyResult.Tables)
                        {
                            <tr><td>@t.Table</td><td class="text-end">@t.Rows.ToString("N0")</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (legacyResult.Skipped.Count > 0)
            {
                <p class="text-muted small mt-2 mb-0">Skipped (no matching table): @string.Join(", ", legacyResult.Skipped)</p>
            }
            @if (legacyResult.UsersGrantedFullAccess > 0)
            {
                <div class="alert alert-danger mt-3 mb-0" role="alert">
                    <Icon class="icon flex-shrink-0 me-2" IconType="@TablerIcons.Shield_lock" />
                    <div>
                        <strong>@legacyResult.UsersGrantedFullAccess.ToString("N0")</strong> imported user(s) were granted
                        full (Super) access. Review and lock down user permissions now.
                    </div>
                </div>
            }
            @if (legacyResult.Findings.Count > 0)
            {
                <div class="alert alert-warning mt-3 mb-0" role="alert">
                    <div class="d-flex">
                        <div class="me-2"><Icon class="icon" IconType="@TablerIcons.Alert_triangle" /></div>
                        <div>
                            <h4 class="alert-title">Data-integrity findings (review only — nothing was changed)</h4>
                            <div class="text-secondary small">
                                The backup loaded with foreign-key enforcement off, so these rows were imported as-is.
                                Orphans reference a parent row that doesn't exist; blank names crash the legacy client.
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive mt-2" style="max-height: 220px; overflow-y: auto;">
                        <table class="table table-sm table-vcenter mb-0">
                            <thead>
                                <tr><th>Kind</th><th>Table</th><th>Reference</th><th>Detail</th><th class="text-end">Rows</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var f in legacyResult.Findings)
                                {
                                    <tr>
                                        <td>
                                            @if (f.Kind == "orphan")
                                            {
                                                <span class="badge bg-red-lt">orphan</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-orange-lt">blank-name</span>
                                            }
                                        </td>
                                        <td>@f.Table</td>
                                        <td>@f.Reference</td>
                                        <td class="text-muted small">@f.Detail</td>
                                        <td class="text-end">@f.Count.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </CardBody>
</Card>

@if (busy)
{
    <div class="mt-3">
        <div class="d-flex justify-content-between small text-muted mb-1">
            <span>@busyLabel</span>
            <span>@(progressPercent.HasValue ? $"{progressPercent}%" : "working")</span>
        </div>
        <div class="progress" style="height: 1.25rem;">
            <div class="progress-bar progress-bar-striped progress-bar-animated @(busyAction is "restore" or "legacy" ? "bg-danger" : null)"
                 role="progressbar"
                 style="width: @(progressPercent ?? 100)%;"
                 aria-valuenow="@(progressPercent ?? 0)" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
        <p class="small text-muted mt-2 mb-0">
            <span class="spinner-border spinner-border-sm me-1"></span>
            @busyNotice
        </p>
    </div>
}

@if (status is not null)
{
    <div class="alert @(statusOk ? "alert-success" : "alert-danger") mb-0 mt-3" role="alert">
        @status
    </div>
}

<div class="d-flex justify-content-end gap-2 mt-3">
    <button type="button" class="btn btn-secondary" @onclick="Close" disabled="@busy">Close</button>
</div>

@code {

    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    // Shared with MainNavigation so we can hide the header close (X) button while busy.
    [Parameter] public ModalOptions? Options { get; set; }

    private HttpClient client = null!;

    private List<BackupFileDto>? backups;
    private string? selectedFile;

    private string? newFileName;
    private bool compress = true;

    private IBrowserFile? legacyFile;
    private string? legacyPassword;
    private bool showLegacyPwd;
    private bool legacyAcknowledged;
    private LegacyRestoreResult? legacyResult;

    private bool _busy;
    private bool busy
    {
        get => _busy;
        set
        {
            if (_busy == value) return;
            _busy = value;
            // Block closing the dialog mid-operation: hide the header X while busy.
            // (Click-outside and Esc are already disabled; the footer Close button is
            // disabled via @busy.) The footer button reappears automatically.
            if (Options is not null)
            {
                Options.ShowCloseButton = !value;
                ModalService.Refresh();
            }
        }
    }
    private string? busyAction;

    private string busyLabel => busyAction switch
    {
        "restore" => "Restoring database",
        "legacy" => "Restoring legacy backup",
        _ => "Creating backup"
    };

    private string busyNotice => busyAction switch
    {
        "restore" or "legacy" => "Please wait until the restore is complete — do not close this window.",
        _ => "Please wait until the backup is complete — do not close this window."
    };

    private string? status;
    private bool statusOk;

    private HubConnection? hubConnection;
    private int? progressPercent;

    protected override async Task OnInitializedAsync()
    {
        client = ClientFactory.CreateClient("WebAPI");

        // Live progress channel. Best-effort: if it can't connect, backup/restore still works,
        // just without a percent readout (the bar falls back to indeterminate).
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl("https://localhost:60879/backupHub")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<int>("BackupProgress", p => UpdateProgress(p));
            hubConnection.On<int>("RestoreProgress", p => UpdateProgress(p));
            hubConnection.On<int>("LegacyRestoreProgress", p => UpdateProgress(p));

            await hubConnection.StartAsync();
        }
        catch
        {
            hubConnection = null;
        }

        await LoadBackups();
    }

    private void UpdateProgress(int percent)
    {
        // Clamp defensively: a server miscount or error path must never push the bar past 100% (or below 0).
        progressPercent = Math.Clamp(percent, 0, 100);
        InvokeAsync(StateHasChanged);
    }

    private bool HubReady =>
        hubConnection is not null
        && hubConnection.State == HubConnectionState.Connected
        && hubConnection.ConnectionId is not null;

    private async Task LoadBackups()
    {
        try
        {
            backups = await client.GetFromJsonAsync<List<BackupFileDto>>("api/Backup") ?? new();
        }
        catch (Exception ex)
        {
            backups = new();
            SetStatus(false, $"Could not load backups: {ex.Message}");
        }
    }

    private async Task CreateBackup()
    {
        busy = true;
        busyAction = "backup";
        status = null;
        progressPercent = HubReady ? 0 : null; // server pushes BackupProgress; indeterminate if hub is down
        try
        {
            var request = new CreateBackupRequest
            {
                FileName = newFileName,
                Compress = compress,
                ConnectionId = HubReady ? hubConnection!.ConnectionId : null
            };
            var response = await client.PostAsJsonAsync("api/Backup", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BackupOperationResult>();
                SetStatus(true, result?.Message ?? "Backup completed.");
                newFileName = null;
                await LoadBackups();
            }
            else
            {
                SetStatus(false, await ReadError(response));
            }
        }
        catch (Exception ex)
        {
            SetStatus(false, $"Backup failed: {ex.Message}");
        }
        finally
        {
            busy = false;
            busyAction = null;
            progressPercent = null;
        }
    }

    private async Task RestoreBackup()
    {
        if (selectedFile is null) return;

        var confirmed = await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = $"Restore database from {selectedFile}?",
            SubText = "This overwrites the current database and disconnects all users. This cannot be undone!",
            IconType = TablerIcons.Alert_triangle,
            StatusColor = TablerColor.Danger
        });
        if (!confirmed) return;

        busy = true;
        busyAction = "restore";
        status = null;
        progressPercent = HubReady ? 0 : null; // server pushes RestoreProgress; indeterminate if hub is down
        try
        {
            var request = new RestoreBackupRequest
            {
                FileName = selectedFile,
                ConnectionId = HubReady ? hubConnection!.ConnectionId : null
            };
            var response = await client.PostAsJsonAsync("api/Backup/restore", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BackupOperationResult>();
                SetStatus(true, result?.Message ?? "Restore completed.");
            }
            else
            {
                SetStatus(false, await ReadError(response));
            }
        }
        catch (Exception ex)
        {
            SetStatus(false, $"Restore failed: {ex.Message}");
        }
        finally
        {
            busy = false;
            busyAction = null;
            progressPercent = null;
        }
    }

    private void OnLegacyFileSelected(InputFileChangeEventArgs e)
    {
        legacyFile = e.File;
        legacyResult = null;
        status = null;
    }

    private async Task RestoreLegacy()
    {
        if (legacyFile is null || !legacyAcknowledged) return;

        var confirmed = await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = $"Restore from legacy backup {legacyFile.Name}?",
            SubText = "Matching tables will be cleared and reloaded from the backup. "
                + "EVERY imported user will be granted full (Super) access — a legacy backup carries no "
                + "permission data, so review and lock down user permissions immediately afterward. "
                + "All previous audit history will be dropped. "
                + "Connectors are obsolete and no longer used — this system is IP only, so any "
                + "connector data in the backup is irrelevant to the new system. "
                + "This overwrites the current data and cannot be undone!",
            IconType = TablerIcons.Alert_triangle,
            StatusColor = TablerColor.Danger
        });
        if (!confirmed) return;

        busy = true;
        busyAction = "legacy";
        status = null;
        legacyResult = null;
        progressPercent = HubReady ? 0 : null;
        try
        {
            // 2 GB cap: the T_Events recordset alone is ~100 MB uncompressed.
            const long maxUpload = 2L * 1024 * 1024 * 1024;

            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(legacyFile.OpenReadStream(maxUpload));
            content.Add(fileContent, "file", legacyFile.Name);
            content.Add(new StringContent(legacyPassword ?? ""), "password");
            if (HubReady)
            {
                content.Add(new StringContent(hubConnection!.ConnectionId!), "connectionId");
            }

            var response = await client.PostAsync("api/Backup/restore-legacy", content);
            if (response.IsSuccessStatusCode)
            {
                legacyResult = await response.Content.ReadFromJsonAsync<LegacyRestoreResult>();
                SetStatus(true, legacyResult?.Message ?? "Legacy restore completed.");
                legacyFile = null;
                legacyPassword = null;
            }
            else
            {
                SetStatus(false, await ReadError(response));
            }
        }
        catch (Exception ex)
        {
            SetStatus(false, $"Legacy restore failed: {ex.Message}");
        }
        finally
        {
            busy = false;
            busyAction = null;
            progressPercent = null;
        }
    }

    private static async Task<string> ReadError(HttpResponseMessage response)
    {
        try
        {
            var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
            if (!string.IsNullOrWhiteSpace(problem?.Detail)) return problem!.Detail!;
        }
        catch { /* fall through */ }
        return $"Request failed ({(int)response.StatusCode}).";
    }

    private void SetStatus(bool ok, string message)
    {
        statusOk = ok;
        status = message;
    }

    private void Close()
    {
        ModalService.Close(ModalResult.Ok());
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private static string FormatSize(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        int unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }
        return $"{size:0.#} {units[unit]}";
    }

    private class ProblemDetails
    {
        public string? Title { get; set; }
        public string? Detail { get; set; }
        public int? Status { get; set; }
    }
}
