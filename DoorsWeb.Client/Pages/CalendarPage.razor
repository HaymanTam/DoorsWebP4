@page "/calendar"
@inject IHttpClientFactory ClientFactory

<Table Item="AccessCalendarDto" @ref="table" Items="calendarList" PageSize="10" AddItemFactory="AddItem"
       OnItemAdded="OnItemAdd" OnItemEdited="OnItemEdit" OnItemDeleted="OnItemDelete" OnBeforeEdit="OnBeforeEdit"
       CancelStrategy="TabBlazor.Components.Tables.OnCancelStrategy.Revert"
       Hover Responsive EditMode=TableEditMode.Inline>
    <HeaderTemplate>

    </HeaderTemplate>

    <ChildContent>
        @if (!IsLoaded)
        {
            <Progress Color="TablerColor.Blue" Indeterminate />
        }
        <Column Item="AccessCalendarDto" Property="e => e.Id" Title="ID" Visible="false">
            <EditorTemplate>
                @(context.Id == Guid.Empty ? context.Id : "")
                <InputNumber class="form-control" @bind-value="@context.Id" Hidden />
            </EditorTemplate>
        </Column>
        <Column Item="AccessCalendarDto" Property="e => e.Name" Title="Name" Searchable Sortable>
            <EditorTemplate>
                <InputText class="form-control" @bind-value="@context.Name" DisplayName="Name" />
            </EditorTemplate>
        </Column>
        <Column Item="AccessCalendarDto" Property="e => e.LastUpdatedAt" Title="Last Updated" Sortable>
            <EditorTemplate>
                @(context.LastUpdatedAt != default ? context.LastUpdatedAt : "")
            </EditorTemplate>
        </Column>
    </ChildContent>
</Table>

@code {
    [Inject] TabBlazor.Services.TablerService TablerService { get; set; } = null!;
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    private bool IsLoaded = false;
    private AccessCalendarDto? _editSnapshot;
    private Table<AccessCalendarDto> table = null!;
    private HttpClient client = new HttpClient();
    private List<AccessCalendarDto> calendarList = new();

    protected override async Task OnInitializedAsync()
    {
        client = ClientFactory.CreateClient("WebAPI");
        calendarList = await client.GetFromJsonAsync<List<AccessCalendarDto>>("api/Calendar") ?? [];
        IsLoaded = true;
    }

    private Task<AccessCalendarDto> AddItem() =>
        Task.FromResult(new AccessCalendarDto { Id = Guid.Empty, Name = "New Calendar" });

    private Task OnBeforeEdit(AccessCalendarDto dto)
    {
        _editSnapshot = new AccessCalendarDto
        {
            Id = dto.Id,
            Name = dto.Name,
            LastUpdatedAt = dto.LastUpdatedAt
        };
        return Task.CompletedTask;
    }

    private async Task OnItemAdd(AccessCalendarDto dto)
    {
        var result = await client.PostAsJsonAsync("api/Calendar/", dto);
        if (result.IsSuccessStatusCode) await UpdateList();
        else
        {
            calendarList.Remove(dto);
            await ShowErrorDialog(result);
        }
    }

    private async Task OnItemEdit(AccessCalendarDto dto)
    {
        var result = await client.PutAsJsonAsync("api/Calendar/" + dto.Id, dto);
        if (result.IsSuccessStatusCode) await UpdateList();
        else
        {
            var index = calendarList.FindIndex(c => c.Id == dto.Id);
            if (index >= 0) calendarList[index] = _editSnapshot!;
            await ShowErrorDialog(result);
        }
    }

    private async Task OnItemDelete(AccessCalendarDto dto)
    {
        calendarList = await client.DeleteFromJsonAsync<List<AccessCalendarDto>>("api/Calendar/" + dto.Id) ?? [];
    }

    private async Task UpdateList()
    {
        calendarList = await client.GetFromJsonAsync<List<AccessCalendarDto>>("api/Calendar") ?? [];
    }

    private async Task ShowErrorDialog(HttpResponseMessage result)
    {
        ClientProblemDetails errjson;
        try
        {
            errjson = await result.Content.ReadFromJsonAsync<ClientProblemDetails>() ??
                new ClientProblemDetails { Status = 500, Title = "Error Returned Null!", Detail = "An unexpected error occurred." };
        }
        catch
        {
            errjson = new ClientProblemDetails { Status = 500, Title = "Unable to Read Error!", Detail = "Failed to read error response." };
        }
        if (errjson.Status == 500) errjson.Detail = "traceId: " + errjson.TraceId;
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = errjson.Status + " " + errjson.Title,
            SubText = errjson.Detail,
            IconType = TablerIcons.Alert_triangle,
            CancelText = "",
            StatusColor = TablerColor.Danger
        });
    }
}
