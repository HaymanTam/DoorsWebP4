@* Card Record dialog. Shown via ModalService.ShowAsync("...", RenderComponent<CardEditModal>...).
   Mirrors the legacy "Card Record" window but with friendlier UX:
     - a "Custom Fields" section driven by the GLOBAL field definitions (T_CustomFieldTypes), so the
       same fields appear on every card; each card's values persist via api/CustomField/card/{n}.
       Field definitions themselves are managed on the separate Custom Fields settings screen
       (the legacy "Add or Remove Fields" toolbar), and
     - a drag-and-drop / click photo uploader with live preview
       (replaces the legacy "Cardholder Photo" toolbar button).
   Core cardholder fields persist via api/Cardholder (POST for new, PUT for edit).
   The photo persists via api/CardPhoto/{cardNumber} (saved/deleted right after the cardholder
   is saved, so it's keyed to the final card number).
   Access levels and bio data are UI-level only for now (no backing endpoint yet) and are clearly
   grouped so they can be wired up later. *@

@using DoorsWeb.Shared.Entities
@using DoorsWeb.Shared.DTO
@inject IHttpClientFactory ClientFactory

<div class="row g-3">
    @* ============================= CARDHOLDER DETAILS ============================= *@
    <div class="col-lg-8">
        <Card Size="CardSize.Default">
            <CardBody>
                <CardTitle>Cardholder Details</CardTitle>

                <div class="mb-2 row align-items-center">
                    <label class="col-4 col-form-label text-end">Card Number</label>
                    <div class="col-8">
                        <input class="form-control" maxlength="8" placeholder="Printed card number"
                               @bind="card.CardId" disabled="@busy" />
                    </div>
                </div>

                <div class="mb-2 row align-items-center">
                    <label class="col-4 col-form-label text-end">Card ID</label>
                    <div class="col-8">
                        <input type="number" class="form-control" @bind="card.CardNumber" disabled="@(!isNew || busy)" />
                        @if (isNew)
                        {
                            <small class="text-muted">System id for this card (next free number suggested).</small>
                        }
                    </div>
                </div>

                <div class="mb-2 row align-items-center">
                    <label class="col-4 col-form-label text-end">Bio Data</label>
                    <div class="col-8 d-flex gap-2">
                        <input class="form-control" style="max-width: 6rem;" @bind="bioTemplate" disabled="@busy" />
                        <input class="form-control" @bind="bioAlias" placeholder="Alias" disabled="@busy" />
                    </div>
                </div>

                <div class="mb-2 row align-items-center">
                    <label class="col-4 col-form-label text-end">First name</label>
                    <div class="col-8">
                        <input class="form-control" maxlength="30" @bind="card.Forname" disabled="@busy" />
                    </div>
                </div>

                <div class="mb-3 row align-items-center">
                    <label class="col-4 col-form-label text-end">Last name</label>
                    <div class="col-8">
                        <input class="form-control" maxlength="30" @bind="card.Surname" disabled="@busy" />
                    </div>
                </div>

                <div class="mb-3 row">
                    <div class="col-4"></div>
                    <div class="col-8 d-flex flex-wrap gap-4">
                        <label class="form-check mb-0">
                            <input type="checkbox" class="form-check-input" @bind="enabled" disabled="@busy" />
                            <span class="form-check-label">Enabled</span>
                        </label>
                        <label class="form-check mb-0">
                            <input type="checkbox" class="form-check-input" @bind="bioAdmin" disabled="@busy" />
                            <span class="form-check-label">Biometric Administrator</span>
                        </label>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label class="col-4 col-form-label text-end">Access Levels</label>
                    <div class="col-8">
                        @* Live name filter for the (potentially long) access-level list. Filters the
                           view only — selections in selectedAccessLevels are preserved while you search. *@
                        @if (accessLevels is { Count: > 0 })
                        {
                            <div class="input-icon mb-2">
                                <span class="input-icon-addon">
                                    <Icon IconType="@TablerIcons.Search" />
                                </span>
                                <input type="search" class="form-control" placeholder="Search access levels by name…"
                                       @bind="accessLevelSearch" @bind:event="oninput" aria-label="Search access levels" />
                            </div>
                        }
                        <div class="border rounded p-2" style="max-height: 160px; overflow-y: auto;">
                            @if (accessLevels is null)
                            {
                                <div class="text-muted small">Loading…</div>
                            }
                            else if (accessLevels.Count == 0)
                            {
                                <div class="text-muted small">No access levels defined.</div>
                            }
                            else if (VisibleAccessLevels.Count == 0)
                            {
                                <div class="text-muted small">@($"No access levels match “{accessLevelSearch.Trim()}”.")</div>
                            }
                            else
                            {
                                @foreach (var al in VisibleAccessLevels)
                                {
                                    var key = $"{al.Site}/{al.AccessLevel}";
                                    <label class="form-check mb-0">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@selectedAccessLevels.Contains(key)"
                                               @onchange="e => ToggleAccessLevel(key, e)" disabled="@busy" />
                                        <span class="form-check-label">@al.Name</span>
                                    </label>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="mb-2 row">
                    <div class="col-4"></div>
                    <div class="col-8 d-flex flex-column gap-2">
                        <label class="form-check mb-0">
                            <input type="checkbox" class="form-check-input" @bind="flexi" disabled="@busy" />
                            <span class="form-check-label">Flexi</span>
                        </label>
                        <label class="form-check mb-0">
                            <input type="checkbox" class="form-check-input" @bind="dormant" disabled="@busy" />
                            <span class="form-check-label">Dormant</span>
                        </label>
                        <div class="d-flex align-items-center gap-2">
                            <label class="form-check mb-0" style="min-width: 6rem;">
                                <input type="checkbox" class="form-check-input" @bind="validFromEnabled" disabled="@busy" />
                                <span class="form-check-label">Valid from</span>
                            </label>
                            <input type="date" class="form-control" style="max-width: 12rem;"
                                   @bind="validFromDate" disabled="@(!validFromEnabled || busy)" />
                        </div>
                    </div>
                </div>
            </CardBody>
        </Card>

        @* ---- Custom fields: driven by the global definitions (shared across every card) ---- *@
        <Card Size="CardSize.Default">
            <CardBody>
                <CardTitle class="mb-2">Custom Fields</CardTitle>

                @if (customFields is null)
                {
                    <div class="text-muted small">Loading…</div>
                }
                else if (customFields.Count == 0)
                {
                    <div class="text-muted small">
                        No custom fields defined. Add them on the
                        <a href="settings/custom-fields">Custom Fields settings</a> screen and they'll
                        appear on every card record.
                    </div>
                }
                else
                {
                    @foreach (var field in customFields)
                    {
                        <div class="row g-2 align-items-start mb-2">
                            <label class="col-4 col-form-label text-end">@field.Name</label>
                            <div class="col-8">
                                @switch ((CustomFieldDataType)field.DataType)
                                {
                                    case CustomFieldDataType.Checkbox:
                                        <label class="form-check mb-0 mt-2">
                                            <input type="checkbox" class="form-check-input"
                                                   checked="@(field.Value == "1")"
                                                   @onchange="e => SetCheckbox(field, e)" disabled="@busy" />
                                            <span class="form-check-label">Yes</span>
                                        </label>
                                        break;

                                    case CustomFieldDataType.Combobox:
                                        <div class="d-flex gap-2">
                                            <select class="form-select" value="@field.Value"
                                                    @onchange="e => field.Value = e.Value?.ToString()" disabled="@busy">
                                                <option value="">— none —</option>
                                                @foreach (var opt in field.Options)
                                                {
                                                    <option value="@opt.Code">@opt.Description</option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-outline-success"
                                                    title="Add a new option to this list"
                                                    @onclick="() => ToggleAddOption(field.Slot)" disabled="@busy">
                                                <Icon IconType="@TablerIcons.Plus" />
                                            </button>
                                        </div>
                                        if (addingOptionSlot == field.Slot)
                                        {
                                            <div class="d-flex gap-2 mt-2">
                                                <input class="form-control" maxlength="30" placeholder="New option"
                                                       @bind="newOptionText" @bind:event="oninput" disabled="@busy" />
                                                <button type="button" class="btn btn-primary"
                                                        @onclick="() => AddOption(field)" disabled="@(busy || string.IsNullOrWhiteSpace(newOptionText))">
                                                    Add
                                                </button>
                                                <button type="button" class="btn btn-secondary" @onclick="CancelAddOption" disabled="@busy">
                                                    Cancel
                                                </button>
                                            </div>
                                            if (optionError is not null)
                                            {
                                                <div class="text-danger small mt-1">@optionError</div>
                                            }
                                        }
                                        break;

                                    case CustomFieldDataType.Date:
                                        <input type="date" class="form-control" value="@field.Value"
                                               @onchange="e => field.Value = e.Value?.ToString()" disabled="@busy" />
                                        break;

                                    case CustomFieldDataType.Number:
                                        <input type="number" class="form-control" @bind="field.Value" disabled="@busy" />
                                        break;

                                    default: @* Text and any unhandled type *@
                                        <input class="form-control" maxlength="30" @bind="field.Value" disabled="@busy" />
                                        break;
                                }
                            </div>
                        </div>
                    }
                }
            </CardBody>
        </Card>
    </div>

    @* ============================= PHOTO ============================= *@
    <div class="col-lg-4">
        <Card Size="CardSize.Default">
            <CardBody>
                <CardTitle>Photo</CardTitle>

                <div class="card-photo-frame">
                    @if (!string.IsNullOrEmpty(photoDataUrl))
                    {
                        <img src="@photoDataUrl" alt="Cardholder photo" class="card-photo-img" />
                    }
                    else
                    {
                        <div class="card-photo-empty">
                            <svg class="card-photo-silhouette" viewBox="0 0 128 128" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                                <circle cx="64" cy="44" r="27" />
                                <path d="M64 78c-27 0-47 17-47 42v8h94v-8c0-25-20-42-47-42z" />
                            </svg>
                            <span class="card-photo-caption">No photo</span>
                        </div>
                    }
                </div>

                <label class="btn btn-outline-primary w-100 mt-3 mb-0" disabled="@busy">
                    <Icon class="icon me-1" IconType="@TablerIcons.Upload" />Upload Photo
                    <InputFile OnChange="OnPhotoSelected" accept="image/*" class="d-none" />
                </label>

                @if (!string.IsNullOrEmpty(photoDataUrl))
                {
                    <button type="button" class="btn btn-link text-danger w-100 mt-1" @onclick="RemovePhoto" disabled="@busy">
                        Remove photo
                    </button>
                }

                @if (photoError is not null)
                {
                    <div class="text-danger small mt-1">@photoError</div>
                }

                <div class="text-muted small mt-2">JPG or PNG, up to 4&nbsp;MB.</div>
            </CardBody>
        </Card>
    </div>
</div>

@if (status is not null)
{
    <div class="alert alert-danger mb-0 mt-2" role="alert">@status</div>
}

<div class="d-flex align-items-center mt-3">
    <span class="text-muted">Last transaction: @lastTransaction</span>
    <div class="ms-auto d-flex gap-2">
        <button type="button" class="btn btn-secondary" @onclick="Cancel" disabled="@busy">Cancel</button>
        <button type="button" class="btn btn-outline-primary" @onclick="Apply" disabled="@busy">
            @if (busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
            Apply
        </button>
        <button type="button" class="btn btn-primary" @onclick="Ok" disabled="@busy">OK</button>
    </div>
</div>

<style>
    /* Photo frame: fixed portrait area that both the uploaded image and the
       empty-state silhouette share, so swapping between them doesn't reflow. */
    .card-photo-frame {
        height: 240px;
        border: 1px solid var(--tblr-border-color, #dbe0e6);
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .6);
    }

    .card-photo-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .card-photo-empty {
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        /* soft studio-backdrop vignette */
        background: radial-gradient(110% 90% at 50% 22%, #f3f5f9 0%, #e4e9f1 55%, #d4dae5 100%);
    }

    .card-photo-silhouette {
        width: 150px;
        height: 200px;
        margin-bottom: -2px; /* let the shoulders meet the bottom edge */
        fill: #aeb8c8;
        filter: drop-shadow(0 3px 5px rgba(33, 43, 64, .18));
    }

    .card-photo-caption {
        position: absolute;
        top: .6rem;
        left: 0;
        right: 0;
        text-align: center;
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #8a93a3;
    }
</style>

@code {
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    /// <summary>Card number to edit. 0 (default) opens a new-record form.</summary>
    [Parameter] public int CardNumber { get; set; }

    /// <summary>Suggested next free card number, used when creating a new record.</summary>
    [Parameter] public int NextCardNumber { get; set; }

    private Cardholder card = new();
    private bool isNew = true;
    private bool busy;
    private string? status;
    private string lastTransaction = "card not issued";

    // ---- Checkbox-friendly local mirrors of the nullable bool columns ----
    private bool enabled;
    private bool bioAdmin;
    private bool flexi;

    // ---- UI-only fields (no backing column yet) ----
    private bool dormant;
    private string? bioTemplate;
    private string? bioAlias;
    private bool validFromEnabled;
    private DateTime validFromDate = DateTime.Today;
    private string? photoDataUrl;
    private string? photoError;

    // Pending photo change, applied to api/CardPhoto after the cardholder is saved. Bytes are
    // captured from the file picker; photoRemoved is set when the user clears an existing photo.
    private byte[]? pendingPhotoBytes;
    private string? pendingPhotoFileName;
    private string? pendingPhotoContentType;
    private bool photoRemoved;

    private HttpClient client = null!;

    private List<AccessLevels>? accessLevels;
    private readonly HashSet<string> selectedAccessLevels = new();

    // Custom fields for this card: the global definitions merged with this card's stored values.
    // null while loading; the definitions are shared across every card (managed on a separate screen).
    private List<CardCustomFieldDto>? customFields;

    // Inline "add a combobox option" state: which field's add-row is open, the pending text, and any error.
    private int? addingOptionSlot;
    private string newOptionText = "";
    private string? optionError;

    // Free-text filter for the access-level list (case-insensitive substring on the level name).
    // Filters the rendered view only; selections in selectedAccessLevels are untouched while searching.
    private string accessLevelSearch = "";

    private List<AccessLevels> VisibleAccessLevels
    {
        get
        {
            if (accessLevels is null) return new();
            if (string.IsNullOrWhiteSpace(accessLevelSearch)) return accessLevels;
            var term = accessLevelSearch.Trim();
            return accessLevels
                .Where(al => al.Name is not null
                    && al.Name.Contains(term, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        client = ClientFactory.CreateClient("WebAPI");

        if (CardNumber == 0)
        {
            isNew = true;
            card = new Cardholder { CardNumber = NextCardNumber, Enabled = true, InUse = true };
        }
        else
        {
            var result = await client.GetFromJsonAsync<Cardholder?>($"api/Cardholder/{CardNumber}");
            if (result is not null)
            {
                card = result;
                isNew = false;
                lastTransaction = card.LastDate?.ToString("g") ?? "card not issued";
            }
            await LoadPhoto();
        }

        // Seed the checkbox mirrors / valid-from controls from the loaded card.
        enabled = card.Enabled ?? false;
        bioAdmin = card.BioAdmin ?? false;
        flexi = card.Flexi ?? false;
        validFromEnabled = card.ValidFrom.HasValue;
        validFromDate = card.ValidFrom ?? DateTime.Today;

        await LoadAccessLevels();
        await LoadCustomFields();
    }

    // Loads the global custom-field definitions merged with this card's stored values. For a new
    // card no value row exists yet, so the fields come back with empty values. Keyed to the current
    // card number (the suggested next number for a new card); values are saved after the card is.
    private async Task LoadCustomFields()
    {
        try
        {
            customFields = await client.GetFromJsonAsync<List<CardCustomFieldDto>>(
                $"api/CustomField/card/{card.CardNumber}") ?? new();
        }
        catch
        {
            customFields = new();
        }
    }

    private async Task LoadAccessLevels()
    {
        try
        {
            accessLevels = await client.GetFromJsonAsync<List<AccessLevels>>("api/AccessLevel") ?? new();
        }
        catch
        {
            accessLevels = new();
        }
    }

    // Loads the existing photo for the card being edited. The API returns 204 (→ null) when there
    // is none, leaving the empty-state silhouette in place.
    private async Task LoadPhoto()
    {
        try
        {
            var result = await client.GetFromJsonAsync<PhotoUploadResult?>($"api/CardPhoto/{card.CardNumber}");
            if (result is not null && !string.IsNullOrEmpty(result.Path))
                photoDataUrl = AbsolutePhotoUrl(result.Path);
        }
        catch
        {
            /* no photo or API unreachable — show the empty state */
        }
    }

    // The photo is served by the API host, but the Blazor app runs on its own origin, so a relative
    // "/media/..." path must be resolved against the API base address to load correctly.
    private string AbsolutePhotoUrl(string path) =>
        client.BaseAddress is null ? path : new Uri(client.BaseAddress, path).ToString();

    private void ToggleAccessLevel(string key, ChangeEventArgs e)
    {
        if (e.Value is bool on && on) selectedAccessLevels.Add(key);
        else selectedAccessLevels.Remove(key);
    }

    // Checkbox custom fields persist as "1"/"0" (the legacy convention).
    private void SetCheckbox(CardCustomFieldDto field, ChangeEventArgs e) =>
        field.Value = (e.Value is bool b && b) ? "1" : "0";

    // Opens (or closes) the inline "add a new option" row under a combobox field.
    private void ToggleAddOption(int slot)
    {
        optionError = null;
        newOptionText = "";
        addingOptionSlot = addingOptionSlot == slot ? null : slot;
    }

    private void CancelAddOption()
    {
        addingOptionSlot = null;
        newOptionText = "";
        optionError = null;
    }

    // Adds a new option to the field's global list (T_Custom) and selects it for this card.
    private async Task AddOption(CardCustomFieldDto field)
    {
        var text = newOptionText.Trim();
        if (string.IsNullOrEmpty(text)) return;

        optionError = null;
        try
        {
            var response = await client.PostAsJsonAsync(
                $"api/CustomField/definitions/{field.Slot}/options", new { Description = text });
            if (!response.IsSuccessStatusCode)
            {
                optionError = $"Could not add option ({(int)response.StatusCode}).";
                return;
            }

            var option = await response.Content.ReadFromJsonAsync<CustomFieldOptionDto>();
            if (option is not null)
            {
                field.Options.Add(option);
                field.Value = option.Code.ToString();   // select the freshly added option
            }
            CancelAddOption();
        }
        catch (Exception ex)
        {
            optionError = $"Could not add option: {ex.Message}";
        }
    }

    // Persists this card's custom-field values. Called after the cardholder save succeeds, so the
    // value row is keyed to the final card number. Skipped when no fields are defined.
    private async Task SaveCustomFields()
    {
        if (customFields is null || customFields.Count == 0) return;

        var values = customFields
            .Select(f => new CardCustomFieldValueDto { Slot = f.Slot, Value = f.Value })
            .ToList();
        await client.PutAsJsonAsync($"api/CustomField/card/{card.CardNumber}", values);
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        photoError = null;
        var file = e.File;
        if (file is null) return;

        const long maxBytes = 4 * 1024 * 1024;
        if (file.Size > maxBytes)
        {
            photoError = "Image is larger than 4 MB.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var contentType = string.IsNullOrEmpty(file.ContentType) ? "image/png" : file.ContentType;
            photoDataUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";

            // Stash for upload after the cardholder is saved (Apply / OK).
            pendingPhotoBytes = bytes;
            pendingPhotoFileName = file.Name;
            pendingPhotoContentType = contentType;
            photoRemoved = false;
        }
        catch (Exception ex)
        {
            photoError = $"Could not read image: {ex.Message}";
        }
    }

    private void RemovePhoto()
    {
        photoDataUrl = null;
        pendingPhotoBytes = null;
        pendingPhotoFileName = null;
        pendingPhotoContentType = null;
        photoRemoved = true;
    }

    // Persist the pending photo change against the (now final) card number. A newly
    // selected image is uploaded; an explicit removal issues a DELETE. No-op when the
    // user left the photo untouched. Failures surface via photoError but do not abort
    // the cardholder save that already succeeded.
    private async Task SavePhoto()
    {
        try
        {
            if (pendingPhotoBytes is not null)
            {
                using var content = new MultipartFormDataContent();
                var fileContent = new ByteArrayContent(pendingPhotoBytes);
                fileContent.Headers.ContentType =
                    new System.Net.Http.Headers.MediaTypeHeaderValue(pendingPhotoContentType ?? "image/png");
                content.Add(fileContent, "file", pendingPhotoFileName ?? $"{card.CardNumber}.png");

                var response = await client.PostAsync($"api/CardPhoto/{card.CardNumber}", content);
                if (response.IsSuccessStatusCode)
                {
                    pendingPhotoBytes = null;
                    pendingPhotoFileName = null;
                    pendingPhotoContentType = null;
                    var result = await response.Content.ReadFromJsonAsync<PhotoUploadResult>();
                    if (result is not null && !string.IsNullOrEmpty(result.Path))
                    {
                        // Cache-bust so the freshly uploaded image replaces any cached one.
                        photoDataUrl = AbsolutePhotoUrl(result.Path) + "?t=" + DateTime.UtcNow.Ticks;
                    }
                }
                else
                {
                    photoError = $"Photo upload failed ({(int)response.StatusCode}).";
                }
            }
            else if (photoRemoved)
            {
                await client.DeleteAsync($"api/CardPhoto/{card.CardNumber}");
                photoRemoved = false;
            }
        }
        catch (Exception ex)
        {
            photoError = $"Photo save failed: {ex.Message}";
        }
    }

    // Push the checkbox / valid-from mirrors back onto the entity before saving.
    private void ApplyToCard()
    {
        card.Enabled = enabled;
        card.BioAdmin = bioAdmin;
        card.Flexi = flexi;
        card.ValidFrom = validFromEnabled ? validFromDate : null;
    }

    private async Task<bool> Persist()
    {
        ApplyToCard();
        busy = true;
        status = null;
        try
        {
            var response = isNew
                ? await client.PostAsJsonAsync("api/Cardholder", card)
                : await client.PutAsJsonAsync($"api/Cardholder/{card.CardNumber}", card);

            if (response.IsSuccessStatusCode)
            {
                // After a successful create the record exists; switch to edit semantics
                // so a follow-up Apply/OK issues a PUT rather than a duplicate POST.
                isNew = false;
                // Now that the card number is final, persist the custom-field values and any photo
                // change against it.
                await SaveCustomFields();
                await SavePhoto();
                return true;
            }

            status = $"Save failed ({(int)response.StatusCode}). {await response.Content.ReadAsStringAsync()}";
            return false;
        }
        catch (Exception ex)
        {
            status = $"Save failed: {ex.Message}";
            return false;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task Ok()
    {
        if (await Persist()) ModalService.Close(ModalResult.Ok());
    }

    private async Task Apply()
    {
        await Persist();
    }

    private void Cancel() => ModalService.Close(ModalResult.Cancel());
}
