@page "/cardmanager"
@using System.Text.Json
@using DoorsWeb.Client.Auth
@using DoorsWeb.Shared.DTO
@using DoorsWeb.Shared.Entities
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory ClientFactory
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@implements IAsyncDisposable

<Card>
    <CardHeader>
        <CardTitle>
            <Icon class="icon me-2" IconType="@TablerIcons.Users" />Card Manager
            @if (isLoadingMore)
            {
                <span class="ms-3 text-muted small fw-normal d-inline-flex align-items-center">
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading more… (@cards.Count)
                </span>
            }
        </CardTitle>
        <CardActions class="ms-auto">
            @if (canWrite)
            {
                <Button BackgroundColor="TablerColor.Success" Class="me-2" OnClick='() => ShowCardEditModal("New Record", 0)'>
                    <Icon class="icon me-1" IconType="@TablerIcons.Plus" />Add Card
                </Button>
            }
            <Button BackgroundColor="TablerColor.Secondary" Class="me-2" OnClick="ShowCardPacksModal">
                <Icon class="icon me-1" IconType="@TablerIcons.Stack_2" />Card Packs
            </Button>
            <Button BackgroundColor="TablerColor.Secondary" OnClick="Refresh">
                <Icon class="icon me-1" IconType="@TablerIcons.Refresh" />Refresh
            </Button>
        </CardActions>
    </CardHeader>
    <CardBody>
        @if (!IsLoaded)
        {
            @* Shown only until the first batch arrives; then the table renders and the rest streams in behind the header chip. *@
            <Progress Color="TablerColor.Blue" Indeterminate />
        }
        else
        {
            @if (!canWrite)
            {
                <div class="alert alert-info mb-3" role="alert">
                    <Icon class="icon me-2" IconType="@TablerIcons.Eye" />
                    You have read-only access to the card manager. Adding, editing and deleting are disabled.
                </div>
            }
            <Table @ref="table" Item="CardDto" Items="filteredCards" PageSize="pageSize" Hover Responsive>
                @* Filter bar sits in the table header, next to the built-in (contains-across-columns) search box.
                   Everything here refines the already-streamed set client-side via ApplyFilters. *@
                <HeaderTemplate>
                    <div class="d-flex flex-wrap align-items-end gap-3">
                        @* Text criterion: field + operator + value (case-insensitive). *@
                        <div class="d-flex flex-column">
                            <label class="form-label mb-1 small">Search field</label>
                            <div class="d-flex gap-1">
                                <select class="form-select form-select-sm" style="width: auto;"
                                        @bind="textField" @bind:after="ApplyFilters">
                                    <option value="Surname">Last Name</option>
                                    <option value="Forname">First Name</option>
                                    <option value="CardId">Card Number</option>
                                </select>
                                <select class="form-select form-select-sm" style="width: auto;"
                                        @bind="textOp" @bind:after="ApplyFilters">
                                    <option value="contains">contains</option>
                                    <option value="begins">begins with</option>
                                    <option value="ends">ends with</option>
                                    <option value="equals">equals</option>
                                    <option value="notequals">not equals</option>
                                </select>
                                <input class="form-control form-control-sm" style="width: 11rem;" placeholder="value…"
                                       @bind="textValue" @bind:event="oninput" @bind:after="DebouncedApplyFilters" />
                            </div>
                        </div>

                        @* Access level. *@
                        <div class="d-flex flex-column">
                            <label class="form-label mb-1 small">Access Level</label>
                            <select class="form-select form-select-sm" style="width: auto;"
                                    @bind="selectedAccessLevel" @bind:after="ApplyFilters">
                                <option value="">All</option>
                                @foreach (var al in accessLevelOptions)
                                {
                                    <option value="@al">@al</option>
                                }
                            </select>
                        </div>

                        @* Status toggles. *@
                        <div class="d-flex flex-column">
                            <label class="form-label mb-1 small">Enabled</label>
                            <select class="form-select form-select-sm" style="width: auto;"
                                    @bind="enabledFilter" @bind:after="ApplyFilters">
                                <option value="">All</option>
                                <option value="yes">Enabled</option>
                                <option value="no">Disabled</option>
                            </select>
                        </div>
                        <div class="d-flex flex-column">
                            <label class="form-label mb-1 small">Void</label>
                            <select class="form-select form-select-sm" style="width: auto;"
                                    @bind="voidFilter" @bind:after="ApplyFilters">
                                <option value="">All</option>
                                <option value="no">Not void</option>
                                <option value="yes">Void</option>
                            </select>
                        </div>

                        @* Valid-date range (only applies when a date is set; cards with no date are excluded). *@
                        <div class="d-flex flex-column">
                            <label class="form-label mb-1 small">Valid from ≥</label>
                            <input type="date" class="form-control form-control-sm" style="width: auto;"
                                   @bind="validFromAfter" @bind:after="ApplyFilters" />
                        </div>
                        <div class="d-flex flex-column">
                            <label class="form-label mb-1 small">Valid to ≤</label>
                            <input type="date" class="form-control form-control-sm" style="width: auto;"
                                   @bind="validToBefore" @bind:after="ApplyFilters" />
                        </div>

                        @* Reset everything. *@
                        <div class="d-flex flex-column">
                            <label class="form-label mb-1 small">&nbsp;</label>
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="ClearFilters">
                                <Icon class="icon icon-sm me-1" IconType="@TablerIcons.Filter_off" />Clear
                            </button>
                        </div>
                    </div>
                </HeaderTemplate>
                <ChildContent>
                    <Column Item="CardDto" Property="c => c.CardId" Title="Card Number" Searchable Sortable>
                        <Template>
                            @if (string.IsNullOrWhiteSpace(context.CardId))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @context.CardId
                            }
                        </Template>
                    </Column>
                    <Column Item="CardDto" Property="c => c.Surname" Title="Last Name" Searchable Sortable>
                        <Template>
                            @if (string.IsNullOrWhiteSpace(context.Surname))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @context.Surname
                            }
                        </Template>
                    </Column>
                    <Column Item="CardDto" Property="c => c.Forname" Title="First Name" Searchable Sortable>
                        <Template>
                            @if (string.IsNullOrWhiteSpace(context.Forname))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @context.Forname
                            }
                        </Template>
                    </Column>
                    <Column Item="CardDto" Title="Access Levels">
                        <Template>
                            @if (context.AccessLevels.Count == 0)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @foreach (var level in context.AccessLevels)
                                {
                                    <span class="badge bg-azure-lt me-1 mb-1">@level</span>
                                }
                            }
                        </Template>
                    </Column>
                    @if (canWrite)
                    {
                        <Column Item="CardDto" title="" ActionColumn Width="130px">
                            <Template>
                                <span class="row-action">
                                    <Icon class="icon" IconType="@TablerIcons.Edit" @onclick='() => ShowCardEditModal("Card Record", context.CardNumber)' />
                                    <Icon class="icon" IconType="@TablerIcons.Trash" @onclick="() => ConfirmDeleteCard(context.CardNumber)" />
                                </span>
                            </Template>
                        </Column>
                    }
                </ChildContent>
            </Table>
            @if (filteredCards.Count == 0)
            {
                <div class="text-muted text-center py-4">No cards found.</div>
            }
            <div class="text-muted small mt-2">
                <Icon class="icon icon-sm me-1" IconType="@TablerIcons.Info_circle" />
                Tip: use the <kbd>←</kbd> / <kbd>→</kbd> arrow keys to change pages.
            </div>
        }
    </CardBody>
</Card>

@code {
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    private bool IsLoaded = false;

    // Whether the signed-in user may mutate cards (Card Manager ReadWrite). Read-only users still
    // see the list. The API is the real boundary; this just hides the Add/Edit/Delete controls.
    private bool canWrite;

    private HttpClient client = new HttpClient();
    private List<CardDto> cards = new();              // full set streamed from the API
    private List<CardDto> filteredCards = new();      // what the table shows after the Access Level filter

    private List<string> accessLevelOptions = new();  // distinct access-level names for the dropdown
    private string? selectedAccessLevel;              // null / "" = all access levels

    // Text criterion: which field, which operator, and the (case-insensitive) needle.
    private string textField = "Surname";             // "Surname" | "Forname" | "CardId"
    private string textOp = "contains";               // contains | begins | ends | equals | notequals
    private string textValue = "";

    // Status toggles: "" = all, "yes" / "no" otherwise.
    private string enabledFilter = "";
    private string voidFilter = "";

    // Valid-date range bounds (null = unbounded on that side).
    private DateTime? validFromAfter;
    private DateTime? validToBefore;

    // Debounce for the live text filter: a fast typist would otherwise trigger a full O(n)
    // re-filter on every keystroke. We wait FilterDebounceMs after the last keystroke and
    // cancel any pending run, so only the final value is applied.
    private const int FilterDebounceMs = 250;
    private CancellationTokenSource? filterDebounceCts;

    // True while rows are still streaming in after the first batch has painted (drives the header chip).
    private bool isLoadingMore;
    private static readonly JsonSerializerOptions JsonWebOptions = new(JsonSerializerDefaults.Web);

    // Paint the first FirstPaintRows as soon as they arrive, then append the remainder,
    // repainting every RepaintEvery rows so the UI stays responsive during the background load.
    private const int FirstPaintRows = 200;
    private const int RepaintEvery = 100;

    // Rows per page, sized to the viewport height (see ComputePageSize). Bucketed so the
    // table doesn't reflow on every pixel of a window drag.
    private int pageSize = 10;
    private IJSObjectReference? viewportModule;
    private DotNetObjectReference<CardManagerPage>? selfRef;

    // Bound to the table so the Left/Right arrow keys can drive its pager.
    private Table<CardDto>? table;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        canWrite = state.User.CanWriteCardManager();

        client = ClientFactory.CreateClient("WebAPI");
        await Refresh();
    }

    // Size the page to the window on first render, then track resizes via JS interop.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        viewportModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/viewport.js");
        var height = await viewportModule.InvokeAsync<double>("getInnerHeight");
        ApplyPageSize(height);

        selfRef = DotNetObjectReference.Create(this);
        await viewportModule.InvokeVoidAsync("registerResize", selfRef);
        await viewportModule.InvokeVoidAsync("registerPageKeys", selfRef);
    }

    [JSInvokable]
    public void OnViewportResized(double height) => ApplyPageSize(height);

    // Left/Right arrow keys turn the table's pages (direction: -1 prev, +1 next).
    [JSInvokable]
    public async Task OnPageKey(int direction)
    {
        if (table is null) return;
        if (direction > 0)
            await table.NextPage();
        else
            await table.PreviousPage();
    }

    // Recompute rows-per-page and repaint only when the bucket actually changes.
    private void ApplyPageSize(double viewportHeight)
    {
        var next = ComputePageSize(viewportHeight);
        if (next == pageSize) return;
        pageSize = next;
        StateHasChanged();
    }

    // Bucket the viewport height into a few row counts. Bounds are rough: the page chrome
    // (app header, card header, search/pager) eats ~320px and each table row is ~40px.
    private static int ComputePageSize(double viewportHeight) => viewportHeight switch
    {
        < 700 => 5,
        < 900 => 10,
        < 1100 => 20,
        _ => 35
    };

    private Task Refresh() => LoadCards();

    // Streams cards from the API, painting the first FirstPaintRows as soon as they arrive
    // so the table is usable almost immediately, then appending the remainder in the
    // background (isLoadingMore drives the header chip).
    private async Task LoadCards()
    {
        IsLoaded = false;
        isLoadingMore = true;
        StateHasChanged();

        var loaded = new List<CardDto>();
        try
        {
            using var response = await client.GetAsync("api/Cardholder/cards", HttpCompletionOption.ResponseHeadersRead);
            response.EnsureSuccessStatusCode();
            using var stream = await response.Content.ReadAsStreamAsync();

            await foreach (var card in JsonSerializer.DeserializeAsyncEnumerable<CardDto>(stream, JsonWebOptions))
            {
                if (card is null) continue;
                loaded.Add(card);

                if (!IsLoaded && loaded.Count >= FirstPaintRows)
                {
                    // First batch is in: bind it and reveal the table.
                    cards = loaded;
                    RebuildAccessLevelOptions();
                    ApplyFilters();
                    IsLoaded = true;
                    StateHasChanged();
                    await Task.Yield();
                }
                else if (IsLoaded && loaded.Count % RepaintEvery == 0)
                {
                    // Subsequent rows: refresh the visible set periodically without blocking.
                    cards = loaded;
                    RebuildAccessLevelOptions();
                    ApplyFilters();
                    StateHasChanged();
                    await Task.Yield();
                }
            }
        }
        catch
        {
            // Fall through with whatever streamed in; the table still renders.
        }

        cards = loaded;
        RebuildAccessLevelOptions();
        ApplyFilters();
        IsLoaded = true;
        isLoadingMore = false;
    }

    // Build the Access Level dropdown options from the distinct access-level names currently loaded.
    private void RebuildAccessLevelOptions()
    {
        accessLevelOptions = cards
            .SelectMany(c => c.AccessLevels)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Distinct()
            .OrderBy(n => n)
            .ToList();
    }

    // Coalesce rapid keystrokes in the text box: each call cancels the previous pending filter and
    // schedules a fresh one FilterDebounceMs later, so only the last keystroke triggers ApplyFilters.
    private async Task DebouncedApplyFilters()
    {
        filterDebounceCts?.Cancel();
        filterDebounceCts?.Dispose();
        var cts = new CancellationTokenSource();
        filterDebounceCts = cts;

        try
        {
            await Task.Delay(FilterDebounceMs, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return; // superseded by a newer keystroke
        }

        ApplyFilters();
        StateHasChanged();
    }

    // All filters are client-side refinements over the streamed set, AND-combined (each is skipped
    // when left at its "all" default). Repaints happen via @bind:after as the user changes a control.
    private void ApplyFilters()
    {
        IEnumerable<CardDto> q = cards;

        if (!string.IsNullOrEmpty(selectedAccessLevel))
            q = q.Where(c => c.AccessLevels.Contains(selectedAccessLevel));

        if (!string.IsNullOrWhiteSpace(textValue))
        {
            var needle = textValue.Trim();
            q = q.Where(c => MatchesText(FieldValue(c, textField), needle, textOp));
        }

        if (enabledFilter == "yes") q = q.Where(c => c.Enabled == true);
        else if (enabledFilter == "no") q = q.Where(c => c.Enabled != true);

        if (voidFilter == "yes") q = q.Where(c => c.Void == true);
        else if (voidFilter == "no") q = q.Where(c => c.Void != true);

        if (validFromAfter is DateTime from)
            q = q.Where(c => c.ValidFrom.HasValue && c.ValidFrom.Value.Date >= from.Date);

        if (validToBefore is DateTime to)
            q = q.Where(c => c.ValidTo.HasValue && c.ValidTo.Value.Date <= to.Date);

        filteredCards = q.ToList();
    }

    // Pick the column the text criterion targets.
    private static string? FieldValue(CardDto c, string field) => field switch
    {
        "Forname" => c.Forname,
        "CardId" => c.CardId,
        _ => c.Surname,
    };

    // Case-insensitive text match mirroring the legacy operators (contains/begins/ends/=/<>).
    private static bool MatchesText(string? value, string needle, string op)
    {
        var v = value ?? "";
        return op switch
        {
            "begins" => v.StartsWith(needle, StringComparison.OrdinalIgnoreCase),
            "ends" => v.EndsWith(needle, StringComparison.OrdinalIgnoreCase),
            "equals" => string.Equals(v, needle, StringComparison.OrdinalIgnoreCase),
            "notequals" => !string.Equals(v, needle, StringComparison.OrdinalIgnoreCase),
            _ => v.Contains(needle, StringComparison.OrdinalIgnoreCase), // contains (default)
        };
    }

    // Reset every filter control back to "all" and repaint.
    private void ClearFilters()
    {
        textField = "Surname";
        textOp = "contains";
        textValue = "";
        selectedAccessLevel = null;
        enabledFilter = "";
        voidFilter = "";
        validFromAfter = null;
        validToBefore = null;
        ApplyFilters();
    }

    private async Task ShowCardEditModal(string title, int cardNumber)
    {
        // T_Name_Header.CardNumber is assigned by us (ValueGeneratedNever), so suggest the next free id.
        var next = cards.Count == 0 ? 1 : cards.Max(c => c.CardNumber) + 1;

        var component = new RenderComponent<CardEditModal>()
            .Set(e => e.CardNumber, cardNumber)
            .Set(e => e.NextCardNumber, next);

        var result = await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
            ModalCssClass = "modal-wide-30", // ~30% wider than Large (see site.css)
        });

        if (!result.Cancelled)
        {
            await Refresh();
        }
    }

    // ---- Card Packs: name-only list modal (api/CardPackHeader, key Code) ----
    private async Task ShowCardPacksModal()
    {
        var component = new RenderComponent<EntityListModal>()
            .Set(e => e.ItemNoun, "Card Pack")
            .Set(e => e.Load, LoadCardPackRows);
        // Read-only users get a view-only list (EntityListModal hides Add/Edit/Delete when these are null).
        if (canWrite)
            component.Set(e => e.OnAdd, () => ShowCardPackEdit(null))
                     .Set(e => e.OnEdit, (EntityListRow row) => ShowCardPackEdit(row))
                     .Set(e => e.OnDelete, DeleteCardPack);

        await ModalService.ShowAsync("Card Packs", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
            CloseOnEsc = true,
        });
    }

    private async Task<List<EntityListRow>> LoadCardPackRows()
    {
        var list = await client.GetFromJsonAsync<List<CardPack>>("api/CardPackHeader") ?? new();
        return list.OrderBy(p => p.Name)
                   .Select(p => new EntityListRow { Id = p.Code.ToString(), Name = p.Name ?? "" }).ToList();
    }

    private async Task ShowCardPackEdit(EntityListRow? row)
    {
        var title = row is null ? "Card packs - New card pack" : "Card packs - Edit card pack";
        var component = new RenderComponent<CardPackModal>();
        // TabBlazor's RenderComponent.Set rejects null, so only set the key when editing.
        if (row is not null) component.Set(e => e.CardPackId, int.Parse(row.Id));

        await ModalService.ShowAsync(title, component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
    }

    private async Task DeleteCardPack(EntityListRow row)
    {
        await client.DeleteAsync($"api/CardPackHeader/{row.Id}");
    }

    private async Task ConfirmDeleteCard(int cardNumber)
    {
        var confirmed = await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = $"Delete card {cardNumber}?",
            SubText = "This action cannot be undone!",
            IconType = TablerIcons.Alert_triangle,
            StatusColor = TablerColor.Danger
        });
        if (!confirmed) return;

        await client.DeleteAsync($"api/Cardholder/{cardNumber}");
        await Refresh();
    }

    public async ValueTask DisposeAsync()
    {
        filterDebounceCts?.Cancel();
        filterDebounceCts?.Dispose();

        if (viewportModule is not null)
        {
            try
            {
                await viewportModule.InvokeVoidAsync("unregisterResize");
                await viewportModule.InvokeVoidAsync("unregisterPageKeys");
                await viewportModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit already gone */ }
        }
        selfRef?.Dispose();
    }
}
