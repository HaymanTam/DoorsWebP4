@page "/doors"
@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<Card>
    <CardHeader>
        <CardTitle>
            <Icon class="icon me-2" IconType="@TablerIcons.Door" />Doors
        </CardTitle>
        <CardActions class="ms-auto">
            <Button BackgroundColor="TablerColor.Primary" @onclick='(() => ShowDoorEditModal("New Door", 0))'>
                <Icon class="icon me-1" IconType="@TablerIcons.Plus" />Add Door
            </Button>
        </CardActions>
    </CardHeader>
    <CardBody>
        @if (!IsLoaded)
        {
            <Progress Color="TablerColor.Blue" Indeterminate />
        }
        else
        {
            <Table Item="DoorListDto" Items="doorList" PageSize="pageSize"
                   Hover Responsive EditMode=TableEditMode.Popup>
                <ChildContent>
                    <Column Item="DoorListDto" Property="e => e.Door" Title="Door" Sortable Visible=false>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.Door" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.Name" Title="Name" Searchable Sortable>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.Name" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.ControllerId" Title="Controller ID" Searchable Sortable>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.ControllerId" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.IPAddressString" Title="IP Address" Searchable Sortable>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.IPAddressString" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.LastUpdated" Title="Last Updated" Sortable>
                        <Template>
                            @(context.LastUpdated != default ? context.LastUpdated : "")
                        </Template>
                    </Column>
                    <Column Item="DoorListDto" title="" ActionColumn Width="130px">
                        <Template>
                            <span class="row-action">
                                <Icon class="icon" IconType="@TablerIcons.Edit" @onclick='(() => ShowDoorEditModal("Edit Door", context.Door))' />
                                <Icon class="icon" IconType="@TablerIcons.Trash" @onclick='(() => ConfirmDeleteDoor(context.Door, context.ControllerId))' />
                            </span>
                        </Template>
                    </Column>
                </ChildContent>
            </Table>
            @if (doorList.Count == 0)
            {
                <div class="text-muted text-center py-4">No doors found.</div>
            }
        }
    </CardBody>
</Card>



@code {
    [Inject] TabBlazor.Services.TablerService TablerService { get; set; } = null!;
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    private bool IsLoaded = false;
    private HttpClient client = new HttpClient();
    private List<DoorListDto> doorList = new List<DoorListDto>();

    // Rows per page, sized to the viewport height (see ComputePageSize). Bucketed so the
    // table doesn't reflow on every pixel of a window drag.
    private int pageSize = 10;
    private IJSObjectReference? viewportModule;
    private DotNetObjectReference<DoorsPage>? selfRef;

    protected override async Task OnInitializedAsync()
    {
        client = ClientFactory.CreateClient("WebAPI");
        doorList = await client.GetFromJsonAsync<List<DoorListDto>>("api/Door") ?? [];
        IsLoaded = true;
    }

    // Size the page to the window on first render, then track resizes via JS interop.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        viewportModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/viewport.js");
        var height = await viewportModule.InvokeAsync<double>("getInnerHeight");
        ApplyPageSize(height);

        selfRef = DotNetObjectReference.Create(this);
        await viewportModule.InvokeVoidAsync("registerResize", selfRef);
    }

    [JSInvokable]
    public void OnViewportResized(double height) => ApplyPageSize(height);

    // Recompute rows-per-page and repaint only when the bucket actually changes.
    private void ApplyPageSize(double viewportHeight)
    {
        var next = ComputePageSize(viewportHeight);
        if (next == pageSize) return;
        pageSize = next;
        StateHasChanged();
    }

    // Bucket the viewport height into a few row counts. Bounds are rough: the page chrome
    // (app header, card header, search/pager) eats ~320px and each table row is ~40px.
    private static int ComputePageSize(double viewportHeight) => viewportHeight switch
    {
        < 700 => 5,
        < 900 => 10,
        < 1100 => 20,
        _ => 35
    };

    private async Task ShowDoorEditModal(string title, int DoorId)
    {
        var component = new RenderComponent<DoorEditModal>().Set(e => e.DoorId, DoorId);
        var result = await ModalService.ShowAsync(title, component, new ModalOptions { 
                                    Size = ModalSize.Large, 
                                    ShowHeader = true, 
                                    Scrollable = false,
                                    });
        if (!result.Cancelled)
        {
            doorList = await client.GetFromJsonAsync<List<DoorListDto>>("api/Door") ?? [];
        }
    }

    private async Task ConfirmDeleteDoor(int DoorId, int CtrlId)
    {
        var result = await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = $"Delete Door Controller {CtrlId}?",
            SubText = "This action cannot be undone!",
            IconType = TablerIcons.Alert_triangle,
            StatusColor = TablerColor.Danger
        });
        if (result)
        {
            doorList = await client.DeleteFromJsonAsync<List<DoorListDto>>("api/Door/" + DoorId) ?? [];
        }
    }

    private async Task ShowDialog(string title)
    {
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            CancelText = "",
            StatusColor = TablerColor.Primary,
            IconType = TablerIcons.Info_circle,
            MainText = title
        });
    }

    public async ValueTask DisposeAsync()
    {
        if (viewportModule is not null)
        {
            try
            {
                await viewportModule.InvokeVoidAsync("unregisterResize");
                await viewportModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit already gone */ }
        }
        selfRef?.Dispose();
    }

}
