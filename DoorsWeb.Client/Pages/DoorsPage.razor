@page "/doors"
@page "/doors/{Site:int}"
@using DoorsWeb.Client.Auth
@using DoorsWeb.Client.Services
@using DoorsWeb.Shared.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory ClientFactory
@inject AuthenticationStateProvider AuthState
@inject DoorStatusStore DoorStatus
@inject IJSRuntime JS
@implements IAsyncDisposable

<Card>
    <CardHeader>
        <CardTitle>
            <Icon class="icon me-2" IconType="@TablerIcons.Door" />Doors
        </CardTitle>
        <CardActions class="ms-auto">
            @if (canWrite)
            {
                <Button BackgroundColor="TablerColor.Success" @onclick='(() => ShowDoorEditModal("New Door", 0))'>
                    <Icon class="icon me-1" IconType="@TablerIcons.Plus" />Add Door
                </Button>
            }
        </CardActions>
    </CardHeader>
    <CardBody>
        @if (!IsLoaded)
        {
            <Progress Color="TablerColor.Blue" Indeterminate />
        }
        else
        {
            @if (!canWrite)
            {
                <div class="alert alert-info mb-3" role="alert">
                    <Icon class="icon me-2" IconType="@TablerIcons.Eye" />
                    You have read-only access to site settings. Adding, editing and deleting doors are disabled.
                </div>
            }
            @* Pending commands: operator commands that have been sent but not yet acknowledged by the
               controller. The server retries them automatically; this panel shows what's outstanding
               and lets a writer cancel a single command or all of them. *@
            @if (DoorStatus.PendingCount > 0)
            {
                <div class="card mb-3 border-warning">
                    <div class="card-header d-flex align-items-center">
                        <Icon class="icon me-2" IconType="@TablerIcons.Clock" />
                        <span class="fw-bold">Pending commands (@DoorStatus.PendingCount)</span>
                        <span class="text-muted small ms-2 d-none d-md-inline">Sent but not yet acknowledged — retrying automatically.</span>
                        @if (canWrite)
                        {
                            <Button class="ms-auto" Size="ButtonSize.Small" BackgroundColor="TablerColor.Danger" @onclick="ClearAllPending">
                                <Icon class="icon me-1" IconType="@TablerIcons.Trash" />Clear all
                            </Button>
                        }
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var cmd in DoorStatus.PendingCommands)
                        {
                            <div class="list-group-item d-flex align-items-center gap-2" @key="cmd.Id">
                                <span class="fw-bold">@DoorLabel(cmd)</span>
                                <span class="text-muted">— @cmd.Description</span>
                                <span class="badge bg-warning-lt" title="Transmission attempts">
                                    @cmd.Attempts attempt@(cmd.Attempts == 1 ? "" : "s")
                                </span>
                                <span class="text-muted small">@PendingAge(cmd)</span>
                                @if (canWrite)
                                {
                                    <Icon class="icon ms-auto row-action text-danger" IconType="@TablerIcons.X"
                                          title="Cancel this command" @onclick="() => ClearPending(cmd.Id)" />
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            @* Editing is fully custom (Add button + action column below, both gated on canWrite),
               so the built-in edit mode is disabled via AllowAdd/AllowEdit/AllowDelete. *@
            <Table @ref="table" Item="DoorListDto" Items="VisibleDoors" PageSize="pageSize"
                   Hover Responsive EditMode="TableEditMode.Popup"
                   AllowAdd="canWrite" AllowEdit="canWrite" AllowDelete="canWrite">
                <ChildContent>
                    <Column Item="DoorListDto" Property="e => e.Door" Title="Door" Sortable Visible=false>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.Door" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.Name" Title="Name" Searchable Sortable>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.Name" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.ControllerIdString" Title="Controller ID" Searchable Sortable>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.ControllerId" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.IPAddressString" Title="IP Address" Searchable Sortable>
                        <EditorTemplate>
                            <input type="text" class="form-control" @bind-value="@context.IPAddressString" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="DoorListDto" Property="e => e.LastUpdated" Title="Last Updated" Sortable>
                        <Template>
                            @(context.LastUpdated != default ? context.LastUpdated : "")
                        </Template>
                    </Column>
                    @* Live activity from the controller's pings (DoorStatusStore). Blue chips mean
                       "not yet known" — no ping reply has been decoded for that relay. *@
                    <Column Item="DoorListDto" title="Activity" Width="220px">
                        <Template>
                            @{
                                var live = DoorStatus.TryGet(context.Door);
                            }
                            @if (live is null)
                            {
                                <span class="badge bg-blue-lt" title="No live status yet">Unknown</span>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap align-items-center gap-1" title="@ActivityTooltip(live)">
                                    @if (live.Status == DoorLiveStatus.Offline)
                                    {
                                        <span class="badge bg-secondary text-white">
                                            <span class="status-dot me-1"></span>Inactive
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-green-lt">
                                            <span class="status-dot status-dot-animated bg-green me-1"></span>Active
                                        </span>
                                    }
                                    @{
                                        var (relayClass, relayLabel) = RelayChip(live.Hardware?.RelayA ?? RelayState.Unknown);
                                    }
                                    <span class="badge @relayClass">@relayLabel</span>
                                    @foreach (var alarm in AlarmLabels(live))
                                    {
                                        <span class="badge bg-red text-white">@alarm</span>
                                    }
                                </div>
                            }
                        </Template>
                    </Column>
                    @if (canWrite)
                    {
                        <Column Item="DoorListDto" title="" ActionColumn Width="130px">
                            <Template>
                                <span class="row-action">
                                    <Icon class="icon" IconType="@TablerIcons.Edit" @onclick='(() => ShowDoorEditModal("Edit Door", context.Door))' />
                                    <Icon class="icon" IconType="@TablerIcons.Trash" @onclick='(() => ConfirmDeleteDoor(context.Door, context.ControllerId))' />
                                </span>
                            </Template>
                        </Column>
                    }
                </ChildContent>
            </Table>
            @if (VisibleDoors.Count == 0)
            {
                <div class="text-muted text-center py-4">No doors found.</div>
            }
            <div class="text-muted small mt-2">
                <Icon class="icon icon-sm me-1" IconType="@TablerIcons.Info_circle" />
                Tip: use the <kbd>←</kbd> / <kbd>→</kbd> arrow keys to change pages.
            </div>
        }
    </CardBody>
</Card>



@code {
    [Inject] TabBlazor.Services.TablerService TablerService { get; set; } = null!;
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    // Set when reached via /doors/{site} (the per-site nav link). Filters the list and is the
    // site newly-added doors are assigned to. Null on the bare /doors route = show all doors.
    [Parameter] public int? Site { get; set; }

    // Doors shown for the current route: this site's doors, or all when no site is in the URL.
    private List<DoorListDto> VisibleDoors =>
        Site is int s ? doorList.Where(d => d.Site == s).ToList() : doorList;

    private bool IsLoaded = false;

    // Whether the signed-in user may mutate doors (Site Settings ReadWrite). Read-only users still
    // see the list. The API is the real boundary; this just hides the Add/Edit/Delete controls.
    private bool canWrite;

    private HttpClient client = new HttpClient();
    private List<DoorListDto> doorList = new List<DoorListDto>();

    // Rows per page, sized to the viewport height (see ComputePageSize). Bucketed so the
    // table doesn't reflow on every pixel of a window drag.
    private int pageSize = 10;
    private IJSObjectReference? viewportModule;
    private DotNetObjectReference<DoorsPage>? selfRef;

    // Bound to the table so the Left/Right arrow keys can drive its pager.
    private Table<DoorListDto>? table;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        canWrite = state.User.CanWriteSiteSettings();

        client = ClientFactory.CreateClient("WebAPI");
        doorList = await client.GetFromJsonAsync<List<DoorListDto>>("api/Door") ?? [];
        IsLoaded = true;

        // Live activity column: subscribe before starting so we don't miss the first snapshot fire.
        DoorStatus.Changed += OnDoorStatusChanged;
        await DoorStatus.EnsureStartedAsync();
    }

    private void OnDoorStatusChanged() => InvokeAsync(StateHasChanged);

    // Size the page to the window on first render, then track resizes via JS interop.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        viewportModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/viewport.js");
        var height = await viewportModule.InvokeAsync<double>("getInnerHeight");
        ApplyPageSize(height);

        selfRef = DotNetObjectReference.Create(this);
        await viewportModule.InvokeVoidAsync("registerResize", selfRef);
        await viewportModule.InvokeVoidAsync("registerPageKeys", selfRef);
    }

    [JSInvokable]
    public void OnViewportResized(double height) => ApplyPageSize(height);

    // Left/Right arrow keys turn the table's pages (direction: -1 prev, +1 next).
    [JSInvokable]
    public async Task OnPageKey(int direction)
    {
        if (table is null) return;
        if (direction > 0)
            await table.NextPage();
        else
            await table.PreviousPage();
    }

    // Recompute rows-per-page and repaint only when the bucket actually changes.
    private void ApplyPageSize(double viewportHeight)
    {
        var next = ComputePageSize(viewportHeight);
        if (next == pageSize) return;
        pageSize = next;
        StateHasChanged();
    }

    // Bucket the viewport height into a few row counts. Bounds are rough: the page chrome
    // (app header, card header, search/pager) eats ~320px and each table row is ~40px.
    private static int ComputePageSize(double viewportHeight) => viewportHeight switch
    {
        < 700 => 5,
        < 900 => 10,
        < 1100 => 20,
        _ => 35
    };

    private async Task ShowDoorEditModal(string title, int DoorId)
    {
        var component = new RenderComponent<DoorEditModal>().Set(e => e.DoorId, DoorId);
        // Hand the current site to the editor so a new door is created under it (0 = none).
        if (Site is int s) component.Set(e => e.SiteId, s);
        var result = await ModalService.ShowAsync(title, component, new ModalOptions {
                                    Size = ModalSize.Large, 
                                    ShowHeader = true, 
                                    Scrollable = false,
                                    });
        if (!result.Cancelled)
        {
            doorList = await client.GetFromJsonAsync<List<DoorListDto>>("api/Door") ?? [];
        }
    }

    private async Task ConfirmDeleteDoor(int DoorId, int CtrlId)
    {
        var result = await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = $"Delete Door Controller {CtrlId}?",
            SubText = "This action cannot be undone!",
            IconType = TablerIcons.Alert_triangle,
            StatusColor = TablerColor.Danger
        });
        if (result)
        {
            doorList = await client.DeleteFromJsonAsync<List<DoorListDto>>("api/Door/" + DoorId) ?? [];
        }
    }

    private async Task ShowDialog(string title)
    {
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            CancelText = "",
            StatusColor = TablerColor.Primary,
            IconType = TablerIcons.Info_circle,
            MainText = title
        });
    }

    // Maps a relay state to a Tabler badge class + label. Unknown is blue ("not yet known").
    private static (string cssClass, string label) RelayChip(RelayState state) => state switch
    {
        RelayState.Open => ("bg-azure-lt", "Released"),
        RelayState.Closed => ("bg-green-lt", "Locked"),
        _ => ("bg-blue-lt", "Unknown")
    };

    // ---- Pending commands ---------------------------------------------------------

    private async Task ClearPending(Guid id) => await DoorStatus.ClearCommandAsync(id);

    private async Task ClearAllPending() => await DoorStatus.ClearAllAsync();

    // Door display label for the pending list: the door's name, falling back to its number.
    private static string DoorLabel(PendingCommandDto cmd)
        => string.IsNullOrWhiteSpace(cmd.DoorName) ? $"Door {cmd.Door}" : cmd.DoorName!;

    // Rough "how long it's been waiting" for the pending list (refreshes on each retry/push).
    private static string PendingAge(PendingCommandDto cmd)
    {
        var elapsed = DateTime.UtcNow - cmd.CreatedUtc;
        if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;
        if (elapsed.TotalSeconds < 60) return $"waiting {(int)elapsed.TotalSeconds}s";
        if (elapsed.TotalMinutes < 60) return $"waiting {(int)elapsed.TotalMinutes}m";
        return $"waiting {(int)elapsed.TotalHours}h";
    }

    // The names of every active alarm on a door, for the red chips.
    private static IEnumerable<string> AlarmLabels(DoorStateDto live)
    {
        var alarms = live.Hardware?.Alarms ?? DoorAlarmFlags.None;
        foreach (DoorAlarmFlags flag in Enum.GetValues<DoorAlarmFlags>())
        {
            if (flag != DoorAlarmFlags.None && alarms.HasFlag(flag))
                yield return flag.ToString();
        }
    }

    // Hover detail for the Activity cell: relays, firmware, supply, unread logs and poll time.
    private static string ActivityTooltip(DoorStateDto live)
    {
        var hw = live.Hardware;
        if (hw is null)
            return $"{live.Status}";

        var parts = new List<string>
        {
            $"State: {live.Status}",
            $"Relay A: {hw.RelayA}",
            $"Relay B: {hw.RelayB}"
        };
        if (!string.IsNullOrWhiteSpace(hw.FirmwareVersion))
            parts.Add($"Firmware: {hw.FirmwareVersion}");
        if (hw.SupplyVoltage is double v)
            parts.Add($"Supply: {v:0.0} V");
        if (hw.UnreadLogCount is int logs)
            parts.Add($"Unread logs: {logs}");
        if (hw.LastPolledUtc is DateTime polled)
            parts.Add($"Last polled: {polled.ToLocalTime():g}");
        return string.Join(" · ", parts);
    }

    public async ValueTask DisposeAsync()
    {
        DoorStatus.Changed -= OnDoorStatusChanged;
        if (viewportModule is not null)
        {
            try
            {
                await viewportModule.InvokeVoidAsync("unregisterResize");
                await viewportModule.InvokeVoidAsync("unregisterPageKeys");
                await viewportModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit already gone */ }
        }
        selfRef?.Dispose();
    }

}
