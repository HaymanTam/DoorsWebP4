@page "/events"
@using System.Text.Json
@using DoorsWeb.Client.Services
@using DoorsWeb.Shared.DTO
@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JS
@inject EventHubClient Hub
@implements IAsyncDisposable

<Card>
    <CardHeader>
        <CardTitle>
            <Icon class="icon me-2" IconType="@TablerIcons.Search" />Events
            @if (isLoadingMore)
            {
                <span class="ms-3 text-muted small fw-normal d-inline-flex align-items-center">
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading more… (@eventList.Count)
                </span>
            }
        </CardTitle>
        <CardActions class="ms-auto d-flex align-items-center gap-2 flex-wrap">
            @* Date range is staged in pendingFrom/pendingTo and only hits the server on Apply. *@
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0">From</label>
                <input type="datetime-local" class="form-control form-control-sm" style="width: auto;"
                       value="@pendingFrom?.ToString("yyyy-MM-ddTHH:mm")" @onchange="OnFromChanged" />
            </div>
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0">To</label>
                <input type="datetime-local" class="form-control form-control-sm" style="width: auto;"
                       value="@pendingTo?.ToString("yyyy-MM-ddTHH:mm")" @onchange="OnToChanged" />
            </div>
            <Button BackgroundColor="TablerColor.Secondary" OnClick="ClearFilters">
                <Icon class="icon me-1" IconType="@TablerIcons.X" />Clear
            </Button>
            <Button BackgroundColor="TablerColor.Primary" OnClick="ApplyDateRange">
                <Icon class="icon me-1" IconType="@TablerIcons.Check" />Apply
            </Button>
        </CardActions>
    </CardHeader>
    <CardBody>
        @if (!IsLoaded)
        {
            @* Shown only until the first batch arrives; then the table renders and the rest streams in behind the header chip. *@
            <Progress Color="TablerColor.Blue" Indeterminate />
        }
        else
        {
            @if (eventList.Count >= MaxRows)
            {
                <div class="alert alert-warning py-2 px-3 small mb-2" role="alert">
                    <Icon class="icon me-1" IconType="@TablerIcons.Info_circle" />
                    Heads up — only the most recent <strong>@MaxRows.ToString("N0")</strong> events are loaded (the maximum shown at once).
                    To see older events, please filter by a <strong>From / To</strong> date range above.
                </div>
            }
            <Table @ref="table" Item="EventDto" Items="filteredEvents" PageSize="pageSize" Hover Responsive>
                @* Event Type filter sits in the table header, next to the built-in search box. *@
                <HeaderTemplate>
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label mb-0">Event Type</label>
                        <select class="form-select form-select-sm" style="width: auto;"
                                @bind="selectedEventType" @bind:after="ApplyFilters">
                            <option value="">All</option>
                            @foreach (var et in eventTypeOptions)
                            {
                                <option value="@et">@et</option>
                            }
                        </select>
                    </div>
                </HeaderTemplate>
                <ChildContent>
                    <Column Item="EventDto" Property="e => e.EventId" Title="Event Id" Width="50px" Sortable Visible="false" />
                    <Column Item="EventDto" Property="e => e.CardHolder" Title="User" Searchable Sortable />
                    <Column Item="EventDto" Property="e => e.CardNumber" Title="Card#" Searchable Sortable />
                    <Column Item="EventDto" Property="e => e.DoorName" Title="Door" Searchable Sortable />
                    <Column Item="EventDto" Property="e => e.ReaderId" Title="Reader" Searchable Sortable />
                    <Column Item="EventDto" Property="e => e.EventName" Title="Event" Searchable Sortable />
                    <Column Item="EventDto" Property="e => e.EventDate" Title="Time" Searchable Sortable />
                </ChildContent>
            </Table>
            @if (filteredEvents.Count == 0)
            {
                <div class="text-muted text-center py-4">No events found.</div>
            }
            <div class="text-muted small mt-2">
                <Icon class="icon icon-sm me-1" IconType="@TablerIcons.Info_circle" />
                Tip: use the <kbd>←</kbd> / <kbd>→</kbd> arrow keys to change pages.
            </div>
        }
    </CardBody>
</Card>

@code {
    private bool IsLoaded = false;
    private HttpClient client = new HttpClient();

    private List<EventDto> eventList = new();        // full set from the API (max 10000, recent first)
    private List<EventDto> filteredEvents = new();   // what the table shows after the filters below

    private List<string> eventTypeOptions = new();   // distinct EventName values for the dropdown
    private string? selectedEventType;               // null / "" = all event types
    private DateTime? fromDate;                       // applied range (drives the server query)
    private DateTime? toDate;
    private DateTime? pendingFrom;                    // staged in the inputs until Apply is clicked
    private DateTime? pendingTo;

    // True while rows are still streaming in after the first batch has painted (drives the header chip).
    private bool isLoadingMore;
    private static readonly JsonSerializerOptions JsonWebOptions = new(JsonSerializerDefaults.Web);

    // Paint the newest FirstPaintRows as soon as they arrive, then append the remainder,
    // repainting every RepaintEvery rows so the UI stays responsive during the background load.
    private const int FirstPaintRows = 1000;
    private const int RepaintEvery = 250;

    // Mirrors EventService.MaxRows: when the load returns this many rows the result was
    // capped, so we surface a hint telling the user to narrow the date range for older events.
    private const int MaxRows = 10000;

    // Rows per page, sized to the viewport height (see ComputePageSize). Bucketed so the
    // table doesn't reflow on every pixel of a window drag.
    private int pageSize = 10;
    private IJSObjectReference? viewportModule;
    private DotNetObjectReference<EventPage>? selfRef;

    // Bound to the table so the Left/Right arrow keys can drive its pager.
    private Table<EventDto>? table;

    protected override async Task OnInitializedAsync()
    {
        client = ClientFactory.CreateClient("WebAPI"); //this is where base setting locate
        await Refresh();

        Hub.NewEvent += OnNewEvent;
        await Hub.StartAsync(); // Last thing in line
    }

    private void OnNewEvent(EventDto evt)
    {
        // The bulk list is range-bounded by the server query; keep the pushed live
        // stream consistent by dropping events outside the currently applied range.
        if ((fromDate.HasValue && evt.EventDate < fromDate.Value) ||
            (toDate.HasValue && evt.EventDate > toDate.Value))
            return;

        // eventList is ordered newest-first. Insert the pushed event at its chronological
        // position rather than always at the top, since a controller can deliver buffered
        // (older) events after being offline.
        int index = eventList.FindIndex(e => e.EventDate < evt.EventDate);
        if (index < 0)
            eventList.Add(evt);
        else
            eventList.Insert(index, evt);

        RebuildEventTypeOptions();
        ApplyFilters();
        InvokeAsync(StateHasChanged);
    }

    // Size the page to the window on first render, then track resizes via JS interop.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        viewportModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/viewport.js");
        var height = await viewportModule.InvokeAsync<double>("getInnerHeight");
        ApplyPageSize(height);

        selfRef = DotNetObjectReference.Create(this);
        await viewportModule.InvokeVoidAsync("registerResize", selfRef);
        await viewportModule.InvokeVoidAsync("registerPageKeys", selfRef);
    }

    [JSInvokable]
    public void OnViewportResized(double height) => ApplyPageSize(height);

    // Left/Right arrow keys turn the table's pages (direction: -1 prev, +1 next).
    [JSInvokable]
    public async Task OnPageKey(int direction)
    {
        if (table is null) return;
        if (direction > 0)
            await table.NextPage();
        else
            await table.PreviousPage();
    }

    // Recompute rows-per-page and repaint only when the bucket actually changes.
    private void ApplyPageSize(double viewportHeight)
    {
        var next = ComputePageSize(viewportHeight);
        if (next == pageSize) return;
        pageSize = next;
        StateHasChanged();
    }

    // Bucket the viewport height into a few row counts. Bounds are rough: the page chrome
    // (app header, card header, search/pager) eats ~320px and each table row is ~40px.
    private static int ComputePageSize(double viewportHeight) => viewportHeight switch
    {
        < 700 => 5,
        < 900 => 10,
        < 1100 => 20,
        _ => 35
    };

    // Reload using whatever filter is currently active (Refresh button / initial load).
    private Task Refresh() => LoadEvents();

    // Streams events from the API, painting the newest FirstPaintRows as soon as they
    // arrive so the table is usable almost immediately, then appending the remainder in
    // the background (isLoadingMore drives the header chip). Newest-first, so the first
    // batch shown is the most recent events.
    private async Task LoadEvents()
    {
        IsLoaded = false;
        isLoadingMore = true;
        StateHasChanged();

        var query = BuildDateQuery();
        var loaded = new List<EventDto>();
        try
        {
            using var response = await client.GetAsync($"api/Event{query}", HttpCompletionOption.ResponseHeadersRead);
            response.EnsureSuccessStatusCode();
            using var stream = await response.Content.ReadAsStreamAsync();

            await foreach (var evt in JsonSerializer.DeserializeAsyncEnumerable<EventDto>(stream, JsonWebOptions))
            {
                if (evt is null) continue;
                loaded.Add(evt);

                if (!IsLoaded && loaded.Count >= FirstPaintRows)
                {
                    // First batch is in: bind it and reveal the table.
                    eventList = loaded;
                    RebuildEventTypeOptions();
                    ApplyFilters();
                    IsLoaded = true;
                    StateHasChanged();
                    await Task.Yield();
                }
                else if (IsLoaded && loaded.Count % RepaintEvery == 0)
                {
                    // Subsequent rows: refresh the visible set periodically without blocking.
                    RebuildEventTypeOptions();
                    ApplyFilters();
                    StateHasChanged();
                    await Task.Yield();
                }
            }
        }
        catch
        {
            // Fall through with whatever streamed in; the table still renders.
        }

        eventList = loaded;
        RebuildEventTypeOptions();
        ApplyFilters();
        IsLoaded = true;
        isLoadingMore = false;
    }

    // Builds the "?from=...&to=..." query string from the active date range (ISO, sortable).
    private string BuildDateQuery()
    {
        var parts = new List<string>();
        if (fromDate.HasValue)
            parts.Add($"from={Uri.EscapeDataString(fromDate.Value.ToString("s"))}");
        if (toDate.HasValue)
            parts.Add($"to={Uri.EscapeDataString(toDate.Value.ToString("s"))}");
        return parts.Count > 0 ? "?" + string.Join("&", parts) : string.Empty;
    }

    // Build the Event Type dropdown options from the distinct event names currently loaded.
    private void RebuildEventTypeOptions()
    {
        eventTypeOptions = eventList
            .Select(e => e.EventName)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Select(n => n!)
            .Distinct()
            .OrderBy(n => n)
            .ToList();
    }

    // Event Type is the only client-side refinement. The date range is enforced
    // server-side by BuildDateQuery, so eventList already holds only in-range rows.
    private void ApplyFilters()
    {
        IEnumerable<EventDto> q = eventList;

        if (!string.IsNullOrEmpty(selectedEventType))
            q = q.Where(e => e.EventName == selectedEventType);

        filteredEvents = q.ToList();
    }

    // Editing the inputs only stages the value; nothing hits the server until Apply.
    private void OnFromChanged(ChangeEventArgs e) => pendingFrom = ParseLocal(e.Value?.ToString());

    private void OnToChanged(ChangeEventArgs e) => pendingTo = ParseLocal(e.Value?.ToString());

    private static DateTime? ParseLocal(string? value)
        => DateTime.TryParse(value, out var dt) ? dt : null;

    // Commit the staged range and run the server-side query.
    private async Task ApplyDateRange()
    {
        fromDate = pendingFrom;
        toDate = pendingTo;
        await LoadEvents();
    }

    private async Task ClearFilters()
    {
        selectedEventType = null;
        fromDate = null;
        toDate = null;
        pendingFrom = null;
        pendingTo = null;
        await LoadEvents();   // reload from scratch with filters cleared
    }

    public async ValueTask DisposeAsync()
    {
        if (viewportModule is not null)
        {
            try
            {
                await viewportModule.InvokeVoidAsync("unregisterResize");
                await viewportModule.InvokeVoidAsync("unregisterPageKeys");
                await viewportModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit already gone */ }
        }
        selfRef?.Dispose();

        Hub.NewEvent -= OnNewEvent;
        await Hub.DisposeAsync();
    }
}
