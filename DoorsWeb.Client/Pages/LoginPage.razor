@page "/login"
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@using DoorsWeb.Shared.Auth
@using DoorsWeb.Shared.DTO
@using DoorsWeb.Shared.Models
@using DoorsWeb.Client.Auth
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject JwtAuthStateProvider AuthStateProvider

<div class="container container-tight py-5">
    <div class="text-center mb-4">
        <img src="img/fingerprint-badge.svg" alt="Doors Web" height="56" class="mb-2">
        <div class="text-uppercase text-secondary" style="font-size: .8rem; letter-spacing: .15em;">Progeny</div>
        <h1 class="h1 m-0 d-inline-flex align-items-center">
            Doors Web
            <span class="badge bg-red text-white ms-2">P4</span>
        </h1>
    </div>
    <div class="card card-md shadow-sm">
        <div class="card-body">
            @if (!requirePasswordChange)
            {
                <h2 class="h2 text-center mb-4">Sign in</h2>
                <EditForm Model="loginDto" OnValidSubmit="HandleLogin">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText class="form-control" @bind-Value="loginDto.Username" @bind-Value:after="FetchHint" placeholder="Enter username" />
                        <ValidationMessage For="@(() => loginDto.Username)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <div class="input-group input-group-flat">
                            <InputText type="@(showLoginPwd ? "text" : "password")" class="form-control" @bind-Value="loginDto.Password" placeholder="Password" />
                            <span class="input-group-text">
                                <a href="#" class="link-secondary" tabindex="-1" title="Show password"
                                   @onclick="() => showLoginPwd = !showLoginPwd" @onclick:preventDefault="true">
                                    <Icon class="icon" IconType="@(showLoginPwd ? TablerIcons.Eye_off : TablerIcons.Eye)" />
                                </a>
                            </span>
                        </div>
                        <ValidationMessage For="@(() => loginDto.Password)" />
                    </div>
                    @if (passwordHint is not null)
                    {
                        <div class="alert alert-info mb-3">
                            <div>First login: the default password is <strong>@passwordHint</strong>. You'll be asked to set a new one.</div>
                        </div>
                    }
                    @if (errorMessage is not null)
                    {
                        <div class="alert alert-danger mb-3">@errorMessage</div>
                    }
                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            Sign in
                        </button>
                    </div>
                </EditForm>
            }
            else
            {
                <h2 class="h2 text-center mb-4">Choose a new password</h2>
                <p class="text-secondary mb-4">Your password needs to be reset before you can continue. Set a new password to continue.</p>
                <EditForm Model="changeModel" OnValidSubmit="HandleChangePassword">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">New password</label>
                        <div class="input-group input-group-flat">
                            <InputText type="@(showNewPwd ? "text" : "password")" class="form-control" @bind-Value="changeModel.NewPassword" @bind-Value:event="oninput" placeholder="New password" />
                            <span class="input-group-text">
                                <a href="#" class="link-secondary" tabindex="-1" title="Show password"
                                   @onclick="() => showNewPwd = !showNewPwd" @onclick:preventDefault="true">
                                    <Icon class="icon" IconType="@(showNewPwd ? TablerIcons.Eye_off : TablerIcons.Eye)" />
                                </a>
                            </span>
                        </div>
                        <PasswordStrengthMeter Password="@changeModel.NewPassword" />
                        <ValidationMessage For="@(() => changeModel.NewPassword)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm new password</label>
                        <div class="input-group input-group-flat">
                            <InputText type="@(showConfirmPwd ? "text" : "password")" class="form-control" @bind-Value="changeModel.ConfirmPassword" placeholder="Re-enter new password" />
                            <span class="input-group-text">
                                <a href="#" class="link-secondary" tabindex="-1" title="Show password"
                                   @onclick="() => showConfirmPwd = !showConfirmPwd" @onclick:preventDefault="true">
                                    <Icon class="icon" IconType="@(showConfirmPwd ? TablerIcons.Eye_off : TablerIcons.Eye)" />
                                </a>
                            </span>
                        </div>
                        <ValidationMessage For="@(() => changeModel.ConfirmPassword)" />
                    </div>
                    @if (errorMessage is not null)
                    {
                        <div class="alert alert-danger mb-3">@errorMessage</div>
                    }
                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            Set password and continue
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private AdminLoginDto loginDto = new() { Username = "admin", Password = "" };
    private ChangePasswordModel changeModel = new();
    private string? errorMessage;
    private string? passwordHint;
    private bool isLoading;
    private bool requirePasswordChange;
    private bool showLoginPwd;
    private bool showNewPwd;
    private bool showConfirmPwd;

    private string RedirectTarget => string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            if (state.User.Identity?.IsAuthenticated == true)
            {
                Navigation.NavigateTo(RedirectTarget);
                return;
            }
        }

        await FetchHint();
    }

    private async Task FetchHint()
    {
        passwordHint = null;
        if (string.IsNullOrWhiteSpace(loginDto.Username))
            return;
        try
        {
            var client = ClientFactory.CreateClient("WebAPI");
            var hint = await client.GetFromJsonAsync<DefaultHint>(
                $"auth/default-hint/{Uri.EscapeDataString(loginDto.Username)}");
            passwordHint = hint?.Hint;
        }
        catch
        {
            passwordHint = null;
        }
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var client = ClientFactory.CreateClient("WebAPI");
            var response = await client.PostAsJsonAsync("auth/signin", loginDto);

            if (response.IsSuccessStatusCode)
            {
                var jwtPair = await response.Content.ReadFromJsonAsync<JwtPairResponse>();
                if (jwtPair?.AccessToken is not null)
                {
                    await StoreTokens(jwtPair);
                    if (jwtPair.MustChangePassword)
                    {
                        // Hold the user on the change-password form; the stored token
                        // authorizes the subsequent auth/change-password call.
                        requirePasswordChange = true;
                    }
                    else
                    {
                        AuthStateProvider.NotifyAuthStateChanged();
                        Navigation.NavigateTo(RedirectTarget);
                    }
                }
            }
            else
            {
                var problem = await response.Content.ReadFromJsonAsync<ClientProblemDetails>();
                errorMessage = problem?.Detail ?? "Invalid credentials.";
            }
        }
        catch
        {
            errorMessage = "Could not connect to the server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleChangePassword()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var client = ClientFactory.CreateClient("WebAPI");
            var response = await client.PostAsJsonAsync("auth/change-password",
                new ChangePasswordDto { NewPassword = changeModel.NewPassword });

            if (response.IsSuccessStatusCode)
            {
                var jwtPair = await response.Content.ReadFromJsonAsync<JwtPairResponse>();
                if (jwtPair?.AccessToken is not null)
                    await StoreTokens(jwtPair);

                AuthStateProvider.NotifyAuthStateChanged();
                Navigation.NavigateTo(RedirectTarget);
            }
            else
            {
                var problem = await response.Content.ReadFromJsonAsync<ClientProblemDetails>();
                errorMessage = problem?.Detail ?? "Could not change password.";
            }
        }
        catch
        {
            errorMessage = "Could not connect to the server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task StoreTokens(JwtPairResponse pair)
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "access_token", pair.AccessToken);
        await JS.InvokeVoidAsync("localStorage.setItem", "refresh_token", pair.RefreshToken);
    }

    private class ChangePasswordModel
    {
        [Required]
        [MinLength(PasswordPolicy.MinLength, ErrorMessage = "Password must be at least 12 characters.")]
        public string NewPassword { get; set; } = "";

        [Required]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }

    private record JwtPairResponse(
        string AccessToken,
        DateTimeOffset AccessTokenExpiresAt,
        string RefreshToken,
        DateTimeOffset RefreshTokenExpiresAt,
        bool MustChangePassword);

    private record DefaultHint(bool IsDefault, string? Hint);
}
