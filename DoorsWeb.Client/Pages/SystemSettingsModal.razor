@* System Settings dialog. Shown via ModalService.ShowAsync("System Settings", ...).
   Manages sites (list / add / rename / remove via the API's SitesController).
   Site changes persist immediately (each is its own API call), so OK and Cancel
   both simply close the dialog. *@

@using DoorsWeb.Client.Auth
@using DoorsWeb.Shared.DTO
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory ClientFactory
@inject AuthenticationStateProvider AuthState

<Card Size="CardSize.Default">
    <CardBody>
        <CardTitle>Sites</CardTitle>

        <div class="table-responsive border rounded mb-2" style="max-height: 240px; overflow-y: auto;">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Name</th>
                        <th style="width: 5rem;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (sites is null)
                    {
                        <tr><td colspan="2" class="text-muted text-center py-4">Loading…</td></tr>
                    }
                    else if (sites.Count == 0)
                    {
                        <tr><td colspan="2" class="text-muted text-center py-4">No sites found.</td></tr>
                    }
                    else
                    {
                        @foreach (var s in sites)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (editingSite == s.Site)
                                    {
                                        <input class="form-control form-control-sm" maxlength="30"
                                               @bind="editName" @bind:event="oninput" disabled="@busy" />
                                    }
                                    else
                                    {
                                        @s.Name
                                    }
                                </td>
                                <td class="text-end text-nowrap">
                                    @if (canWrite)
                                    {
                                        @if (editingSite == s.Site)
                                        {
                                            <Icon class="icon text-success me-2" style="cursor: pointer;" IconType="@TablerIcons.Check"
                                                  @onclick="() => SaveRename(s)" />
                                            <Icon class="icon text-muted" style="cursor: pointer;" IconType="@TablerIcons.X"
                                                  @onclick="CancelRename" />
                                        }
                                        else
                                        {
                                            <Icon class="icon text-primary me-2" style="cursor: pointer;" IconType="@TablerIcons.Pencil"
                                                  @onclick="() => BeginRename(s)" />
                                            @if (sites.Count > 1)
                                            {
                                                <Icon class="icon text-danger" style="cursor: pointer;" IconType="@TablerIcons.Trash"
                                                      @onclick="() => RemoveSite(s)" />
                                            }
                                            else
                                            {
                                                <Icon class="icon text-muted" style="opacity: .35; cursor: not-allowed;" IconType="@TablerIcons.Trash" />
                                            }
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="text-muted small mb-2">
            <Icon class="icon icon-sm me-1" IconType="@TablerIcons.Info_circle" />
            At least one site is required — the last remaining site can't be removed.
        </div>

        @if (canWrite)
        {
            <div class="row g-2 align-items-center">
                <div class="col">
                    <input class="form-control" placeholder="New site name" maxlength="30"
                           @bind="newSiteName" @bind:event="oninput" disabled="@busy" />
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-success" @onclick="AddSite"
                            disabled="@(busy || string.IsNullOrWhiteSpace(newSiteName))">
                        <Icon class="icon me-1" IconType="@TablerIcons.Plus" />Add Site
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0" role="alert">
                <Icon class="icon me-2" IconType="@TablerIcons.Eye" />
                You have read-only access to site settings. Adding, renaming and removing sites are disabled.
            </div>
        }
    </CardBody>
</Card>

@* Controller Communication: global protocol-polling settings (no connectors — IP only).
   Persisted to the settings JSON via api/SystemSettings; saved when the dialog's OK is clicked. *@
<h3 class="mt-3 mb-2">Controller Communication</h3>
<Card Size="CardSize.Default">
    <CardBody>
        <div class="mb-2 row align-items-center">
            <div class="col-lg-5 text-lg-end"><label class="form-label mb-0">Ping controllers every</label></div>
            <div class="col-auto" style="width: 6rem;">
                <input type="number" min="1" class="form-control text-center" disabled="@(!canWrite || busy)"
                       @bind="settings.ControllerCommunication.PingIntervalSeconds" />
            </div>
            <div class="col-auto"><span class="form-label mb-0">seconds</span></div>
        </div>
        <div class="mb-2 row align-items-center">
            <div class="col-lg-5 text-lg-end"><label class="form-label mb-0">Check for commands every</label></div>
            <div class="col-auto" style="width: 6rem;">
                <input type="number" min="1" class="form-control text-center" disabled="@(!canWrite || busy)"
                       @bind="settings.ControllerCommunication.CommandCheckIntervalSeconds" />
            </div>
            <div class="col-auto"><span class="form-label mb-0">seconds</span></div>
        </div>
        <div class="row align-items-center">
            <div class="col-lg-5 text-lg-end"><label class="form-label mb-0">Force a ping after</label></div>
            <div class="col-auto" style="width: 6rem;">
                <input type="number" min="1" class="form-control text-center" disabled="@(!canWrite || busy)"
                       @bind="settings.ControllerCommunication.ForcePingAfterCommands" />
            </div>
            <div class="col-auto"><span class="form-label mb-0">commands</span></div>
        </div>
    </CardBody>
</Card>

@* Custom Card Format (mirrors the legacy DoorsClient dialog). The fields use Blazor input
   components, which need an ambient EditContext — hence the wrapping EditForm. *@
<h3 class="mt-3 mb-2">Custom Card Format</h3>
<EditForm Model="cardFormat">
    <CustomCardFormatFields Format="cardFormat" />
</EditForm>

@if (status is not null)
{
    <div class="alert @(statusOk ? "alert-success" : "alert-danger") mb-0 mt-3" role="alert">
        @status
    </div>
}

<div class="d-flex justify-content-end gap-2 mt-3">
    <button type="button" class="btn btn-secondary" @onclick="Cancel" disabled="@busy">Cancel</button>
    <button type="button" class="btn btn-primary" @onclick="Save" disabled="@busy">
        @if (busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
        OK
    </button>
</div>

@code {

    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    private HttpClient client = null!;

    private List<SiteDto>? sites;
    private string? newSiteName;

    // Custom Card Format section. UI-only for now (no API/persistence yet — mirrors the
    // legacy dialog), so OK/Cancel don't save these values.
    private CustomCardFormatFields.CustomCardFormatModel cardFormat = new();

    // Global settings (controller communication). Loaded on init, saved on OK.
    private SystemSettings settings = new();

    // Inline rename state: the site currently being edited and its working name.
    private int? editingSite;
    private string? editName;

    private bool busy;
    private string? status;
    private bool statusOk;

    // Whether the signed-in user may mutate sites (Site Settings ReadWrite). Read-only users still
    // see the list. The API is the real boundary; this just hides the add/rename/remove controls.
    private bool canWrite;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        canWrite = state.User.CanWriteSiteSettings();

        client = ClientFactory.CreateClient("WebAPI");
        await LoadSites();
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        try
        {
            settings = await client.GetFromJsonAsync<SystemSettings>("api/SystemSettings") ?? new();
            settings.ControllerCommunication ??= new();
        }
        catch (Exception ex)
        {
            settings = new();
            SetStatus(false, $"Could not load settings: {ex.Message}");
        }
    }

    private async Task LoadSites()
    {
        try
        {
            sites = await client.GetFromJsonAsync<List<SiteDto>>("api/Sites") ?? new();
        }
        catch (Exception ex)
        {
            sites = new();
            SetStatus(false, $"Could not load sites: {ex.Message}");
        }
    }

    private async Task AddSite()
    {
        var name = newSiteName?.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;

        busy = true;
        status = null;
        try
        {
            var response = await client.PostAsJsonAsync("api/Sites", new SiteDto { Name = name });
            if (response.IsSuccessStatusCode)
            {
                newSiteName = null;
                await LoadSites();
            }
            else
            {
                SetStatus(false, await ReadError(response));
            }
        }
        catch (Exception ex)
        {
            SetStatus(false, $"Add site failed: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private void BeginRename(SiteDto site)
    {
        editingSite = site.Site;
        editName = site.Name;
        status = null;
    }

    private void CancelRename()
    {
        editingSite = null;
        editName = null;
    }

    private async Task SaveRename(SiteDto site)
    {
        var name = editName?.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;

        // No-op if the name is unchanged.
        if (string.Equals(name, site.Name, StringComparison.Ordinal))
        {
            CancelRename();
            return;
        }

        busy = true;
        status = null;
        try
        {
            var response = await client.PutAsJsonAsync($"api/Sites/{site.Site}", new SiteDto { Name = name });
            if (response.IsSuccessStatusCode)
            {
                CancelRename();
                await LoadSites();
            }
            else
            {
                SetStatus(false, await ReadError(response));
            }
        }
        catch (Exception ex)
        {
            SetStatus(false, $"Rename site failed: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task RemoveSite(SiteDto site)
    {
        var confirmed = await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = $"Delete site \"{site.Name}\"?",
            SubText = "This action cannot be undone!",
            IconType = TablerIcons.Alert_triangle,
            StatusColor = TablerColor.Danger
        });
        if (!confirmed) return;

        busy = true;
        status = null;
        try
        {
            var response = await client.DeleteAsync($"api/Sites/{site.Site}");
            if (response.IsSuccessStatusCode)
            {
                await LoadSites();
            }
            else
            {
                SetStatus(false, await ReadError(response));
            }
        }
        catch (Exception ex)
        {
            SetStatus(false, $"Delete site failed: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    // Sites persist immediately as they are edited; OK additionally saves the global settings
    // (controller communication). On failure the dialog stays open so the error is visible.
    private async Task Save()
    {
        if (canWrite)
        {
            busy = true;
            status = null;
            try
            {
                var response = await client.PutAsJsonAsync("api/SystemSettings", settings);
                if (!response.IsSuccessStatusCode)
                {
                    SetStatus(false, await ReadError(response));
                    return;
                }
            }
            catch (Exception ex)
            {
                SetStatus(false, $"Could not save settings: {ex.Message}");
                return;
            }
            finally
            {
                busy = false;
            }
        }

        ModalService.Close(ModalResult.Ok());
    }

    private void Cancel()
    {
        ModalService.Close(ModalResult.Cancel());
    }

    private static async Task<string> ReadError(HttpResponseMessage response)
    {
        try
        {
            var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
            if (!string.IsNullOrWhiteSpace(problem?.Detail)) return problem!.Detail!;
        }
        catch { /* fall through */ }
        return $"Request failed ({(int)response.StatusCode}).";
    }

    private void SetStatus(bool ok, string message)
    {
        statusOk = ok;
        status = message;
    }

    private class ProblemDetails
    {
        public string? Title { get; set; }
        public string? Detail { get; set; }
        public int? Status { get; set; }
    }
}
