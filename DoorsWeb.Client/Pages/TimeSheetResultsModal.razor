@* Read-only hours-worked report produced by running a time sheet definition.
   Opened from TimeSheetSettingsModal after the server runs the legacy sp_TimeSheet algorithm. *@

@using DoorsWeb.Shared.DTO

<div class="mb-2 d-flex align-items-center justify-content-between">
    <div class="text-muted small">
        <Icon class="icon icon-sm me-1" IconType="@TablerIcons.Report_analytics" />
        @Rows.Count row@(Rows.Count == 1 ? "" : "s")
    </div>
</div>

@if (Rows.Count == 0)
{
    <div class="text-muted text-center py-4">No transactions matched these settings.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-vcenter card-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Card ID</th>
                    <th>First name</th>
                    <th>Last name</th>
                    <th class="text-end">In</th>
                    <th class="text-end">Out</th>
                    <th class="text-end">Hours worked</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Rows)
                {
                    <tr>
                        <td>@r.EventDate</td>
                        <td>@r.CardId</td>
                        <td>@r.FirstName</td>
                        <td>@r.LastName</td>
                        <td class="text-end">@r.TimeFrom</td>
                        <td class="text-end">@r.TimeTo</td>
                        <td class="text-end">@r.HoursWorked</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="d-flex justify-content-end gap-2 mt-3">
    <button type="button" class="btn btn-secondary" @onclick="Close">Close</button>
</div>

@code {
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    /// <summary>The report rows to display.</summary>
    [Parameter] public List<TimeSheetReportRowDto> Rows { get; set; } = new();

    /// <summary>The time sheet's name (shown by the caller in the modal title; kept for context).</summary>
    [Parameter] public string Heading { get; set; } = "Time sheet";

    private void Close() => ModalService.Close(ModalResult.Ok());
}
