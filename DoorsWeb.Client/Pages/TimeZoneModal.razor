@* Time Zone dialog (mirrors LegacyDoorsClient "Time Zones - New time zone").
   Shown via ModalService.ShowAsync("Time Zones - New time zone", ...).
   OK + Cancel only (Apply ignored). The green "Auto-update is ON" banner is intentionally omitted. *@

<TablerForm Model="@timeZone" OnValidSubmit="OK">
    <Card Size="CardSize.Default">
        <CardBody>
            <CardTitle>Time Zone</CardTitle>
            <div class="mb-2 row align-items-center">
                <div class="col-lg-3 text-end">
                    <label class="form-label mb-0">Name</label>
                </div>
                <div class="col-lg-9">
                    <InputText class="form-control" @bind-Value="timeZone.Name"></InputText>
                </div>
            </div>
            <div class="mb-1 row align-items-center">
                <div class="col-lg-3 text-end">
                    <label class="form-label mb-0">Calendar</label>
                </div>
                <div class="col-lg-8">
                    <InputSelect class="form-select" @bind-Value="timeZone.Calendar">
                        <option value="(none)">(none)</option>
                    </InputSelect>
                </div>
                <div class="col-lg-1">
                    <button type="button" class="btn btn-outline-secondary w-100" @onclick="EditCalendars">...</button>
                </div>
            </div>
        </CardBody>
    </Card>

    <Card Size="CardSize.Default">
        <CardBody>
            <CardTitle>Elements</CardTitle>
            <p class="mb-1">Time zones are split into elements. Each element has a start time and end time and can be applied to specific days of the week.</p>
            <p class="mb-2">Click "Add.." to create a new element.</p>

            <div class="table-responsive border rounded mb-2" style="max-height: 260px; overflow-y: auto;">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Start</th>
                            <th>End</th>
                            <th>Mon</th>
                            <th>Tues</th>
                            <th>Wed</th>
                            <th>Thu</th>
                            <th>Fri</th>
                            <th>Sat</th>
                            <th>Sun</th>
                            <th>Calendar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (timeZone.Elements.Count == 0)
                        {
                            <tr><td colspan="10" class="text-muted text-center py-4">No elements. Click "Add..." to create one.</td></tr>
                        }
                        else
                        {
                            @foreach (var el in timeZone.Elements)
                            {
                                <tr class="@(el == selected ? "table-active" : null)" @onclick="() => selected = el">
                                    <td>@el.Start</td>
                                    <td>@el.End</td>
                                    <td>@(el.Mon ? "X" : "")</td>
                                    <td>@(el.Tues ? "X" : "")</td>
                                    <td>@(el.Wed ? "X" : "")</td>
                                    <td>@(el.Thu ? "X" : "")</td>
                                    <td>@(el.Fri ? "X" : "")</td>
                                    <td>@(el.Sat ? "X" : "")</td>
                                    <td>@(el.Sun ? "X" : "")</td>
                                    <td>@el.Calendar</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" @onclick="AddElement">Add...</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="RemoveElement" disabled="@(selected is null)">Remove</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="ChangeElement" disabled="@(selected is null)">Change...</button>
            </div>
        </CardBody>
    </Card>

    @if (status is not null)
    {
        <div class="alert alert-danger py-2 px-3 small mt-3 mb-0" role="alert">@status</div>
    }

    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-secondary" @onclick="Cancel" disabled="@busy">Cancel</button>
        <button type="submit" class="btn btn-primary" disabled="@busy">OK</button>
    </div>
</TablerForm>

@code {

    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;
    [Inject] IHttpClientFactory ClientFactory { get; set; } = null!;

    /// <summary>Existing time zone's number; null when creating a new one.</summary>
    [Parameter] public int? TimeZoneId { get; set; }

    /// <summary>Owning site (required when creating).</summary>
    [Parameter] public int SiteId { get; set; }

    private TimeZoneModel timeZone = new();
    private TimeZoneElement? selected;
    private bool busy;
    private string? status;

    protected override async Task OnInitializedAsync()
    {
        if (TimeZoneId is not int tz) return;

        // Editing: pull the header name and element rows to seed the form.
        try
        {
            var client = ClientFactory.CreateClient("WebAPI");
            var dto = await client.GetFromJsonAsync<TimeZoneSaveDto>($"api/TimeZoneHeader/{SiteId}/{tz}/full");
            if (dto is not null)
            {
                timeZone.Name = dto.Name;
                timeZone.Elements = dto.Elements.Select(FromDto).ToList();
            }
        }
        catch
        {
            // Leave the form empty; the user can still re-enter values.
        }
    }

    private async Task OK(EditContext context)
    {
        busy = true;
        status = null;
        try
        {
            var dto = new TimeZoneSaveDto
            {
                TimeZone = TimeZoneId,
                Site = SiteId,
                Name = timeZone.Name,
                Elements = timeZone.Elements.Select(ToDto).ToList(),
            };

            var client = ClientFactory.CreateClient("WebAPI");
            var response = await client.PostAsJsonAsync("api/TimeZoneHeader/save", dto);
            if (response.IsSuccessStatusCode)
            {
                ModalService.Close(ModalResult.Ok());
                return;
            }

            status = $"Save failed ({(int)response.StatusCode}). {await response.Content.ReadAsStringAsync()}";
        }
        catch (Exception ex)
        {
            status = $"Save failed: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }

    private void Cancel()
    {
        ModalService.Close(ModalResult.Cancel());
    }

    private void EditCalendars()
    {
        // Placeholder: open the calendar editor (no dialog wired yet).
    }

    private async Task AddElement()
    {
        var result = await ShowElementEditor(new TimeZoneElementModal.TimeZoneElementModel());
        if (result is not null)
        {
            var el = FromEditor(result);
            timeZone.Elements.Add(el);
            selected = el;
        }
    }

    private void RemoveElement()
    {
        if (selected is not null)
        {
            timeZone.Elements.Remove(selected);
            selected = null;
        }
    }

    private async Task ChangeElement()
    {
        if (selected is null) return;

        var result = await ShowElementEditor(ToEditor(selected));
        if (result is not null)
        {
            ApplyEditor(selected, result);
        }
    }

    private async Task<TimeZoneElementModal.TimeZoneElementModel?> ShowElementEditor(TimeZoneElementModal.TimeZoneElementModel seed)
    {
        var component = new RenderComponent<TimeZoneElementModal>().Set(e => e.Element, seed);
        var result = await ModalService.ShowAsync("Time Zone Element", component, new ModalOptions
        {
            Size = ModalSize.Large,
            ShowHeader = true,
            Scrollable = true,
        });
        return result.Cancelled ? null : result.Data as TimeZoneElementModal.TimeZoneElementModel;
    }

    // ---- Mapping between the editor view-model, the table row, and the wire DTO ----

    private static TimeZoneElement FromEditor(TimeZoneElementModal.TimeZoneElementModel m) => new()
    {
        Start = m.From.ToString("HH:mm"),
        End = m.To.ToString("HH:mm"),
        Mon = m.Monday,
        Tues = m.Tuesday,
        Wed = m.Wednesday,
        Thu = m.Thursday,
        Fri = m.Friday,
        Sat = m.Saturday,
        Sun = m.Sunday,
        Calendar = m.ExcludingDays,
    };

    private static void ApplyEditor(TimeZoneElement el, TimeZoneElementModal.TimeZoneElementModel m)
    {
        el.Start = m.From.ToString("HH:mm");
        el.End = m.To.ToString("HH:mm");
        el.Mon = m.Monday;
        el.Tues = m.Tuesday;
        el.Wed = m.Wednesday;
        el.Thu = m.Thursday;
        el.Fri = m.Friday;
        el.Sat = m.Saturday;
        el.Sun = m.Sunday;
        el.Calendar = m.ExcludingDays;
    }

    private static TimeZoneElementModal.TimeZoneElementModel ToEditor(TimeZoneElement el) => new()
    {
        From = ParseTime(el.Start, new TimeOnly(9, 0)),
        To = ParseTime(el.End, new TimeOnly(17, 0)),
        ExcludingDays = string.IsNullOrEmpty(el.Calendar) ? "Level default" : el.Calendar,
        Monday = el.Mon,
        Tuesday = el.Tues,
        Wednesday = el.Wed,
        Thursday = el.Thu,
        Friday = el.Fri,
        Saturday = el.Sat,
        Sunday = el.Sun,
    };

    private static TimeZoneElementDto ToDto(TimeZoneElement el) => new()
    {
        StartTime = el.Start,
        EndTime = el.End,
        Mon = el.Mon,
        Tue = el.Tues,
        Wed = el.Wed,
        Thu = el.Thu,
        Fri = el.Fri,
        Sat = el.Sat,
        Sun = el.Sun,
        DefaultCalendar = el.Calendar == "Level default",
    };

    private static TimeZoneElement FromDto(TimeZoneElementDto d) => new()
    {
        Start = d.StartTime,
        End = d.EndTime,
        Mon = d.Mon,
        Tues = d.Tue,
        Wed = d.Wed,
        Thu = d.Thu,
        Fri = d.Fri,
        Sat = d.Sat,
        Sun = d.Sun,
        Calendar = d.DefaultCalendar ? "Level default" : "(none)",
    };

    private static TimeOnly ParseTime(string? value, TimeOnly fallback)
        => TimeOnly.TryParse(value, out var t) ? t : fallback;

    public class TimeZoneModel
    {
        public string? Name { get; set; }
        public string Calendar { get; set; } = "(none)";
        public List<TimeZoneElement> Elements { get; set; } = new();
    }

    public class TimeZoneElement
    {
        public string? Start { get; set; }
        public string? End { get; set; }
        public bool Mon { get; set; }
        public bool Tues { get; set; }
        public bool Wed { get; set; }
        public bool Thu { get; set; }
        public bool Fri { get; set; }
        public bool Sat { get; set; }
        public bool Sun { get; set; }
        public string? Calendar { get; set; }
    }
}
