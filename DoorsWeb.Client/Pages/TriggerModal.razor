@* Trigger dialog (mirrors LegacyDoorsClient "Triggers - New Trigger").
   Shown via ModalService.ShowAsync("Triggers - New Trigger", ...).
   Two tabs: General / Actions. OK + Cancel only (Apply ignored). *@

<TablerForm Model="@trigger" OnValidSubmit="OK">
    <Tabs>
        @* ============================= GENERAL ============================= *@
        <Tab Title="General">
            <Card Size="CardSize.Default">
                <CardBody>
                    <CardTitle>Name</CardTitle>
                    <InputText class="form-control" @bind-Value="trigger.Name"></InputText>
                </CardBody>
            </Card>

            <Card Size="CardSize.Default">
                <CardBody>
                    <CardTitle>Where - select the doors you want to include</CardTitle>
                    <div class="row">
                        <div class="col-lg-8">
                            <div class="border rounded px-3 py-2" style="height: 160px; overflow-y: auto;">
                                @{
                                    var doors = trigger.ShowSelectedDoorsOnly ? trigger.Doors.Where(d => d.Selected).ToList() : trigger.Doors;
                                }
                                @if (doors.Count == 0)
                                {
                                    <div class="text-muted text-center py-4">No doors available.</div>
                                }
                                else
                                {
                                    @foreach (var door in doors)
                                    {
                                        <label class="form-check mb-1">
                                            <InputCheckbox class="form-check-input" @bind-Value="door.Selected"></InputCheckbox>
                                            <span class="form-check-label">@door.Name</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                        <div class="col-lg-4 d-flex flex-column gap-2">
                            <button type="button" class="btn btn-outline-secondary" @onclick="SelectAllDoors">Select All</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ClearAllDoors">Clear All</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="AddNewDoor">Add New...</button>
                        </div>
                    </div>
                    <label class="form-check mb-0 mt-2">
                        <InputCheckbox class="form-check-input" @bind-Value="trigger.ShowSelectedDoorsOnly"></InputCheckbox>
                        <span class="form-check-label">Show selected doors only</span>
                    </label>
                </CardBody>
            </Card>

            <Card Size="CardSize.Default">
                <CardBody>
                    <CardTitle>What - select the events you want to include</CardTitle>
                    <div class="row">
                        <div class="col-lg-8">
                            <div class="border rounded px-3 py-2" style="height: 160px; overflow-y: auto;">
                                @{
                                    var events = trigger.ShowSelectedEventsOnly ? trigger.Events.Where(e => e.Selected).ToList() : trigger.Events;
                                }
                                @if (events.Count == 0)
                                {
                                    <div class="text-muted text-center py-4">No events available.</div>
                                }
                                else
                                {
                                    @foreach (var ev in events)
                                    {
                                        <label class="form-check mb-1">
                                            <InputCheckbox class="form-check-input" @bind-Value="ev.Selected"></InputCheckbox>
                                            <span class="form-check-label">@ev.Name</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                        <div class="col-lg-4 d-flex flex-column gap-2">
                            <button type="button" class="btn btn-outline-secondary" @onclick="SelectAllEvents">Select All</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ClearAllEvents">Clear All</button>
                        </div>
                    </div>
                    <label class="form-check mb-0 mt-2">
                        <InputCheckbox class="form-check-input" @bind-Value="trigger.ShowSelectedEventsOnly"></InputCheckbox>
                        <span class="form-check-label">Show selected events only</span>
                    </label>
                </CardBody>
            </Card>

            <Card Size="CardSize.Default">
                <CardBody>
                    <CardTitle>
                        <label class="form-check mb-0">
                            <InputCheckbox class="form-check-input" @bind-Value="trigger.ShowAlarmMessage"></InputCheckbox>
                            <span class="form-check-label">Show alarm message</span>
                        </label>
                    </CardTitle>
                    <InputTextArea class="form-control" rows="4" @bind-Value="trigger.AlarmMessage" disabled="@(!trigger.ShowAlarmMessage)"></InputTextArea>
                </CardBody>
            </Card>
        </Tab>

        @* ============================= ACTIONS ============================= *@
        <Tab Title="Actions">
            <Card Size="CardSize.Default">
                <CardBody>
                    <label class="form-check mb-3">
                        <InputCheckbox class="form-check-input" @bind-Value="trigger.SuppressDuplicateAlarms"></InputCheckbox>
                        <span class="form-check-label">Suppress duplicate alarms</span>
                    </label>

                    <Card Size="CardSize.Default">
                        <CardBody>
                            <CardTitle>
                                <label class="form-check mb-0">
                                    <InputCheckbox class="form-check-input" @bind-Value="trigger.TriggerRelayB"></InputCheckbox>
                                    <span class="form-check-label">Trigger Relay B</span>
                                </label>
                            </CardTitle>

                            <div class="mb-2 row align-items-center">
                                <div class="col-lg-3 text-end">
                                    <label class="form-label mb-0">Door</label>
                                </div>
                                <div class="col-lg-7">
                                    <InputSelect class="form-select" @bind-Value="trigger.RelayDoor" disabled="@(!trigger.TriggerRelayB)">
                                        <option value="">(none)</option>
                                        @foreach (var door in trigger.Doors)
                                        {
                                            <option value="@door.Code">@door.Name</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-lg-2">
                                    <button type="button" class="btn btn-outline-secondary w-100" @onclick="EditDoors" disabled="@(!trigger.TriggerRelayB)">...</button>
                                </div>
                            </div>

                            <div class="mb-2 row align-items-center">
                                <div class="col-lg-3 text-end">
                                    <label class="form-label mb-0">Action</label>
                                </div>
                                <div class="col-lg-7">
                                    <InputSelect class="form-select" @bind-Value="trigger.RelayAction" disabled="@(!trigger.TriggerRelayB)">
                                        <option value="">(none)</option>
                                        <option value="Open">Open</option>
                                        <option value="Close">Close</option>
                                    </InputSelect>
                                </div>
                            </div>

                            <div class="mb-1 row align-items-center">
                                <div class="col-lg-3"></div>
                                <div class="col-lg-4">
                                    <label class="form-check mb-0">
                                        <InputCheckbox class="form-check-input" @bind-Value="trigger.ResetAfter" disabled="@(!trigger.TriggerRelayB)"></InputCheckbox>
                                        <span class="form-check-label">Reset after</span>
                                    </label>
                                </div>
                                <div class="col-lg-3">
                                    <InputNumber class="form-control" @bind-Value="trigger.ResetAfterSeconds" disabled="@(!trigger.TriggerRelayB || !trigger.ResetAfter)"></InputNumber>
                                </div>
                                <div class="col-lg-2">
                                    <label class="form-label mb-0">seconds</label>
                                </div>
                            </div>
                        </CardBody>
                    </Card>
                </CardBody>
            </Card>
        </Tab>
    </Tabs>

    @if (status is not null)
    {
        <div class="alert alert-danger py-2 px-3 small mt-3 mb-0" role="alert">@status</div>
    }

    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-secondary" @onclick="Cancel" disabled="@busy">Cancel</button>
        <button type="submit" class="btn btn-primary" disabled="@busy">OK</button>
    </div>
</TablerForm>

@code {

    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;
    [Inject] IHttpClientFactory ClientFactory { get; set; } = null!;

    // Door trigger.
    private const int TriggerTypeDoor = 1;

    /// <summary>Existing trigger's code; null when creating a new one.</summary>
    [Parameter] public int? Code { get; set; }

    /// <summary>Owning site (required when creating).</summary>
    [Parameter] public int SiteId { get; set; }

    private TriggerModel trigger = new();
    private bool busy;
    private string? status;

    protected override async Task OnInitializedAsync()
    {
        // Always pull the site's door list; selection + header are seeded when editing.
        try
        {
            var client = ClientFactory.CreateClient("WebAPI");
            var url = $"api/TriggersHeader/edit/{SiteId}/{TriggerTypeDoor}";
            if (Code is int c) url += $"?code={c}";

            var dto = await client.GetFromJsonAsync<TriggerSaveDto>(url);
            if (dto is not null)
            {
                trigger.Name = dto.Name ?? trigger.Name;
                trigger.ShowAlarmMessage = dto.ShowAlarm;
                trigger.AlarmMessage = dto.AlarmText;
                trigger.SuppressDuplicateAlarms = dto.SuppressDuplicates;
                trigger.TriggerRelayB = dto.TriggerRelayB;
                trigger.RelayDoor = dto.RelayBdoor > 0 ? dto.RelayBdoor.ToString() : "";
                trigger.RelayAction = dto.TriggerRelayB ? (dto.OpenRelayB ? "Open" : "Close") : "";
                trigger.ResetAfter = dto.ResetRelayB;
                trigger.ResetAfterSeconds = dto.ResetRelayBperiod;
                trigger.Doors = dto.Sources.Select(s => new DoorItem
                {
                    Code = s.Code,
                    Name = s.Name,
                    Selected = s.Selected,
                }).ToList();
            }
        }
        catch
        {
            // Leave the form empty; the user can still enter a name.
        }
    }

    private async Task OK(EditContext context)
    {
        busy = true;
        status = null;
        try
        {
            var dto = new TriggerSaveDto
            {
                Code = Code,
                Site = SiteId,
                Name = trigger.Name,
                TriggerType = TriggerTypeDoor,
                ShowAlarm = trigger.ShowAlarmMessage,
                AlarmText = trigger.AlarmMessage,
                SuppressDuplicates = trigger.SuppressDuplicateAlarms,
                TriggerRelayB = trigger.TriggerRelayB,
                RelayBdoor = int.TryParse(trigger.RelayDoor, out var relayDoor) ? relayDoor : 0,
                OpenRelayB = trigger.RelayAction == "Open",
                ResetRelayB = trigger.ResetAfter,
                ResetRelayBperiod = trigger.ResetAfterSeconds ?? 0,
                Sources = trigger.Doors.Select(d => new TriggerSourceDto
                {
                    Code = d.Code,
                    Selected = d.Selected,
                }).ToList(),
            };

            var client = ClientFactory.CreateClient("WebAPI");
            var response = await client.PostAsJsonAsync("api/TriggersHeader/save", dto);
            if (response.IsSuccessStatusCode)
            {
                ModalService.Close(ModalResult.Ok());
                return;
            }

            status = $"Save failed ({(int)response.StatusCode}). {await response.Content.ReadAsStringAsync()}";
        }
        catch (Exception ex)
        {
            status = $"Save failed: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }

    private void Cancel()
    {
        ModalService.Close(ModalResult.Cancel());
    }

    private void SelectAllDoors() { foreach (var d in trigger.Doors) d.Selected = true; }
    private void ClearAllDoors() { foreach (var d in trigger.Doors) d.Selected = false; }
    private void AddNewDoor()
    {
        // Placeholder: open the door editor to create a new door (no dialog wired yet).
    }

    private void SelectAllEvents() { foreach (var e in trigger.Events) e.Selected = true; }
    private void ClearAllEvents() { foreach (var e in trigger.Events) e.Selected = false; }

    private void EditDoors()
    {
        // Placeholder: open the door chooser (no dialog wired yet).
    }

    public class TriggerModel
    {
        public string? Name { get; set; }

        public List<DoorItem> Doors { get; set; } = new();
        public bool ShowSelectedDoorsOnly { get; set; } = false;

        public List<EventItem> Events { get; set; } = DefaultEvents();
        public bool ShowSelectedEventsOnly { get; set; } = false;

        public bool ShowAlarmMessage { get; set; } = false;
        public string? AlarmMessage { get; set; }

        // Actions tab
        public bool SuppressDuplicateAlarms { get; set; } = false;
        public bool TriggerRelayB { get; set; } = false;
        public string? RelayDoor { get; set; }
        public string? RelayAction { get; set; }
        public bool ResetAfter { get; set; } = false;
        public int? ResetAfterSeconds { get; set; }

        private static List<EventItem> DefaultEvents() => new()
        {
            new EventItem { Name = "Valid Identity" },
            new EventItem { Name = "Invalid Identity" },
            new EventItem { Name = "Hacker Alarm" },
            new EventItem { Name = "PC Release" },
            new EventItem { Name = "Duress Alarm" },
            new EventItem { Name = "Door Forced" },
        };
    }

    public class DoorItem
    {
        public int Code { get; set; }
        public bool Selected { get; set; }
        public string? Name { get; set; }
    }

    public class EventItem
    {
        public bool Selected { get; set; }
        public string? Name { get; set; }
    }
}
