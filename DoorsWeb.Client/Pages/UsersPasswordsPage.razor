@page "/userspasswords"
@using DoorsWeb.Shared.Entities
@inject IHttpClientFactory ClientFactory


<Card>
    <CardHeader>
        <CardTitle>
            <Icon class="icon me-2" IconType="@TablerIcons.User_star" />Users and Passwords
        </CardTitle>
    </CardHeader>
    <CardBody>
        @if (!IsLoaded)
        {
            <Progress Color="TablerColor.Blue" Indeterminate />
        }
        else
        {
            <Table Item="Users" Items="userList" PageSize="10" AddItemFactory="AddItem"
                   OnItemAdded="OnItemAdd" OnItemEdited="OnItemEdit" OnItemDeleted="OnItemDelete"
                   Hover Responsive EditMode=TableEditMode.Inline>
                <ChildContent>
                    <Column Item="Users" Property="e => e.Code" Title="User Id" Width="50px" Sortable Visible="false">
                        <EditorTemplate>
                            @(context.Code == 0 ? context.Code : "")
                            <InputNumber class="form-control" @bind-value="@context.Code" Hidden />
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Property="e => e.Description" Title="Name" Searchable Sortable>
                        <EditorTemplate>
                            <InputText class="form-control" @bind-value="@context.Description" DisplayName="name" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Property="e => e.Password" Title="Pass">
                        <Template>
                            ●●●●●●●●
                        </Template>
                        <EditorTemplate>
                            @* Native input bound on oninput so the strength meter updates live as you type. *@
                            <div class="input-group input-group-flat">
                                <input type="@(showRowPwd ? "text" : "password")" class="form-control"
                                       value="@context.Password" aria-label="password"
                                       @oninput="e => context.Password = e.Value?.ToString() ?? string.Empty" />
                                <span class="input-group-text">
                                    <a href="#" class="link-secondary" tabindex="-1" title="Show password"
                                       @onclick="() => showRowPwd = !showRowPwd" @onclick:preventDefault="true">
                                        <Icon class="icon" IconType="@(showRowPwd ? TablerIcons.Eye_off : TablerIcons.Eye)" />
                                    </a>
                                </span>
                            </div>
                            <PasswordStrengthMeter Password="@context.Password" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Property="e => e.Administrator" Title="Admin" Width="50px" Sortable>
                        <Template>
                            @if (context.Administrator)
                            {
                                <Icon class="icon" IconType="@TablerIcons.Check" />
                            }
                            else
                            {
                                <Icon class="icon" IconType="@TablerIcons.X" />
                            }
                        </Template>
                        <EditorTemplate>
                            <Checkbox @bind-value="@context.Administrator" />
                        </EditorTemplate>
                    </Column>
                </ChildContent>
            </Table>
            @if (userList.Count == 0)
            {
                <div class="text-muted text-center py-4">No users found.</div>
            }
        }
    </CardBody>
</Card>



@code {
    [Inject] TabBlazor.Services.TablerService TablerService { get; set; } = null!;
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    private bool IsLoaded = false;
    private HttpClient client = new HttpClient();
    private List<Users> userList = new List<Users>();
    private bool showRowPwd;   // toggles the inline password editor between masked/clear

    // Snapshot of each user's saved password (by Code) so we only enforce strength when the
    // password actually changes - editing the name/admin flag of a legacy weak account is allowed.
    private Dictionary<int, string> originalPasswords = new();

    protected override async Task OnInitializedAsync()
    {
        client = ClientFactory.CreateClient("WebAPI");
        userList = await client.GetFromJsonAsync<List<Users>>("api/Users") ?? [];
        SnapshotPasswords();
        IsLoaded = true;
    }

    private void SnapshotPasswords()
        => originalPasswords = userList.ToDictionary(u => u.Code, u => u.Password);

    private Task<Users> AddItem()
    {
        // this function feeds default value
        return Task.FromResult(new Users { Code = 0, Description = "user", Password = "pass", Administrator = false });
    }

    private async Task OnItemAdd(Users user)
    {
        // New accounts must meet the strength bar; otherwise drop the unsaved row.
        if (!PasswordStrength.MeetsMinimum(user.Password))
        {
            userList.Remove(user);
            await ShowWeakPasswordDialog();
            return;
        }

        var result = await client.PostAsJsonAsync<Users>("api/Users/", user);
        if (result.IsSuccessStatusCode) await UpdateList();
        else {
            userList.Remove(user);
            await ShowErrorDialog(result);
        }
    }

    private async Task OnItemEdit(Users user)
    {
        // Only enforce strength when the password was actually changed in this edit.
        bool passwordChanged = !(originalPasswords.TryGetValue(user.Code, out var orig) && orig == user.Password);
        if (passwordChanged && !PasswordStrength.MeetsMinimum(user.Password))
        {
            await ShowWeakPasswordDialog();
            await UpdateList();   // discard the unsaved weak change by reloading server state
            return;
        }

        var result = await client.PutAsJsonAsync<Users>("api/Users/" + user.Code, user);
        if (!result.IsSuccessStatusCode) await ShowErrorDialog(result);
        else SnapshotPasswords();   // the saved password is the new baseline
    }

    private async Task OnItemDelete(Users user)
    {
        userList = await client.DeleteFromJsonAsync<List<Users>>("api/Users/" + user.Code) ?? [];
        SnapshotPasswords();
    }

    private async Task UpdateList()
    {
        userList = await client.GetFromJsonAsync<List<Users>>("api/Users") ?? [];
        SnapshotPasswords();
    }

    private async Task ShowWeakPasswordDialog()
    {
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = "Password too weak",
            SubText = "Use at least 8 characters mixing letters, numbers or symbols (strength 'Fair' or better) before saving.",
            IconType = TablerIcons.Lock,
            CancelText = "",
            StatusColor = TablerColor.Warning
        });
    }

    private async Task ShowErrorDialog(HttpResponseMessage result)
    {
        ClientProblemDetails errjson;
        try
        {
            errjson = await result.Content.ReadFromJsonAsync<ClientProblemDetails>() ??
                new ClientProblemDetails { Status = 500, Title = "Error Returned Null!", Detail = "An unexpected error occurred." };
        }
        catch
        {
            errjson = new ClientProblemDetails { Status = 500, Title = "Unable to Read Error!", Detail = "Failed to read error response." };
        }
        if (errjson.Status == 500) errjson.Detail = "traceId: " + errjson.TraceId;
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = errjson.Status + " " + errjson.Title,
            SubText = errjson.Detail,
            IconType = TablerIcons.Alert_triangle,
            CancelText = "",
            StatusColor = TablerColor.Danger
        });
    }
}
