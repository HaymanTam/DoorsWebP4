@page "/userspasswords"
@using DoorsWeb.Client.Auth
@using DoorsWeb.Shared.Entities
@using DoorsWeb.Shared.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory ClientFactory
@inject AuthenticationStateProvider AuthState


<Card>
    <CardHeader>
        <CardTitle>
            <Icon class="icon me-2" IconType="@TablerIcons.User_star" />Users and Passwords
        </CardTitle>
    </CardHeader>
    <CardBody>
        @if (!IsLoaded)
        {
            <Progress Color="TablerColor.Blue" Indeterminate />
        }
        else
        {
            @if (!canWrite)
            {
                <div class="alert alert-info mb-3" role="alert">
                    <Icon class="icon me-2" IconType="@TablerIcons.Eye" />
                    You have read-only access to user settings. Adding, editing and deleting are disabled.
                </div>
            }
            <Table Item="Users" Items="userList" PageSize="10" AddItemFactory="addFactory"
                   OnItemAdded="OnItemAdd" OnItemEdited="OnItemEdit" OnItemDeleted="OnItemDelete"
                   Hover Responsive EditMode="TableEditMode.Inline"
                   AllowAdd="canWrite" AllowEdit="canWrite" AllowDelete="canWrite">
                <ChildContent>
                    <Column Item="Users" Property="e => e.Code" Title="User Id" Width="50px" Sortable Visible="false">
                        <EditorTemplate>
                            @(context.Code == 0 ? context.Code : "")
                            <InputNumber class="form-control" @bind-value="@context.Code" Hidden />
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Property="e => e.Description" Title="Name" Searchable Sortable>
                        <EditorTemplate>
                            <InputText class="form-control" @bind-value="@context.Description" DisplayName="name" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Property="e => e.Password" Title="Pass" Width="240px">
                        <Template>
                            ●●●●●●●●
                        </Template>
                        <EditorTemplate>
                            @* Native input bound on oninput so the strength meter updates live as you type. *@
                            <div style="max-width: 220px;">
                                <div class="input-group input-group-flat">
                                    <input type="@(showRowPwd ? "text" : "password")" class="form-control"
                                           value="@context.Password" aria-label="password"
                                           @oninput="e => context.Password = e.Value?.ToString() ?? string.Empty" />
                                    <span class="input-group-text">
                                        <a href="#" class="link-secondary" tabindex="-1" title="Show password"
                                           @onclick="() => showRowPwd = !showRowPwd" @onclick:preventDefault="true">
                                            <Icon class="icon" IconType="@(showRowPwd ? TablerIcons.Eye_off : TablerIcons.Eye)" />
                                        </a>
                                    </span>
                                </div>
                                <PasswordStrengthMeter Password="@context.Password" />
                            </div>
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Property="e => e.Administrator" Title="Super" Width="60px" Sortable>
                        <Template>
                            @if (context.Administrator)
                            {
                                <Icon class="icon text-green" IconType="@TablerIcons.Check" />
                            }
                            else
                            {
                                <Icon class="icon text-muted" IconType="@TablerIcons.X" />
                            }
                        </Template>
                        <EditorTemplate>
                            <Checkbox @bind-value="@context.Administrator" />
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Title="Card Manager" Width="130px">
                        <Template>@AreaDisplay(context, context.CardManagerAccess)</Template>
                        <EditorTemplate>
                            <select class="form-select" @bind="context.CardManagerAccess" disabled="@context.Administrator">
                                @foreach (var opt in AccessOptions)
                                {
                                    <option value="@opt.Key">@opt.Value</option>
                                }
                            </select>
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Title="Site Settings" Width="130px">
                        <Template>@AreaDisplay(context, context.SiteSettingsAccess)</Template>
                        <EditorTemplate>
                            <select class="form-select" @bind="context.SiteSettingsAccess" disabled="@context.Administrator">
                                @foreach (var opt in AccessOptions)
                                {
                                    <option value="@opt.Key">@opt.Value</option>
                                }
                            </select>
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Title="User Settings" Width="130px">
                        <Template>@AreaDisplay(context, context.UserSettingsAccess)</Template>
                        <EditorTemplate>
                            <select class="form-select" @bind="context.UserSettingsAccess" disabled="@context.Administrator">
                                @foreach (var opt in AccessOptions)
                                {
                                    <option value="@opt.Key">@opt.Value</option>
                                }
                            </select>
                        </EditorTemplate>
                    </Column>
                    <Column Item="Users" Title="Reports" Width="130px">
                        <Template>@AreaDisplay(context, context.ReportsAccess)</Template>
                        <EditorTemplate>
                            <select class="form-select" @bind="context.ReportsAccess" disabled="@context.Administrator">
                                @foreach (var opt in AccessOptions)
                                {
                                    <option value="@opt.Key">@opt.Value</option>
                                }
                            </select>
                        </EditorTemplate>
                    </Column>
                </ChildContent>
            </Table>
            @if (userList.Count == 0)
            {
                <div class="text-muted text-center py-4">No users found.</div>
            }
            <div class="text-muted small mt-2">
                <Icon class="icon icon-sm me-1" IconType="@TablerIcons.Info_circle" />
                A <strong>Super</strong> user has full access to every area and is the only role that can manage users.
                At least one Super must always exist.
            </div>
        }
    </CardBody>
</Card>



@code {
    [Inject] TabBlazor.Services.TablerService TablerService { get; set; } = null!;
    [Inject] TabBlazor.Services.IModalService ModalService { get; set; } = null!;

    private bool IsLoaded = false;
    private HttpClient client = new HttpClient();
    private List<Users> userList = new List<Users>();
    private bool showRowPwd;   // toggles the inline password editor between masked/clear

    // Whether the signed-in user may mutate (User Settings ReadWrite). Read-only users still
    // see the list. The API is the real boundary; this just hides the controls.
    // canWrite drives the Table's AllowAdd/AllowEdit/AllowDelete so read-only users get a view-only grid.
    private bool canWrite;
    private Func<Task<Users>>? addFactory;   // null = no Add button (read-only)

    // Dropdown options for the three area-access columns (value = AreaAccess int).
    private static readonly Dictionary<int, string> AccessOptions = new()
    {
        [(int)AreaAccess.None] = "None",
        [(int)AreaAccess.Read] = "Read",
        [(int)AreaAccess.ReadWrite] = "Read/Write",
    };

    // Snapshot of each user's saved password (by Code) so we only enforce strength when the
    // password actually changes - editing the name/admin flag of a legacy weak account is allowed.
    private Dictionary<int, string> originalPasswords = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        canWrite = state.User.CanWriteUserSettings();
        addFactory = canWrite ? AddItem : null;

        client = ClientFactory.CreateClient("WebAPI");
        userList = await client.GetFromJsonAsync<List<Users>>("api/Users") ?? [];
        SnapshotPasswords();
        IsLoaded = true;
    }

    private void SnapshotPasswords()
        => originalPasswords = userList.ToDictionary(u => u.Code, u => u.Password);

    // Number of Supers other than the given user. Used to block removing the last Super client-side
    // (the API also enforces this and returns 409).
    private int OtherSupers(int code) => userList.Count(u => u.Administrator && u.Code != code);

    private static string AccessLabel(int level) => level switch
    {
        (int)AreaAccess.ReadWrite => "Read/Write",
        (int)AreaAccess.Read => "Read",
        _ => "None"
    };

    // A Super has full access regardless of the stored per-area value.
    private static string AreaDisplay(Users user, int level) =>
        user.Administrator ? "Full (Super)" : AccessLabel(level);

    private Task<Users> AddItem()
    {
        // this function feeds default value
        return Task.FromResult(new Users { Code = 0, Description = "user", Password = "pass", Administrator = false });
    }

    private async Task OnItemAdd(Users user)
    {
        // New accounts must meet the strength bar; otherwise drop the unsaved row.
        if (!PasswordStrength.MeetsMinimum(user.Password))
        {
            userList.Remove(user);
            await ShowWeakPasswordDialog();
            return;
        }

        var result = await client.PostAsJsonAsync<Users>("api/Users/", user);
        if (result.IsSuccessStatusCode) await UpdateList();
        else {
            userList.Remove(user);
            await ShowErrorDialog(result);
        }
    }

    private async Task OnItemEdit(Users user)
    {
        // Last-Super protection: never let the only remaining Super be demoted.
        if (!user.Administrator && OtherSupers(user.Code) == 0)
        {
            await ShowLastSuperDialog("removing this user's Super status");
            await UpdateList();   // discard the unsaved change by reloading server state
            return;
        }

        // Only enforce strength when the password was actually changed in this edit.
        bool passwordChanged = !(originalPasswords.TryGetValue(user.Code, out var orig) && orig == user.Password);
        if (passwordChanged && !PasswordStrength.MeetsMinimum(user.Password))
        {
            await ShowWeakPasswordDialog();
            await UpdateList();   // discard the unsaved weak change by reloading server state
            return;
        }

        var result = await client.PutAsJsonAsync<Users>("api/Users/" + user.Code, user);
        if (!result.IsSuccessStatusCode)
        {
            await ShowErrorDialog(result);
            await UpdateList();
        }
        else SnapshotPasswords();   // the saved password is the new baseline
    }

    private async Task OnItemDelete(Users user)
    {
        // Last-Super protection: never delete the only remaining Super.
        if (user.Administrator && OtherSupers(user.Code) == 0)
        {
            await ShowLastSuperDialog("deleting this user");
            await UpdateList();
            return;
        }

        userList = await client.DeleteFromJsonAsync<List<Users>>("api/Users/" + user.Code) ?? [];
        SnapshotPasswords();
    }

    private async Task UpdateList()
    {
        userList = await client.GetFromJsonAsync<List<Users>>("api/Users") ?? [];
        SnapshotPasswords();
    }

    private async Task ShowWeakPasswordDialog()
    {
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = "Password too short",
            SubText = "Use at least 12 characters before saving. A short passphrase of a few words works well — length matters more than mixing in symbols.",
            IconType = TablerIcons.Lock,
            CancelText = "",
            StatusColor = TablerColor.Warning
        });
    }

    private async Task ShowLastSuperDialog(string action)
    {
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = "At least one Super must remain",
            SubText = $"Promote another user to Super before {action}.",
            IconType = TablerIcons.Shield_lock,
            CancelText = "",
            StatusColor = TablerColor.Warning
        });
    }

    private async Task ShowErrorDialog(HttpResponseMessage result)
    {
        ClientProblemDetails errjson;
        try
        {
            errjson = await result.Content.ReadFromJsonAsync<ClientProblemDetails>() ??
                new ClientProblemDetails { Status = 500, Title = "Error Returned Null!", Detail = "An unexpected error occurred." };
        }
        catch
        {
            errjson = new ClientProblemDetails { Status = 500, Title = "Unable to Read Error!", Detail = "Failed to read error response." };
        }
        if (errjson.Status == 500) errjson.Detail = "traceId: " + errjson.TraceId;
        await ModalService.ShowDialogAsync(new TabBlazor.Components.Modals.DialogOptions
        {
            MainText = errjson.Status + " " + errjson.Title,
            SubText = errjson.Detail,
            IconType = TablerIcons.Alert_triangle,
            CancelText = "",
            StatusColor = TablerColor.Danger
        });
    }
}
